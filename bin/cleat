#!/usr/bin/env bash
set -euo pipefail

# ── Config ──────────────────────────────────────────────────────────────────
VERSION="1.1.0"
# Gates the on-start release highlight (_maybe_show_release_highlight): must
# equal VERSION to fire. Bump it to the new VERSION at each tag so the
# maintainer-curated highlight re-surfaces for that release; a mismatch shows
# nothing (fail-safe). The highlight COPY and its version label are editorial,
# set by hand below, not derived from VERSION (a big feature stays highlighted
# across several releases, labelled with the version it shipped in).
RELEASE_HIGHLIGHT_VERSION="1.1.0"
# How many launches after an upgrade the highlight is shown before going quiet.
# Bounded repetition aids feature discovery (people miss it the first time)
# without training the eye to skip the startup block, where drift/update/security
# notices also live. See concept/21-on-start-notices.md.
RELEASE_HIGHLIGHT_MAX_SHOWS=3
IMAGE_NAME="cleat"
REGISTRY_BASE="ghcr.io/cleatdev/cleat"
REGISTRY_IMAGE="${REGISTRY_BASE}:v${VERSION}"
REPO_URL="https://github.com/cleatdev/cleat"

# Image content identity, DELIBERATELY decoupled from VERSION.
#
# The on-start rebuild prompt used to fire whenever the image's baked CLI
# version was older than this CLI, so a version-only release (no change under
# docker/) still nagged every user to re-pull and recreate their container,
# discarding its writable layer for nothing. ~Two-thirds of recent releases
# were version-only. This integer tracks the IMAGE CONTENT instead.
#
# Bump _IMAGE_SPEC_VERSION by one (1 -> 2 -> 3 ...) whenever anything that lands
# in the built image changes: docker/Dockerfile, docker/entrypoint.sh,
# docker/clip, docker/clip-daemon, docker/open-bridge, docker/CLAUDE.md, or a
# pinned base. A CLI-only release leaves it untouched and no one is nagged.
# It is stamped onto the image as the sh.cleat.image-spec label (by _do_build,
# cmd_rebuild, and the publish CI) and read back by _maybe_prompt_image_rebuild,
# which prompts only when the local image's spec is OLDER than this value.
#
# A unit test (test/unit/image_spec.bats) hashes the build inputs and FAILS if
# they change without this being bumped, so it can never be silently forgotten.
# See concept/24-image-spec-versioning.md.
#
# Spec history (what each value shipped):
#   1  initial scheme; floating node:24-bookworm-slim base
#   2  base image pinned by digest (reproducible base; see docker/Dockerfile)
_IMAGE_SPEC_VERSION=2
# Anchor for classifying PRE-STAMPING images (built before sh.cleat.image-spec
# existed, so they carry no spec label): their content is inferred from the
# version they were built at. v0.16.3 was the LAST docker/ content change before
# stamping, so a label-less image built at or after it carries that pre-pin,
# floating-base content == spec 1; an older label-less image predates even that
# and is treated as spec 0. Both are then compared against _IMAGE_SPEC_VERSION,
# so on the release that introduces this scheme (spec 2, pinned base) a label-less
# spec-1 image is correctly offered the one-time refresh to the pinned base. This
# anchor never moves: every image built from the stamping release on carries an
# explicit label, so the inference path only ever sees genuinely pre-stamping
# images.
_IMAGE_SPEC_INTRO_VERSION="0.16.3"
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# XDG-compliant config directory
CLEAT_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/cleat"
CLEAT_GLOBAL_CONFIG="$CLEAT_CONFIG_DIR/config"
CLEAT_GLOBAL_ENV="$CLEAT_CONFIG_DIR/env"

# Per-container runtime state: the settings overlay, clipboard bridge, and hook
# event spool. Persistent (deliberately NOT under /tmp) so macOS file rotation
# and reboots can't delete a container's bind-mount sources out from under it and
# force a recreate (which would discard the container's writable layer, e.g. an
# ad-hoc `az` install). One dir per container, NOT mounted into the container:
#   $CLEAT_RUN_DIR/<cname>/{settings,clip,hooks}
CLEAT_RUN_DIR="$CLEAT_CONFIG_DIR/run"
CLEAT_TRUST_FILE="$CLEAT_CONFIG_DIR/trust"
# Host-side per-box descriptions, keyed by container name. NOT Docker labels:
# labels are immutable, so editing one would force a recreate that wipes the
# writable layer (e.g. an `az login`). See concept/20-boxes.md.
CLEAT_BOXES_DIR="$CLEAT_CONFIG_DIR/boxes"

# Persistent per-project Claude global-state (.claude.json) store. Unlike
# $CLEAT_RUN_DIR (per-container, wiped on `cleat rm`/recreate), this is keyed by
# PROJECT and deliberately survives recreate so a project's trust/MCP approvals
# persist. One file per project: $CLEAT_PROJECTS_DIR/<project_session_key>/claude.json
CLEAT_PROJECTS_DIR="$CLEAT_CONFIG_DIR/projects"

# Known capabilities (order matters for display).
# Two behavioral categories. See _cap_category for the mapping:
#   mount   git, ssh, env, hooks, gh   auth/identity bind-mounts (no install)
#   sandbox docker                     mounts host docker socket (breaks isolation)
KNOWN_CAPS=(git ssh env hooks gh docker)

# Session-scoped state (populated by parse_global_flags / cmd_run / cmd_resume)
_CLI_CAPS=()
_RESOLVED_PROJECT=""
# The active box: a named per-project sandbox (see concept/20-boxes.md).
# Default "main" = the legacy suffix-less container. Set by the dispatch via
# _set_box for box-aware verbs; stays "main" for everything else.
_BOX="main"
_CLI_ENVS=()
_CLI_ENV_FILES=()
_CLI_TRUST_PROJECT=0
_CLI_DESC=""
_CLI_DESC_SET=0
# Original argv as `main` received it, used by the CLI self-update preflight to
# re-exec the freshly-installed version with the same command.
_CLEAT_ORIG_ARGV=()

# Caps display buckets (populated by _caps_bucket_active for _print_caps).
_CAPS_MOUNT=()
_CAPS_SANDBOX=()

# ── Colors & Formatting ────────────────────────────────────────────────────
BOLD='\033[1m'
DIM='\033[2m'
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
# Amber/orange for warnings, visually distinct from the neutral-yellow status
# markers. xterm-256 color 214 (~#ffaf00) approximates the site's warning orange
# rgb(245,158,11) and renders correctly everywhere 256-color is supported
# (Terminal.app, iTerm2, Linux terminals, VS Code), unlike 24-bit truecolor,
# which degrades to the default foreground on terminals that don't support it.
AMBER='\033[38;5;214m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
UNDERLINE='\033[4m'
RESET='\033[0m'

header() {
  echo ""
  echo -e "${BOLD}${CYAN}  ┌───────────────────────────────────────────┐${RESET}"
  echo -e "${BOLD}${CYAN}  │   Cleat                                   │${RESET}"
  echo -e "${BOLD}${CYAN}  │   Give the agent a cage, not your keys.   │${RESET}"
  echo -e "${BOLD}${CYAN}  │   Unattended, not unguarded.              │${RESET}"
  echo -e "${BOLD}${CYAN}  └───────────────────────────────────────────┘${RESET}"
  echo ""
}

info()    { echo -e "  ${BLUE}▸${RESET} $1"; }
success() { echo -e "  ${GREEN}✔ $1${RESET}"; }
warn()    { echo -e "  ${AMBER}!${RESET} $1"; }
# A sandbox-break warning: the whole line renders in the sandbox amber (marker
# AND message), so it reads as loud as the `docker` cap it warns about. Unlike
# generic warn(), which tints only the `!` marker and leaves the text default.
warn_sandbox() { echo -e "  ${AMBER}! $1${RESET}"; }
error()   { echo -e "  ${RED}✖${RESET} $1"; }

# Aligned interactive Y/n prompt that pairs with an info()/warn() headline.
# The headline owns the icon (▸/!); the question continues underneath it,
# indented to sit under the headline TEXT (4 spaces), not back at the margin.
# Reads one line into the named variable. TTY-gating is the caller's job.
#
# A `read` FAILURE (EOF: e.g. `cleat start </dev/null`, a wrapper that redirects
# stdin, a non-interactive pipe) yields "n", i.e. DECLINE, never an empty string.
# Callers treat empty as the [Y/n] default of yes, so without this a redirected
# stdin would silently auto-accept destructive actions (git checkout + re-exec,
# a rebuild) with no human input. Empty-as-yes only happens on a real Enter press.
# Usage: _ask_yn answer "Rebuild now? [Y/n] "
_ask_yn() {
  local _var="$1" _prompt="$2"
  echo -en "    ${_prompt}"
  local _reply=""
  read -r _reply || { printf -v "$_var" '%s' 'n'; return 0; }
  printf -v "$_var" '%s' "$_reply"
}

# ── Spinner ────────────────────────────────────────────────────────────────
_SPIN_PID=""

_is_tty() { [[ -t 1 ]]; }

_has_unicode() {
  local lang="${LANG:-}${LC_ALL:-}${LC_CTYPE:-}"
  [[ "$lang" == *UTF-8* ]] || [[ "$lang" == *utf8* ]]
}

# True when the terminal is known to render OSC 8 hyperlinks (and we're on a
# TTY). Deliberately a conservative allow-list: a miss just falls back to a bare
# clickable URL (see _hyperlink), so we never risk escape garbage on an unknown
# or old terminal, a multiplexer, or piped output. Covers the terminals the
# maintainer's audience actually uses; Apple Terminal is intentionally absent
# (it has no OSC 8 but autodetects bare URLs itself).
_supports_osc8() {
  _is_tty || return 1
  case "${TERM_PROGRAM:-}" in
    iTerm.app|vscode|WezTerm|ghostty|Hyper|Tabby|rio) return 0 ;;
  esac
  [[ -n "${KITTY_WINDOW_ID:-}" || -n "${WEZTERM_PANE:-}" || -n "${GHOSTTY_BIN_DIR:-}" ]] && return 0
  # GNOME VTE 0.50+ (VTE_VERSION ≥ 5000) added OSC 8 support.
  [[ "${VTE_VERSION:-}" =~ ^[0-9]+$ ]] && (( ${VTE_VERSION:-0} >= 5000 )) && return 0
  return 1
}

# Render a terminal hyperlink. In OSC-8-capable terminals (iTerm2, VS Code,
# WezTerm, Ghostty, kitty, GNOME/VTE…) the short TEXT becomes a clickable link to
# URL; elsewhere it degrades to the bare URL, which terminals like Apple Terminal
# autodetect and make clickable on their own (so it's always at least copyable).
# OSC 8 format:  ESC ] 8 ; ; URL  ST   TEXT   ESC ] 8 ; ; ST     (ST = ESC \).
# Prints with no trailing newline; callers add color/underline around it.
_hyperlink() {
  local url="$1" text="${2:-$1}"
  if _supports_osc8; then
    printf '\033]8;;%s\033\\%s\033]8;;\033\\' "$url" "$text"
  else
    printf '%s' "$url"
  fi
}

spin() {
  local msg="$1"
  if ! _is_tty; then
    info "$msg"
    return
  fi
  # A second spin() before spin_stop would orphan the first frame loop and
  # interleave two \r-animations into garbage. Stop the old one first.
  [[ -n "${_SPIN_PID:-}" ]] && _cleanup_spin
  local frames
  if _has_unicode; then
    frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
  else
    frames=('-' '\' '|' '/')
  fi
  command -v tput &>/dev/null && tput civis 2>/dev/null
  local _spin_parent=$$
  (
    trap 'exit 0' TERM INT
    local i=0
    while kill -0 "$_spin_parent" 2>/dev/null; do
      printf "\r  ${BLUE}%s${RESET} %s" "${frames[$i]}" "$msg"
      i=$(( (i + 1) % ${#frames[@]} ))
      sleep 0.08
    done
    # Parent died without spin_stop (SIGKILL, hard crash): erase the frame and
    # restore the cursor instead of overwriting the shell prompt every 80 ms
    # with the cursor left hidden. The old spinner was un-disownable spam.
    printf "\r\033[K"
    { command -v tput &>/dev/null && tput cnorm 2>/dev/null; } || true
  ) &
  _SPIN_PID=$!
  # NOT disowned: spin_stop's `wait` must synchronize with the loop's exit so
  # no final frame can print after the ✔/✖ line (wait on a disowned pid is a
  # no-op race).
}

spin_stop() {
  local code="$1" ok_msg="$2" fail_msg="${3:-$2}"
  if [[ -n "$_SPIN_PID" ]]; then
    kill "$_SPIN_PID" 2>/dev/null || true
    wait "$_SPIN_PID" 2>/dev/null || true
    _SPIN_PID=""
    { command -v tput &>/dev/null && tput cnorm 2>/dev/null; } || true
  fi
  if ! _is_tty; then
    [[ "$code" -eq 0 ]] && success "$ok_msg" || error "$fail_msg"
    return
  fi
  if [[ "$code" -eq 0 ]]; then
    printf "\r\033[K  ${GREEN}✔ %s${RESET}\n" "$ok_msg"
  else
    printf "\r\033[K  ${RED}✖${RESET} %s\n" "$fail_msg"
  fi
}

_cleanup_spin() {
  if [[ -n "${_SPIN_PID:-}" ]]; then
    kill "$_SPIN_PID" 2>/dev/null || true
    wait "$_SPIN_PID" 2>/dev/null || true
    _SPIN_PID=""
  fi
  { command -v tput &>/dev/null && tput cnorm 2>/dev/null; } || true
}

# Restore the host terminal after an interactive `docker exec`. The docker CLI
# only undoes the termios state it set itself; private modes enabled by the
# in-box TUI: alternate screen, mouse tracking, bracketed paste, hidden
# cursor: survive a hard crash (a SIGSEGV'd claude, fork lockup at the pids
# cap) and leave the terminal spraying escape garbage on every keystroke and
# mouse move until a manual `reset`. Every sequence here is a no-op on a
# terminal already in a clean state, so this is safe after normal exits too.
_restore_terminal() {
  _is_tty || return 0
  {
    stty sane
    printf '\033[?1049l\033[?2004l\033[?1000l\033[?1002l\033[?1003l\033[?1006l\033[?25h\033[0m'
  } </dev/tty >/dev/tty 2>/dev/null || true
}

# ── Keypress reader for TUI ────────────────────────────────────────────────
_read_keypress() {
  local key
  IFS= read -rsn1 key 2>/dev/null || true
  if [[ "$key" == $'\e' ]]; then
    # Read the rest of the escape sequence in one call.
    # Arrow keys send \e[A/B/C/D. Read up to 2 chars with a timeout.
    local seq=""
    IFS= read -rsn2 -t 1 seq 2>/dev/null || true
    case "$seq" in
      "[A") echo "UP" ;;
      "[B") echo "DOWN" ;;
      *)    echo "ESC" ;;
    esac
  elif [[ "$key" == " " ]]; then
    echo "SPACE"
  elif [[ "$key" == "" ]]; then
    echo "ENTER"
  elif [[ "$key" == "q" || "$key" == "Q" ]]; then
    echo "QUIT"
  else
    echo "OTHER"
  fi
}

# Portable MD5: works on both Linux (md5sum) and macOS (md5 -q)
_md5() {
  if command -v md5sum &>/dev/null; then
    md5sum
  elif command -v md5 &>/dev/null; then
    md5 -q
  else
    cksum | awk '{print $1}'
  fi
}

# ── Project-scoped container naming ─────────────────────────────────────────
container_name_for() {
  local project_path="$1"
  local box="${2:-}"
  local dir_name hash suffix=""
  # A named (non-default) box folds in as a trailing -<box>. The default box
  # ("main" or empty) gets the legacy suffix-less name: zero migration for
  # existing containers (see concept/20-boxes.md). The 8-char hash is ALWAYS
  # preserved; only the human-readable dir segment is re-truncated to fit.
  if [[ -n "$box" && "$box" != "main" ]]; then
    suffix="-${box}"
  fi
  dir_name="$(basename "$project_path" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g')"
  # Keep the full name under Docker's 63-char limit:
  #   "cleat-" (6) + dir + "-" (1) + hash8 (8) + suffix = 15 + dir + |suffix|.
  # Budget the remaining room (48 minus the suffix length) for dir_name.
  local max_dir=$(( 48 - ${#suffix} ))
  (( max_dir < 1 )) && max_dir=1
  dir_name="${dir_name:0:$max_dir}"
  # Remove trailing dash from truncation
  dir_name="${dir_name%-}"
  hash="$(echo -n "$project_path" | _md5 | head -c 8)"
  echo "cleat-${dir_name}-${hash}${suffix}"
}

# Validate a box name. Boxes are named, per-project sandboxes (see
# concept/20-boxes.md): 1–31 chars, must start with a lowercase alnum, and may
# contain lowercase alnum, dash, or underscore. The pattern is held in a
# variable and used UNQUOTED: bash 3.2 treats a quoted =~ RHS as a literal
# string, which would silently break matching.
_validate_box_name() {
  local box="$1"
  local _box_re='^[a-z0-9][a-z0-9_-]{0,30}$'
  [[ "$box" =~ $_box_re ]]
}

# Derive the per-project session key used for Claude session/history isolation
# and the per-project .claude.json store (see concept/19-claude-json-isolation.md
# and concept/20-boxes.md). The DEFAULT box ("main" or empty) returns the legacy
# <basename>-<hash8> key BYTE-IDENTICALLY: folding a suffix in for the default
# would orphan every existing user's session history on upgrade. A named box
# appends "-<box>" so two boxes over one workspace never share sessions.
_derive_project_session_key() {
  local project="$1"
  local box="${2:-}"
  local _basename _hash key
  _basename="$(basename "$project" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g')"
  _hash="$(echo -n "$project" | _md5 | head -c 8)"
  key="${_basename}-${_hash}"
  if [[ -n "$box" && "$box" != "main" ]]; then
    key="${key}-${box}"
  fi
  echo "$key"
}

# Parse and validate the box positional for a box-aware verb (see
# concept/20-boxes.md). Sets the global _BOX; an empty arg → the default box
# "main". Prints an error and exits on an invalid name. Call from the dispatch
# DIRECTLY, not inside $(...), so the exit propagates to the whole process.
_set_box() {
  local box="${1:-}"
  # A box-aware verb takes exactly one [box] positional; reject stray args so a
  # typo like `cleat stop az dev` errors instead of silently acting on only az.
  if [[ $# -gt 1 ]]; then
    error "Unexpected argument: ${BOLD}${2}${RESET}"
    echo -e "    ${DIM}A box-aware command takes a single [box] name.${RESET}"
    exit 1
  fi
  if [[ -z "$box" ]]; then
    _BOX="main"
    return 0
  fi
  if ! _validate_box_name "$box"; then
    error "Invalid box name: ${BOLD}${box}${RESET}"
    echo -e "    ${DIM}Box names: lowercase letters, digits, '-' or '_'; max 31 chars (e.g. ${BOLD}az${RESET}${DIM}, ${BOLD}dev${RESET}${DIM}).${RESET}"
    exit 1
  fi
  _BOX="$box"
}

resolve_project() {
  local project="${1:-$PWD}"
  if [[ -d "$project" ]]; then
    (cd "$project" && pwd)
  else
    echo "$project"
  fi
}

# ── Helpers ─────────────────────────────────────────────────────────────────
is_running() {
  docker ps --filter "name=^${1}$" --format '{{.Names}}' 2>/dev/null | grep -q "^${1}$"
}

container_exists() {
  docker ps -a --filter "name=^${1}$" --format '{{.Names}}' 2>/dev/null | grep -q "^${1}$"
}

image_exists() {
  docker images --format '{{.Repository}}' 2>/dev/null | grep -q "^${IMAGE_NAME}$"
}

# GOARCH of the docker daemon (arm64/amd64): the architecture containers
# actually run as. Read from the SERVER, not uname: with a remote DOCKER_HOST
# the local machine's arch is irrelevant. Empty when unreachable (callers
# must fail open).
_daemon_arch() {
  docker version --format '{{.Server.Arch}}' 2>/dev/null || true
}

# GOARCH of a local image, empty if unknown/absent.
_image_arch() {
  docker image inspect "$1" --format '{{.Architecture}}' 2>/dev/null || true
}

# True when the image's architecture matches the daemon's, i.e. its
# containers run natively. Unknown daemon or image arch fails OPEN (ok): an
# unreachable daemon or exotic setup must never force a rebuild loop. FALSE
# means the image would run under emulation: slow, and the documented
# trigger for node segfaults and garbled TTYs on Apple Silicon (Docker calls
# amd64-on-arm "best effort"). Callers treat such an image as missing and
# re-acquire a native one.
_image_arch_ok() {
  local image="${1:-$IMAGE_NAME}"
  local want have
  want="$(_daemon_arch)"
  [[ -n "$want" ]] || return 0
  have="$(_image_arch "$image")"
  [[ -n "$have" ]] || return 0
  [[ "$have" == "$want" ]]
}

# One-line explanation used by the acquisition gates when replacing an
# emulated image with a native one.
_warn_image_emulated() {
  warn "Local image is ${BOLD}$(_image_arch "$IMAGE_NAME")${RESET} but Docker runs ${BOLD}$(_daemon_arch)${RESET}. Emulated boxes are slow and crash-prone; fetching a native image"
}

require_running() {
  local cname="$1"
  if ! is_running "$cname"; then
    error "Container ${BOLD}${cname}${RESET} is not running."
    echo -e "    ${DIM}Start it with: cleat start${RESET}"
    exit 1
  fi
}

# ── Host connectivity ────────────────────────────────────────────────────
# Docker Desktop (macOS/Windows) provides host.docker.internal automatically.
# On Linux with Docker Engine, we need --add-host for it.
_is_docker_desktop() {
  # Read JUST the OperatingSystem field via --format, NOT `docker info | grep`.
  # The piped form is SIGPIPE-fragile under `set -o pipefail` (which the real
  # binary runs): when `grep -q` matches it exits immediately and closes the
  # pipe, `docker info` then dies of SIGPIPE (141) on its next write, and
  # pipefail reports the whole pipeline as FAILED even though it matched. Under
  # memory pressure `docker info` is slow and has lots still to write when grep
  # bails, so the race tips to "failed" exactly when the Docker-Desktop-only VM
  # advisory needs to fire: the on-start "give Docker more memory" steps then
  # silently vanished (observed v0.16.1). The format query has no pipe, no race,
  # and is cheaper (one field, not the whole info dump).
  local os
  os="$(docker info --format '{{.OperatingSystem}}' 2>/dev/null)" || return 1
  [[ "$os" == *"Docker Desktop"* ]]
}

# True on macOS. macOS keeps Claude Code's OAuth login in the login Keychain,
# not in ~/.claude/.credentials.json, so the shared ~/.claude mount carries no
# token and a freshly-auth'd host still re-prompts inside the box. The seed
# helpers below bridge that gap. Overridable in tests.
_is_macos() {
  [[ "${OSTYPE:-}" == darwin* ]] || [[ "$(uname -s 2>/dev/null)" == "Darwin" ]]
}

# Read Claude Code's OAuth credential blob from the macOS login Keychain. Claude
# stores it as a generic-password under the service "Claude Code-credentials"
# (older builds: "Claude Code"); `-w` prints just the secret (the JSON blob).
# Prints the blob on stdout, nothing on failure. `security` may pop a one-time
# Keychain access dialog the first time. Once the user clicks "Always Allow"
# it's silent; a denied/headless read (errSecInteractionNotAllowed over SSH)
# simply fails and we fall through. Overridable in tests.
_macos_keychain_credentials() {
  command -v security &>/dev/null || return 1
  local svc blob
  for svc in "Claude Code-credentials" "Claude Code"; do
    blob="$(security find-generic-password -s "$svc" -w 2>/dev/null)" || continue
    [[ -n "$blob" ]] && { printf '%s' "$blob"; return 0; }
  done
  return 1
}

# Extract the OAuth token's expiry (epoch MILLISECONDS) from a Claude credentials
# blob on stdin; empty when absent or unparseable. Pure-bash grep (no jq dep),
# case-insensitive so it matches `expiresAt` whatever the wrapper key around it,
# same leading-zero-safe style as the swap reader. Claude stores expiresAt in ms;
# a missing, non-numeric, or seconds-scaled value just fails the validity compare
# in _seed_macos_credentials, which then keeps the existing file untouched (the
# safe path). Overridable indirectly via the blob the caller pipes in.
_oauth_expires_at() {
  local n
  n="$(grep -iEo '"expiresat"[[:space:]]*:[[:space:]]*[0-9]+' 2>/dev/null \
         | grep -Eo '[0-9]+' | tail -1 || true)"
  [[ "$n" =~ ^[0-9]+$ ]] && printf '%s' "$n"
  # Always succeed: the caller assigns this in `x="$(...)"`, and a non-zero exit
  # there trips the CLI's `set -e` (a missing/absent expiresAt is normal, not an
  # error). The empty stdout is the signal; the exit code must stay 0.
  return 0
}

# On macOS, materialize the Keychain-stored OAuth credential into
# ~/.claude/.credentials.json (the path Claude reads on Linux), so the box,
# which only sees the mounted ~/.claude dir, never the Keychain, starts
# authenticated instead of re-prompting. The blob is validated as a JSON object
# and written 0600. No-op off macOS or when the Keychain has nothing.
#
# When to (re)seed:
#   - File ABSENT/empty  -> seed (Linux hosts already have it; this never runs).
#   - File PRESENT       -> re-seed ONLY when its OAuth token has EXPIRED *and*
#                           the Keychain holds a fresher, still-valid one.
# The re-seed closes the host-re-login gap (concept/23 open item): a host
# re-login rotates the Keychain token and invalidates the file's now-stale
# refresh token, so a freshly-created box that has never refreshed reads a dead
# token from the shared file and drops to an interactive LOGIN. A still-valid
# file token is never touched (the box refreshes its own and may be fresher than
# the Keychain). Anything we can't parse (no expiresAt, non-numeric, seconds
# scale) falls through to "keep the file", so an unrecognized schema can never
# trigger a clobber. Sets _SEEDED_CREDS=1 on a write. _CLEAT_NOW_S overrides the
# clock for tests.
_SEEDED_CREDS=0
_seed_macos_credentials() {
  _is_macos || return 0
  local cred="${HOME}/.claude/.credentials.json"
  local blob=""
  if [[ -s "$cred" ]]; then
    local file_exp kc_exp now_ms
    file_exp="$(_oauth_expires_at < "$cred" 2>/dev/null)"
    [[ "$file_exp" =~ ^[0-9]+$ ]] || return 0          # unparseable file token -> keep
    now_ms=$(( ${_CLEAT_NOW_S:-$(date +%s)} * 1000 ))
    (( file_exp > now_ms )) && return 0                # file token still valid -> keep
    blob="$(_macos_keychain_credentials)" || return 0
    [[ -n "$blob" ]] || return 0
    kc_exp="$(printf '%s' "$blob" | _oauth_expires_at 2>/dev/null)"
    [[ "$kc_exp" =~ ^[0-9]+$ ]] || return 0            # unparseable keychain token -> keep
    # Only a Keychain token that is BOTH fresher than the file's AND not itself
    # expired earns the overwrite; otherwise keep what we have.
    (( kc_exp > file_exp && kc_exp > now_ms )) || return 0
  else
    blob="$(_macos_keychain_credentials)" || return 0
    [[ -n "$blob" ]] || return 0
  fi
  mkdir -p "${HOME}/.claude" 2>/dev/null || return 0
  local tmp="${cred}.tmp.$$"
  ( umask 077; printf '%s' "$blob" > "$tmp" ) 2>/dev/null || { rm -f "$tmp" 2>/dev/null; return 0; }
  # Never write a non-JSON-object (e.g. an error string) into the creds file.
  local ok=false
  if command -v jq &>/dev/null; then
    jq -e 'type=="object"' "$tmp" >/dev/null 2>&1 && ok=true
  else
    _looks_like_json_object "$tmp" && ok=true
  fi
  if $ok; then
    chmod 600 "$tmp" 2>/dev/null || true
    if mv -f "$tmp" "$cred" 2>/dev/null; then _SEEDED_CREDS=1; else rm -f "$tmp" 2>/dev/null; fi
  else
    rm -f "$tmp" 2>/dev/null
  fi
  return 0
}

_host_connectivity_args() {
  local args=()
  if ! _is_docker_desktop 2>/dev/null; then
    args+=(--add-host "host.docker.internal:host-gateway")
  fi
  echo "${args[@]+"${args[@]}"}"
}

# ── Capabilities: config file reading ──────────────────────────────────────
# Read capabilities from a config file. Returns newline-separated cap names.
# Config format: [caps] section header, then one cap name per line.
_read_caps_from_file() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  local in_caps=false
  # `|| [[ -n "$line" ]]` so a final line with no trailing newline (common in
  # hand-edited .cleat/config files, e.g. `printf '[caps]\nenv'`) is still read;
  # without it `read` returns non-zero at EOF and the last capability is silently
  # dropped. Matches the env-file parser (_parse_env_file).
  while IFS= read -r line || [[ -n "$line" ]]; do
    # Strip carriage return (CRLF from Windows editors)
    line="${line%$'\r'}"
    # Strip leading/trailing whitespace
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    # Skip empty lines and comments
    [[ -z "$line" || "$line" == \#* ]] && continue
    # Section header
    if [[ "$line" == "["*"]" ]]; then
      [[ "$line" == "[caps]" ]] && in_caps=true || in_caps=false
      continue
    fi
    if $in_caps; then
      echo "$line"
    fi
  done < "$file"
}

# Write capabilities to a config file. Preserves non-[caps] sections.
_write_caps_to_file() {
  local file="$1"
  shift
  local caps=("$@")

  mkdir -p "$(dirname "$file")"

  # If file exists, preserve everything outside [caps] section
  local preserved=""
  if [[ -f "$file" ]]; then
    local in_caps=false
    while IFS= read -r line; do
      line="${line%$'\r'}"
      if [[ "$line" == "[caps]" ]]; then
        in_caps=true
        continue
      fi
      if $in_caps; then
        # Skip lines in old [caps] section until next section or EOF
        if [[ "$line" == "["*"]" ]]; then
          in_caps=false
          preserved+="$line"$'\n'
        fi
        continue
      fi
      preserved+="$line"$'\n'
    done < "$file"
  fi

  # Write preserved content + new [caps] section
  {
    if [[ -n "$preserved" ]]; then
      printf '%s' "$preserved"
    fi
    if [[ ${#caps[@]} -gt 0 ]]; then
      echo "[caps]"
      for cap in "${caps[@]}"; do
        echo "$cap"
      done
    fi
  } > "$file"
}

# Resolve which project cap file applies to a box (see concept/20-boxes.md):
# a named box uses .cleat.<box> if present, ELSE falls back to .cleat. The
# default/"main" box always uses .cleat. REPLACE semantics: a box file fully
# replaces .cleat (it does NOT inherit), which is what enables least privilege:
# a box can declare FEWER caps than the project default.
_project_caps_file() {
  local project="$1" box="${2:-main}"
  if [[ "$box" != "main" && -f "$project/.cleat.$box" ]]; then
    echo "$project/.cleat.$box"
  else
    echo "$project/.cleat"
  fi
}

# Same fallback shape for the env file: .cleat.<box>.env else .cleat.env, so
# an az box's cloud credentials are never visible to a dev box.
_project_env_file() {
  local project="$1" box="${2:-main}"
  if [[ "$box" != "main" && -f "$project/.cleat.$box.env" ]]; then
    echo "$project/.cleat.$box.env"
  else
    echo "$project/.cleat.env"
  fi
}

# ── Resources: per-box memory limit ──────────────────────────────────────────
# Read one key from a config file's [resources] section. Lines are
# `key = value` (spaces optional). Same parsing hygiene as [caps]: CRLF-safe,
# comment- and whitespace-tolerant. Prints the value, or nothing when absent.
_read_resource_from_file() {
  local file="$1" key="$2"
  [[ -f "$file" ]] || return 0
  local in_section=false line k v
  # `|| [[ -n "$line" ]]` so a final line with no trailing newline (a hand-edited
  # `.cleat` ending in `memory = 8g`) is still read; without it `read` returns
  # non-zero at EOF and the configured ceiling is silently dropped, falling back
  # to the VM-derived default. Matches _read_caps_from_file and _parse_env_file.
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%$'\r'}"
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z "$line" || "$line" == \#* ]] && continue
    if [[ "$line" == "["*"]" ]]; then
      [[ "$line" == "[resources]" ]] && in_section=true || in_section=false
      continue
    fi
    $in_section || continue
    [[ "$line" == *"="* ]] || continue
    k="${line%%=*}"
    v="${line#*=}"
    k="${k%"${k##*[![:space:]]}"}"
    v="${v#"${v%%[![:space:]]*}"}"
    if [[ "$k" == "$key" ]]; then
      echo "$v"
      return 0
    fi
  done < "$file"
}

# A docker memory value: positive integer with optional b/k/m/g suffix.
_valid_memory_value() {
  [[ "$1" =~ ^[0-9]+[bkmgBKMG]?$ ]] || return 1
  local n="${1%[bkmgBKMG]}"
  [[ -n "$n" ]] || return 1
  # Per-suffix digit caps keep the byte conversion inside 64-bit arithmetic.
  # An overflowed product WRAPS (possibly negative), slips past the 8g project
  # clamp comparison, and then aborts `docker run` with an opaque daemon error,
  # so e.g. "99999999999g" must be rejected here, not discovered by dockerd.
  case "$1" in
    *[gG]) [[ ${#n} -le 9 ]] || return 1 ;;
    *[mM]) [[ ${#n} -le 12 ]] || return 1 ;;
    *[kK]) [[ ${#n} -le 15 ]] || return 1 ;;
    *)     [[ ${#n} -le 18 ]] || return 1 ;;
  esac
  # Force base-10: a leading zero ("08g") is otherwise an octal parse error in
  # bash arithmetic, and all-zero spellings ("0", "00g") mean --memory 0,
  # which docker treats as UNLIMITED, a clamp bypass rather than a limit.
  (( 10#$n > 0 ))
}

# Convert a validated memory value to bytes (for clamping comparisons).
_mem_to_bytes() {
  local v="$1" n unit
  n="${v%[bkmgBKMG]}"
  unit="${v#"$n"}"
  n=$(( 10#$n ))   # strip leading zeros; bare $((08*…)) is an octal error
  case "$unit" in
    [gG]) echo $(( n * 1073741824 )) ;;
    [mM]) echo $(( n * 1048576 )) ;;
    [kK]) echo $(( n * 1024 )) ;;
    *)    echo "$n" ;;
  esac
}

# The Docker VM's total memory in bytes (empty when unknown). Split out so
# tests and the overload check can override/reuse it.
_docker_vm_memory() {
  docker info --format '{{.MemTotal}}' 2>/dev/null || true
}

# Round a byte count to the NEAREST whole GB. `docker info` reports the guest
# kernel's MemTotal, which is always a few hundred MB UNDER the Docker Desktop
# memory slider (the kernel reserves some at boot), so a 16 GB slider reports
# ~15.6 GiB. Flooring that prints a misleading "15 GB" AND, compared against an
# exact 16 GiB target, false-positives the undersized advisory on a VM that is
# in fact sized right. The slider moves in whole-GB steps and the reserve is
# under half a GB, so rounding to the nearest GB recovers the configured value:
# 15.6 → 16, while a genuine 15 GB slider (~14.6 GiB) still rounds to 15. Used
# for BOTH the displayed size and the threshold so the two can never contradict
# (no "shows 16 GB but warns it's too small"). Arg: $1 = bytes. Echoes whole GB
# (0 on missing/non-numeric input).
_vm_gb_rounded() {
  local b="${1:-0}"
  [[ "$b" =~ ^[0-9]+$ ]] || { echo 0; return; }
  # 10# forces base-10: a digit-only value can still carry a leading zero, which is
  # invalid octal and would abort the arithmetic under set -e (same guard the swap
  # reader uses). +0.5 GiB then floor = round-to-nearest.
  echo $(( (10#$b + 536870912) / 1073741824 ))
}

# The Docker Desktop settings file (empty when none is readable). `docker info`
# reports the VM's MemTotal but NOT its configured swap, so swap can only be read
# from Docker Desktop's own settings, which on macOS live under
# ~/Library/Group Containers/group.com.docker/. Newer Docker Desktop writes
# settings-store.json (PascalCase keys); older writes settings.json (camelCase).
# Try the newer one first. The base dir is overridable for tests.
_docker_desktop_settings_file() {
  local base="${_DD_SETTINGS_DIR:-$HOME/Library/Group Containers/group.com.docker}"
  local f
  for f in "$base/settings-store.json" "$base/settings.json"; do
    [[ -r "$f" ]] && { printf '%s' "$f"; return 0; }
  done
  return 0   # no file is the common case (non-Docker-Desktop, or a moved path):
             # return clean so a caller's `f="$(...)"` can never trip set -e.
}

# The Docker Desktop VM's configured SWAP size in bytes, empty when it can't be
# read. Scrapes "SwapMiB": <n> (case-insensitive, so it matches both the newer
# `SwapMiB` and the older `swapMiB`) from the settings file with a pure-bash grep
# (no jq dependency). Fail-soft is deliberate: a parse miss returns empty so the
# swap advisory NEVER fires on a guess, only on a value we definitely read. The
# raw value is overridable for tests via _DD_SWAP_BYTES.
_docker_vm_swap_bytes() {
  if [[ -n "${_DD_SWAP_BYTES:-}" ]]; then
    [[ "${_DD_SWAP_BYTES}" =~ ^[0-9]+$ ]] && printf '%s' "${_DD_SWAP_BYTES}"
    return 0
  fi
  local f mib
  f="$(_docker_desktop_settings_file)"
  [[ -n "$f" ]] || return 0
  # `|| true` keeps a no-match (grep exits 1) from tripping `set -e` inside the
  # assignment under pipefail; the regex guard below handles the empty result.
  mib="$(grep -iEo '"swapmib"[[:space:]]*:[[:space:]]*[0-9]+' "$f" 2>/dev/null \
           | grep -Eo '[0-9]+' | tail -1 || true)"
  [[ "$mib" =~ ^[0-9]+$ ]] || return 0
  # 10# forces base-10: a leading-zero value (a hand-edited "08"/"09") passes the
  # digit guard but is invalid octal, which under set -e aborts the arithmetic and
  # leaks an error to the user; "0001024" would silently misread as octal. Same
  # guard _mem_to_bytes uses. Fail-soft stays intact.
  printf '%s' "$(( 10#$mib * 1048576 ))"
}

# The Docker Desktop VM's CONFIGURED memory slider in whole GB, empty when it
# can't be read. `docker info` reports the guest kernel's MemTotal, which sits a
# few hundred MB to over a GiB UNDER the slider (the kernel reserves memory at
# boot and the reserve GROWS with VM size), so on a large VM round-to-nearest
# can't recover the slider: a 24 GB slider reads ~23.4 GiB and rounds to 23, and
# MemTotal alone can't even tell a 23 GB slider from a 24 GB one once the reserve
# is ~0.6 GiB. The true value lives only in Docker Desktop's settings: MemoryMiB
# (newer, PascalCase) or memoryMiB (older, camelCase). Docker Desktop labels
# these GiB as "GB", which is exactly what we print. Fail-soft: a parse miss
# returns empty so the caller falls back to MemTotal rounding (Linux, no Docker
# Desktop, a moved path). Rounds MiB -> GB through `_vm_gb_rounded` (the same
# round-to-nearest the fallback uses), so a non-1024-aligned MemoryMiB (a
# hand-edited or non-standard-default value) reports the slider the user set
# (7936 -> 8) instead of truncating it (7) and re-tripping the undersized nag.
# Whole-GB sliders stay exact (24576 -> 24). Overridable for tests via _DD_MEMORY_MIB.
_docker_vm_configured_gb() {
  if [[ -n "${_DD_MEMORY_MIB:-}" ]]; then
    # 10# forces base-10 (a hand-edited leading-zero value is invalid octal and
    # would abort the arithmetic under set -e), same guard the swap reader uses.
    [[ "${_DD_MEMORY_MIB}" =~ ^[0-9]+$ ]] && _vm_gb_rounded "$(( 10#${_DD_MEMORY_MIB} * 1048576 ))"
    return 0
  fi
  local f mib
  f="$(_docker_desktop_settings_file)"
  [[ -n "$f" ]] || return 0
  # `|| true` keeps a no-match (grep exits 1) from tripping `set -e` under
  # pipefail; the regex guard below handles the empty result. The leading-quote
  # anchor ("memorymib") never matches SwapMiB / DiskSizeMiB / *ReservationMiB.
  mib="$(grep -iEo '"memorymib"[[:space:]]*:[[:space:]]*[0-9]+' "$f" 2>/dev/null \
           | grep -Eo '[0-9]+' | tail -1 || true)"
  [[ "$mib" =~ ^[0-9]+$ ]] || return 0
  _vm_gb_rounded "$(( 10#$mib * 1048576 ))"
}

# The VM size to DISPLAY and to THRESHOLD against, in whole GB. Prefer the
# configured Docker Desktop slider (exact); fall back to rounding the kernel's
# MemTotal when the settings can't be read. Display AND every threshold must
# call THIS one helper so a "shows 24 GB but warns it's too small" contradiction
# is impossible by construction. Arg: $1 = MemTotal bytes (for the fallback).
_docker_vm_display_gb() {
  local cfg
  cfg="$(_docker_vm_configured_gb)"
  if [[ "$cfg" =~ ^[0-9]+$ ]] && (( cfg > 0 )); then
    printf '%s' "$cfg"
    return 0
  fi
  _vm_gb_rounded "${1:-0}"
}

# Total physical RAM of the HOST machine in BYTES, empty when unknown. Used to
# judge whether the Docker Desktop VM is sized sensibly *relative to the host*
# (concept/22: a VM of ~half the host RAM). macOS: `sysctl hw.memsize` (already
# bytes). Linux: read MemTotal (kB) from /proc/meminfo and scale in bash, NOT
# `awk '{print $2 * 1024}'`, which makes awk do float math and print scientific
# notation (e.g. `3.36e+10`) for real RAM sizes, failing the `^[0-9]+$` check
# every consumer uses (→ host RAM silently treated as unknown on Linux). The
# meminfo path is overridable for tests. Empty on any failure → callers fall
# back to the absolute floor.
_host_total_memory() {
  if [[ "$(uname -s 2>/dev/null)" == "Darwin" ]]; then
    sysctl -n hw.memsize 2>/dev/null || true
  elif [[ -r "${_MEMINFO_FILE:-/proc/meminfo}" ]]; then
    local kb
    kb="$(awk '/^MemTotal:/ { print $2; exit }' "${_MEMINFO_FILE:-/proc/meminfo}" 2>/dev/null)"
    [[ "$kb" =~ ^[0-9]+$ ]] && echo $(( kb * 1024 ))
  fi
}

# Default per-box memory: a quarter of the Docker VM's memory, clamped to
# [4g, 8g]. A cgroup limit is a ceiling, not a reservation: a box only uses
# what it touches, so a bigger floor only bites when several boxes spike at
# once, which the on-start overload notice and undersized-VM advisory already
# warn about. The 2g floor that shipped in v0.16.0 was too tight for a single
# 1M-context Opus session: at 60% (the NODE_OPTIONS heap pin) that's a ~1.2g
# heap, which GC-thrashes and OOM-kills under a build/test. 4g lifts that to
# ~2.4g. Still far under the old fixed 8g that exceeded entire default VMs.
# Unknown VM size falls back to 2g: we can't gauge overcommit risk on a VM we
# can't size, so we stay conservative there rather than commit to the 4g floor.
_default_box_memory() {
  local vm_bytes
  vm_bytes="$(_docker_vm_memory)"
  if ! [[ "$vm_bytes" =~ ^[0-9]+$ ]] || (( vm_bytes == 0 )); then
    echo "2g"
    return
  fi
  local quarter_gb=$(( vm_bytes / 4 / 1073741824 ))
  if (( quarter_gb < 4 )); then
    echo "4g"
  elif (( quarter_gb > 8 )); then
    echo "8g"
  else
    echo "${quarter_gb}g"
  fi
}

# Resolve the per-box memory limit: project box config ([resources] memory in
# .cleat.<box>, else .cleat) > global config > VM-derived default. Invalid
# values fall through to the next source (a typo must not abort `docker run`
# with an opaque daemon error). PROJECT-supplied values are clamped to 8g,
# .cleat ships with the repo, and an untrusted project must not be able to
# re-introduce VM-wide overcommit; the user's own global config is not capped.
resolve_box_memory() {
  local project="$1" box="${2:-main}"
  local v

  v="$(_read_resource_from_file "$(_project_caps_file "$project" "$box")" memory)"
  if [[ -n "$v" ]]; then
    if _valid_memory_value "$v"; then
      if (( $(_mem_to_bytes "$v") > 8589934592 )); then
        echo "8g"
      else
        echo "$v"
      fi
      return 0
    fi
    warn "Ignoring invalid memory '$v' in project config ${DIM}(use e.g. 2g, 4096m)${RESET}" >&2
  fi

  v="$(_read_resource_from_file "$CLEAT_GLOBAL_CONFIG" memory)"
  if [[ -n "$v" ]]; then
    if _valid_memory_value "$v"; then
      echo "$v"
      return 0
    fi
    warn "Ignoring invalid memory '$v' in global config ${DIM}(use e.g. 2g, 4096m)${RESET}" >&2
  fi

  _default_box_memory
}

# A docker --cpus value: positive decimal (2, 1.5, 0.5). Length-capped so the
# clamp arithmetic below can't overflow; zero is rejected (docker reads 0 as
# "no limit", not a limit).
_valid_cpus_value() {
  [[ "$1" =~ ^[0-9]+(\.[0-9]+)?$ ]] || return 1
  [[ ${#1} -le 7 ]] || return 1
  local digits="${1//./}"
  (( 10#$digits > 0 ))
}

# The daemon's core count (empty when unknown). Seam for tests + the clamp.
_daemon_ncpu() {
  docker info --format '{{.NCPU}}' 2>/dev/null || true
}

# Resolve the per-box CPU limit: project box config > global config > NO
# default. Memory gets a default ceiling because memory is held, not shared;
# CPU is work-conserving: an idle core costs nothing and the scheduler
# already balances competing boxes, so an unconfigured box keeps all cores.
# PROJECT-supplied values are clamped to the daemon's core count: --cpus
# above NCPU is a dockerd error, so an untrusted .cleat could otherwise abort
# `docker run` outright. The user's own global config is passed through
# (dockerd validates it against the actual machine).
resolve_box_cpus() {
  local project="$1" box="${2:-main}"
  local v ncpu

  v="$(_read_resource_from_file "$(_project_caps_file "$project" "$box")" cpus)"
  if [[ -n "$v" ]]; then
    if _valid_cpus_value "$v"; then
      ncpu="$(_daemon_ncpu)"
      if [[ "$ncpu" =~ ^[0-9]+$ ]] && (( ncpu > 0 )) && \
         awk -v v="$v" -v n="$ncpu" 'BEGIN { exit !(v > n) }'; then
        echo "$ncpu"
      else
        echo "$v"
      fi
      return 0
    fi
    warn "Ignoring invalid cpus '$v' in project config ${DIM}(use e.g. 2, 1.5)${RESET}" >&2
  fi

  v="$(_read_resource_from_file "$CLEAT_GLOBAL_CONFIG" cpus)"
  if [[ -n "$v" ]]; then
    if _valid_cpus_value "$v"; then
      echo "$v"
      return 0
    fi
    warn "Ignoring invalid cpus '$v' in global config ${DIM}(use e.g. 2, 1.5)${RESET}" >&2
  fi
}

# ── Configured resources, for the config fingerprint ONLY ────────────────────
# The fingerprint must reflect what the USER declared in config, never a value
# the CLI derives at runtime. resolve_box_memory falls back to a VM-derived
# default (_default_box_memory) and resolve_box_cpus clamps to the daemon's core
# count, so both MOVE when the Docker VM is resized or the CLI's own default
# formula changes between versions, even though the user touched nothing. Folding
# those into the fingerprint quietly reintroduced the very version/VM coupling the
# VERSION exclusion was meant to kill: a CLI upgrade or a memory-slider change
# would shift the hash and fire a false "config changed, recreate?" on an
# untouched box. These variants read config files ONLY (project box > project >
# global) and emit nothing when unset, so an unconfigured box hashes the same
# regardless of VM size or CLI version. Values are validated but NOT warned about
# here (the real resolvers warn during the actual run); an invalid value is
# ignored so a typo can't change the fingerprint either.
_configured_box_memory() {
  local project="$1" box="${2:-main}" v
  v="$(_read_resource_from_file "$(_project_caps_file "$project" "$box")" memory)"
  if [[ -n "$v" ]] && _valid_memory_value "$v"; then
    # Mirror resolve_box_memory's project clamp so the fingerprint matches the
    # ceiling the container would actually get (deterministic, not VM-dependent).
    if (( $(_mem_to_bytes "$v") > 8589934592 )); then echo "8g"; else echo "$v"; fi
    return 0
  fi
  v="$(_read_resource_from_file "$CLEAT_GLOBAL_CONFIG" memory)"
  if [[ -n "$v" ]] && _valid_memory_value "$v"; then
    echo "$v"
    return 0
  fi
  return 0
}

_configured_box_cpus() {
  local project="$1" box="${2:-main}" v
  v="$(_read_resource_from_file "$(_project_caps_file "$project" "$box")" cpus)"
  if [[ -n "$v" ]] && _valid_cpus_value "$v"; then
    echo "$v"
    return 0
  fi
  v="$(_read_resource_from_file "$CLEAT_GLOBAL_CONFIG" cpus)"
  if [[ -n "$v" ]] && _valid_cpus_value "$v"; then
    echo "$v"
    return 0
  fi
  return 0
}

# ── Box descriptions (host-side metadata) ────────────────────────────────────
# An optional one-line human description per box, keyed by container name so it
# survives stop/resume/recreate and is removed with the box. Text is always
# written with printf and printed as data, never eval'd. See
# concept/20-boxes.md for why this is a host-side file, not a Docker label.
_box_desc_file() {
  echo "$CLEAT_BOXES_DIR/$1"
}

_box_desc_read() {
  local f
  f="$(_box_desc_file "$1")"
  [[ -f "$f" ]] && cat "$f" || true
}

_box_desc_write() {
  local cname="$1" text="$2"
  # Collapse CR/LF so a description is always a single line (it renders as a
  # one-line sub-entry in status/ps; see concept/20-boxes.md).
  text="$(printf '%s' "$text" | tr '\r\n' '  ')"
  mkdir -p "$CLEAT_BOXES_DIR"
  printf '%s\n' "$text" > "$(_box_desc_file "$cname")"
}

_box_desc_remove() {
  rm -f "$(_box_desc_file "$1")" 2>/dev/null || true
}

# ── Workspace trust ─────────────────────────────────────────────────────────
#
# A project's .cleat file lives in the repo: it's untrusted input. Before
# applying any capabilities it declares, the user must explicitly trust the
# file. Approval is per-project, keyed by the project's absolute path, and
# re-prompted whenever the set of requested caps changes (hash mismatch).
#
# Global config (~/.config/cleat/config) and --cap CLI flags are always
# trusted: the user wrote those themselves.
#
# Full design: concept/16-workspace-trust.md.

# Canonicalize a cap list for hashing: sort, deduplicate, join with commas.
# Reads one cap per line from stdin, outputs a single canonical string.
_canonical_caps() {
  awk 'NF' | LC_ALL=C sort -u | paste -sd, -
}

# Hash the canonical cap list from a .cleat file. Prints empty when the
# file is missing or declares no caps (nothing to gate).
# Note: `_md5` passes stdin through `md5sum` on Linux, which appends
# "  -" (the filename of stdin). Strip that so the stored trust hash is
# purely hex, otherwise we write malformed tab-separated lines.
_hash_cleat_caps() {
  local path="$1"
  [[ -f "$path" ]] || return 0
  local caps
  caps="$(_read_caps_from_file "$path" | _canonical_caps)"
  [[ -z "$caps" ]] && return 0
  echo -n "$caps" | _md5 | awk '{print $1}'
}

# Look up the stored trust hash for a (project, box). Empty on miss.
# The trust file is <path><TAB><box><TAB><hash>. Legacy two-column rows
# (<path><TAB><hash>) are read as the "main" box (see concept/20-boxes.md).
_trust_lookup() {
  local project="$1" box="${2:-main}"
  [[ -f "$CLEAT_TRUST_FILE" ]] || return 0
  awk -F'\t' -v p="$project" -v b="$box" '
    /^#/ { next }
    $1 != p { next }
    NF >= 3 { if ($2 == b) { print $3; exit } ; next }
    NF == 2 { if (b == "main") { print $2; exit } }
  ' "$CLEAT_TRUST_FILE" 2>/dev/null
}

# Append/update a trust entry for a (project, box). Atomic via temp+rename.
# 0600 permissions. Refuses paths containing tab/newline/carriage-return.
# Recording the "main" box also supersedes any legacy two-column row.
_trust_record() {
  # box is the optional LAST arg so legacy 2-arg callers (project, hash) keep
  # working with box defaulting to "main".
  local project="$1" hash="$2" box="${3:-main}"
  case "$project" in
    *$'\t'*|*$'\n'*|*$'\r'*)
      error "Refusing to trust a project path containing control characters"
      return 1 ;;
  esac
  [[ -z "$hash" ]] && return 1
  mkdir -p "$(dirname "$CLEAT_TRUST_FILE")"
  local tmp="${CLEAT_TRUST_FILE}.tmp.$$"
  {
    echo "# Cleat project trust file (one entry per line)"
    echo "# <absolute-project-path><TAB><box><TAB><hash-of-canonical-caps>"
    echo "# Legacy two-column rows (<path><TAB><hash>) are read as the 'main' box."
    if [[ -f "$CLEAT_TRUST_FILE" ]]; then
      awk -F'\t' -v p="$project" -v b="$box" '
        /^#/ { next }
        NF < 2 { next }
        {
          if ($1 == p) {
            if (NF >= 3 && $2 == b) next
            if (NF == 2 && b == "main") next
          }
          print
        }
      ' "$CLEAT_TRUST_FILE"
    fi
    printf '%s\t%s\t%s\n' "$project" "$box" "$hash"
  } > "$tmp"
  chmod 0600 "$tmp" 2>/dev/null || true
  mv "$tmp" "$CLEAT_TRUST_FILE"
}

# Remove a (project, box) trust entry. Silent no-op if not present. Removing
# the "main" box also clears any legacy two-column row for the path.
_trust_remove() {
  local project="$1" box="${2:-main}"
  [[ -f "$CLEAT_TRUST_FILE" ]] || return 0
  local tmp="${CLEAT_TRUST_FILE}.tmp.$$"
  {
    echo "# Cleat project trust file (one entry per line)"
    echo "# <absolute-project-path><TAB><box><TAB><hash-of-canonical-caps>"
    echo "# Legacy two-column rows (<path><TAB><hash>) are read as the 'main' box."
    awk -F'\t' -v p="$project" -v b="$box" '
      /^#/ { next }
      NF < 2 { next }
      {
        if ($1 == p) {
          if (NF >= 3 && $2 == b) next
          if (NF == 2 && b == "main") next
        }
        print
      }
    ' "$CLEAT_TRUST_FILE"
  } > "$tmp"
  chmod 0600 "$tmp" 2>/dev/null || true
  mv "$tmp" "$CLEAT_TRUST_FILE"
}

# List all trusted (project, box) pairs as <path><TAB><box>, one per line.
# Legacy two-column rows surface as <path><TAB>main.
_trust_list() {
  [[ -f "$CLEAT_TRUST_FILE" ]] || return 0
  awk -F'\t' '
    /^#/ { next }
    NF >= 3 { print $1 "\t" $2; next }
    NF == 2 { print $1 "\t" "main" }
  ' "$CLEAT_TRUST_FILE" 2>/dev/null
}

# Is a project trusted at its current .cleat caps hash?
# Returns 0 when trusted, 1 when not (missing entry, stale hash, or no .cleat).
_is_project_trusted() {
  local project="$1"
  local box="${_BOX:-main}"
  local caps_file stored current
  caps_file="$(_project_caps_file "$project" "$box")"
  stored="$(_trust_lookup "$project" "$box")"
  [[ -z "$stored" ]] && return 1
  current="$(_hash_cleat_caps "$caps_file")"
  [[ -z "$current" ]] && return 1
  [[ "$stored" == "$current" ]]
}

# Show a trust prompt and read y/n. Returns 0 on approval.
# $1 = project path; $2..$N = capability names being requested.
# Must only be called when _is_tty is true.
_trust_prompt() {
  local project="$1"; shift
  local caps=("$@")

  # Detect if this is a re-prompt (stored hash exists but doesn't match).
  local is_reprompt=0
  [[ -n "$(_trust_lookup "$project" "${_BOX:-main}")" ]] && is_reprompt=1

  # Comma-joined cap names for the notice line; docker is amber because it
  # breaks the sandbox. Same aligned startup-prompt style (info + _ask_yn) as the
  # image-rebuild, Claude-update, and recreate prompts, not the old notice box.
  local cap _list=""
  for cap in "${caps[@]}"; do
    if [[ "$cap" == "docker" ]]; then
      _list="${_list:+$_list, }${AMBER}${cap}${RESET}"
    else
      _list="${_list:+$_list, }${BOLD}${cap}${RESET}"
    fi
  done

  if [[ $is_reprompt -eq 1 ]]; then
    info "Project ${BOLD}.cleat${RESET} changed since you trusted it: it now grants ${_list} ${DIM}on your host${RESET}"
  else
    info "Project ${BOLD}.cleat${RESET} requests host access: ${_list} ${DIM}(beyond the sandbox)${RESET}"
  fi

  # Default-DENY ([y/N]): only an explicit yes grants the caps. Empty / EOF / no
  # all decline, so untrusted project input never auto-applies.
  local yn=""
  _ask_yn yn "Trust this project's .cleat? ${DIM}(applies its caps; approve once, undo with cleat untrust)${RESET} [y/N] "
  case "$yn" in
    [yY]*) return 0 ;;
    *) return 1 ;;
  esac
}

# Session-scoped decision cache: avoid prompting twice per invocation when
# resolve_caps is called from multiple command paths in the same run.
_TRUST_SESSION_DECISION=""   # "", "approved", "rejected"
_TRUST_SESSION_PROJECT=""    # the project path we decided on
_TRUST_SESSION_BOX=""        # the box we decided on (per-box trust)

# Decide whether to apply a project's .cleat caps. Sets _TRUST_SESSION_* on
# first call for a given project. Returns 0 = apply, 1 = skip.
# $1 = project path (must have a .cleat with caps; caller's responsibility).
# $2 = "prompt" (default) or "readonly" to forbid interactive prompting.
_resolve_project_trust() {
  local project="$1"
  local mode="${2:-prompt}"
  local box="${_BOX:-main}"
  local caps_file
  caps_file="$(_project_caps_file "$project" "$box")"

  # Cached decision for this session/project/box
  if [[ -n "$_TRUST_SESSION_DECISION" && "$_TRUST_SESSION_PROJECT" == "$project" && "$_TRUST_SESSION_BOX" == "$box" ]]; then
    [[ "$_TRUST_SESSION_DECISION" == "approved" ]] && return 0 || return 1
  fi

  # Already approved at the current hash (per box)
  if _is_project_trusted "$project"; then
    _TRUST_SESSION_DECISION="approved"
    _TRUST_SESSION_PROJECT="$project"
    _TRUST_SESSION_BOX="$box"
    return 0
  fi

  # Explicit non-interactive opt-in
  if [[ "${CLEAT_TRUST_PROJECT:-}" == "1" || "${_CLI_TRUST_PROJECT:-0}" == "1" ]]; then
    local hash
    hash="$(_hash_cleat_caps "$caps_file")"
    _trust_record "$project" "$hash" "$box" || true
    _TRUST_SESSION_DECISION="approved"
    _TRUST_SESSION_PROJECT="$project"
    _TRUST_SESSION_BOX="$box"
    return 0
  fi

  # Read-only contexts never prompt (e.g. cleat status)
  [[ "$mode" == "readonly" ]] && return 1

  # Interactive prompt
  if _is_tty; then
    local -a req_caps=()
    local c
    while IFS= read -r c; do [[ -n "$c" ]] && req_caps+=("$c"); done < <(_read_caps_from_file "$caps_file")
    if _trust_prompt "$project" "${req_caps[@]}"; then
      local hash
      hash="$(_hash_cleat_caps "$caps_file")"
      _trust_record "$project" "$hash" "$box" || true
      _TRUST_SESSION_DECISION="approved"
      _TRUST_SESSION_PROJECT="$project"
      _TRUST_SESSION_BOX="$box"
      return 0
    else
      warn "Project .cleat ignored, not trusted ${DIM}(global config still applied)${RESET}"
      _TRUST_SESSION_DECISION="rejected"
      _TRUST_SESSION_PROJECT="$project"
      _TRUST_SESSION_BOX="$box"
      return 1
    fi
  fi

  # Non-TTY, no explicit opt-in: default-deny with an informational warning
  warn "Project .cleat skipped in non-interactive mode ${DIM}(pass --trust-project or set CLEAT_TRUST_PROJECT=1 to approve)${RESET}"
  _TRUST_SESSION_DECISION="rejected"
  _TRUST_SESSION_PROJECT="$project"
  _TRUST_SESSION_BOX="$box"
  return 1
}

# Resolve active capabilities: global config + project config + CLI flags.
# Sets the global ACTIVE_CAPS array.
resolve_caps() {
  local project="${1:-}"
  local trust_mode="${2:-prompt}"
  local box="${_BOX:-main}"
  ACTIVE_CAPS=()

  # 1. Global config
  local global_caps
  global_caps="$(_read_caps_from_file "$CLEAT_GLOBAL_CONFIG")"

  # 2. Project config, gated by workspace trust. A .cleat file sitting in
  # the repo is untrusted input. Apply its caps only if the user has
  # approved this project (either a persistent trust record, a one-off
  # --trust-project flag, or an interactive "y" to the prompt).
  # The box's cap file REPLACES .cleat (no merge): .cleat.<box> if present,
  # else .cleat; main always uses .cleat. See concept/20-boxes.md.
  local project_caps=""
  if [[ -n "$project" ]]; then
    local caps_file
    caps_file="$(_project_caps_file "$project" "$box")"
    if [[ -f "$caps_file" ]]; then
      local _raw_project_caps
      _raw_project_caps="$(_read_caps_from_file "$caps_file")"
      if [[ -n "$_raw_project_caps" ]]; then
        if _resolve_project_trust "$project" "$trust_mode"; then
          project_caps="$_raw_project_caps"
        fi
      fi
    fi
  fi

  # 3. Merge: global + project (union, deduplicated)
  local seen=""
  local cap
  while IFS= read -r cap; do
    [[ -z "$cap" ]] && continue
    case ",$seen," in
      *,"$cap",*) ;;
      *) seen="${seen:+$seen,}$cap"; ACTIVE_CAPS+=("$cap") ;;
    esac
  done <<< "${global_caps}${global_caps:+$'\n'}${project_caps}"

  # 4. Add CLI --cap flags (session-scoped additions)
  for cap in "${_CLI_CAPS[@]+"${_CLI_CAPS[@]}"}"; do
    case ",$seen," in
      *,"$cap",*) ;;
      *) seen="${seen:+$seen,}$cap"; ACTIVE_CAPS+=("$cap") ;;
    esac
  done
}

# Check if a specific capability is active
cap_is_active() {
  local target="$1"
  local cap
  for cap in "${ACTIVE_CAPS[@]+"${ACTIVE_CAPS[@]}"}"; do
    [[ "$cap" == "$target" ]] && return 0
  done
  return 1
}

# ── Capabilities: env file parsing ─────────────────────────────────────────
# Parse an env file and output KEY=VALUE lines (resolved).
# Bare KEY entries are resolved from the host environment.
_parse_env_file() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  while IFS= read -r line || [[ -n "$line" ]]; do
    # Strip carriage return (CRLF from Windows editors)
    line="${line%$'\r'}"
    # Strip leading/trailing whitespace
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    # Skip empty lines and comments
    [[ -z "$line" || "$line" == \#* ]] && continue
    if [[ "$line" == *=* ]]; then
      # KEY=VALUE: validate key is non-empty
      local _key="${line%%=*}"
      [[ -z "$_key" ]] && continue
      echo "$line"
    else
      # Bare KEY: resolve from host environment
      # Validate variable name to prevent indirect expansion of invalid names
      if [[ ! "$line" =~ ^[a-zA-Z_][a-zA-Z0-9_]*$ ]]; then
        continue
      fi
      local val="${!line:-}"
      if [[ -n "$val" ]]; then
        echo "${line}=${val}"
      fi
    fi
  done < "$file"
}

# Resolve all env vars to pass to the container.
# Returns an array of -e KEY=VALUE docker arguments via _RESOLVED_ENV_ARGS.
resolve_env_args() {
  local project="${1:-}"
  _RESOLVED_ENV_ARGS=()
  # Parallel arrays: _ek[i] holds the key, _ev[i] holds the value
  local _ek=() _ev=()
  local key val line i

  _env_set() {
    local k="$1" v="$2"
    # Replace existing or append
    for ((i=0; i<${#_ek[@]}; i++)); do
      if [[ "${_ek[$i]}" == "$k" ]]; then
        _ev[$i]="$v"
        return
      fi
    done
    _ek+=("$k")
    _ev+=("$v")
  }

  # 1. If env capability is active, read env files
  if cap_is_active env 2>/dev/null; then
    # Global env file
    if [[ -f "$CLEAT_GLOBAL_ENV" ]]; then
      while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        key="${line%%=*}"; val="${line#*=}"
        _env_set "$key" "$val"
      done < <(_parse_env_file "$CLEAT_GLOBAL_ENV")
    fi

    # Project env file, box-aware: .cleat.<box>.env else .cleat.env
    local _env_file
    _env_file="$(_project_env_file "$project" "${_BOX:-main}")"
    if [[ -n "$project" && -f "$_env_file" ]]; then
      while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        key="${line%%=*}"; val="${line#*=}"
        _env_set "$key" "$val"
      done < <(_parse_env_file "$_env_file")
    fi
  fi

  # 2. --env-file flags (always work, bypass capability gate)
  for file in "${_CLI_ENV_FILES[@]+"${_CLI_ENV_FILES[@]}"}"; do
    if [[ ! -f "$file" ]]; then
      error "Env file not found: $file"
      exit 1
    fi
    while IFS= read -r line; do
      [[ -z "$line" ]] && continue
      key="${line%%=*}"; val="${line#*=}"
      _env_set "$key" "$val"
    done < <(_parse_env_file "$file")
  done

  # 3. --env flags (always work, bypass capability gate)
  for entry in "${_CLI_ENVS[@]+"${_CLI_ENVS[@]}"}"; do
    if [[ "$entry" == *=* ]]; then
      key="${entry%%=*}"; val="${entry#*=}"
      _env_set "$key" "$val"
    else
      # Bare key: resolve from host
      val="${!entry:-}"
      if [[ -n "$val" ]]; then
        _env_set "$entry" "$val"
      fi
    fi
  done

  # 4. Build -e arguments (sorted for deterministic fingerprinting)
  if [[ ${#_ek[@]} -gt 0 ]]; then
    while IFS= read -r key; do
      for ((i=0; i<${#_ek[@]}; i++)); do
        if [[ "${_ek[$i]}" == "$key" ]]; then
          _RESOLVED_ENV_ARGS+=(-e "${key}=${_ev[$i]}")
          break
        fi
      done
    done < <(printf '%s\n' "${_ek[@]}" | sort)
  fi

  unset -f _env_set
}

# Count env vars loaded from each source (for startup feedback)
_env_summary() {
  local project="${1:-}"
  local global_count=0
  local project_count=0

  if cap_is_active env 2>/dev/null; then
    if [[ -f "$CLEAT_GLOBAL_ENV" ]]; then
      global_count=$(_parse_env_file "$CLEAT_GLOBAL_ENV" | wc -l)
      global_count=$((global_count + 0))  # force integer
    fi
    local _env_file
    _env_file="$(_project_env_file "$project" "${_BOX:-main}")"
    if [[ -n "$project" && -f "$_env_file" ]]; then
      project_count=$(_parse_env_file "$_env_file" | wc -l)
      project_count=$((project_count + 0))
    fi
  fi

  if (( global_count + project_count > 0 )); then
    local msg="Env:"
    if (( global_count > 0 )); then
      msg+=" ${global_count} from ~/.config/cleat/env"
    fi
    if (( project_count > 0 )); then
      [[ "$msg" != "Env:" ]] && msg+=","
      msg+=" ${project_count} from $(basename "$_env_file")"
    fi
    info "$msg"
  fi
}

# ── Configuration drift detection ──────────────────────────────────────────
# Fingerprint storage-format version. Bump whenever the fingerprint INPUTS change
# (v0.16.4 dropped the VM-derived resource values). It is stored as a `v<N>:`
# prefix on the container's config-hash label, so a hash written under an OLDER
# format is recognisable as legacy: its bytes can't be recomputed here (we no
# longer know the old formula or the VM size at creation), so a mismatch against
# it can't be trusted to mean real drift. Legacy-format containers are therefore
# NOT nagged to recreate; they adopt the current format the next time they're
# recreated for a genuine reason. See _resolve_config_drift.
_CONFIG_FP_VERSION=2

# Compute a fingerprint from sorted caps + sorted env keys ONLY.
# Env VALUES are intentionally excluded: only structural changes (adding/removing
# keys or capabilities) trigger drift. Value changes don't require container
# recreation since env vars are passed at exec time, not baked into the container.
#
# The CLI VERSION is deliberately NOT part of the fingerprint. Folding it in made
# every release fire a false "caps or env keys differ" notice on existing
# containers whose only change was the version bump: a misleading message whose
# offered remedy (recreate the container from the *same* image) does nothing for a
# version change. Version drift is handled separately by _maybe_prompt_image_rebuild,
# which offers a real rebuild and only when the image is genuinely older.
#
# Same principle for resources (fixed v0.16.4): the fingerprint uses CONFIGURED
# memory/cpus (_configured_box_*), never the VM-derived default or the daemon
# clamp, both of which move when the VM is resized or the CLI's default formula
# changes between releases. Folding those in had quietly re-coupled the hash to
# VM size and CLI version, so a memory-slider tweak or a routine upgrade fired a
# false recreate prompt on a box the user never touched. The stored hash carries a
# format-version prefix (_CONFIG_FP_VERSION) so a future formula change is
# detectable rather than silently mistaken for real drift; see _resolve_config_drift.
compute_config_fingerprint() {
  local project="${1:-}"
  local fingerprint_input=""

  # Caps (sorted)
  fingerprint_input+="caps:"
  if [[ ${#ACTIVE_CAPS[@]} -gt 0 ]]; then
    fingerprint_input+="$(printf '%s\n' "${ACTIVE_CAPS[@]}" | sort | tr '\n' ',')"
  fi
  fingerprint_input+=$'\n'

  # Env keys (sorted HERE, values excluded). We sort inside this function rather
  # than trust the caller's arg order: resolve_env_args happens to emit keys
  # sorted today, but folding that assumption in means a different ordering (a
  # refactor, a new env source) would silently change the hash and fire a false
  # "caps or env keys differ" drift notice on an otherwise-unchanged setup.
  fingerprint_input+="env-keys:"
  if [[ ${#_RESOLVED_ENV_ARGS[@]} -gt 0 ]]; then
    local _ekeys=""
    for arg in "${_RESOLVED_ENV_ARGS[@]}"; do
      [[ "$arg" == -e ]] && continue
      _ekeys+="${arg%%=*}"$'\n'
    done
    fingerprint_input+="$(printf '%s' "$_ekeys" | sort | tr '\n' ',')"
  fi
  fingerprint_input+=$'\n'

  # Resources: only what the user DECLARED in config (_configured_box_*), so an
  # explicit `[resources] memory = 8g` still triggers a recreate (the ceiling is
  # baked at `docker run`, not changeable on a live container) while an
  # unconfigured box stays stable across VM resizes and CLI upgrades. Never the
  # VM-derived default or the daemon-clamped cpus: those move underfoot and were
  # the source of the v0.16.4 false-positive recreate.
  fingerprint_input+="resources:memory=$(_configured_box_memory "$project" "${_BOX:-main}")"
  fingerprint_input+=$'\n'
  fingerprint_input+="resources:cpus=$(_configured_box_cpus "$project" "${_BOX:-main}")"
  fingerprint_input+=$'\n'

  if command -v sha256sum &>/dev/null; then
    echo -n "$fingerprint_input" | sha256sum | head -c 16
  else
    echo -n "$fingerprint_input" | _md5 | head -c 16
  fi
}

# Read config hash stored on a container's Docker label
_container_config_hash() {
  local cname="$1"
  docker inspect "$cname" --format '{{index .Config.Labels "sh.cleat.config-hash"}}' 2>/dev/null || echo ""
}

# Read Cleat version stored on the Docker image label
_image_cleat_version() {
  docker inspect "$IMAGE_NAME" --format '{{index .Config.Labels "sh.cleat.version"}}' 2>/dev/null || echo ""
}

# Read the image-content spec stamped on the Docker image label. Empty for
# pre-stamping images (built before sh.cleat.image-spec existed) and for any
# image the daemon can't inspect. See _IMAGE_SPEC_VERSION.
_image_spec_version() {
  docker inspect "$IMAGE_NAME" --format '{{index .Config.Labels "sh.cleat.image-spec"}}' 2>/dev/null || echo ""
}

# True when version $1 is >= version $2 (dotted numeric, prerelease/build suffix
# stripped). Used to classify a pre-stamping image's content from the version it
# was built at. Pure integer field sort, bash 3.2 safe.
_version_ge() {
  local a="${1%%[-+]*}" b="${2%%[-+]*}"
  [[ "$a" == "$b" ]] && return 0
  local newest
  newest="$(printf '%s\n%s\n' "$a" "$b" | sort -t. -k1,1n -k2,2n -k3,3n | tail -1)"
  [[ "$newest" == "$a" ]]
}

# Read the Claude Code version bundled in the image. The `claude` launcher is a
# symlink into ~/.local/share/claude/versions/<v>, so the target's basename is
# the version. Prints the version string, or nothing if it can't be determined
# (e.g. layout changed, or no image). Spawns a throwaway container to resolve
# the symlink as it exists *inside* the image.
_image_claude_version() {
  local target v
  target="$(docker run --rm "$IMAGE_NAME" \
    bash -c 'readlink -f /home/coder/.local/bin/claude 2>/dev/null' 2>/dev/null)" || true
  case "$target" in
    */versions/*) v="${target##*/versions/}"; v="${v%%/*}" ;;
    *) v="" ;;
  esac
  printf '%s' "$v"
}

# Return success if the container's settings-overlay bind sources are all
# present and the right type. Return failure when the overlay dir is missing
# OR when any bind source within it is missing or has the wrong type.
#
# The overlay now lives under $CLEAT_RUN_DIR (persistent), not /tmp, so routine
# macOS /tmp rotation no longer invalidates it. This check now serves two roles:
#   1. Migration: a container created before the move has its overlay mounts
#      under /tmp, so the new-layout dir is absent → recreate to adopt the
#      persistent layout.
#   2. Defense: if the overlay dir or a file within it is missing (manual
#      deletion, partial state), recreate rather than mount a broken source.
# Why per-file, not just the dir: Docker auto-creates a missing bind source as a
# directory, which then fails to mount onto a file destination with an opaque
# OCI "not a directory" error.
_settings_overlay_intact() {
  local cname="$1"
  local overlay_dir="$CLEAT_RUN_DIR/${cname}/settings"
  [[ -d "$overlay_dir" ]] || return 1

  local mounts src
  mounts="$(docker inspect "$cname" --format '{{range .Mounts}}{{.Source}}{{"\n"}}{{end}}' 2>/dev/null)" || return 0
  [[ -n "$mounts" ]] || return 0
  while IFS= read -r src; do
    [[ -z "$src" ]] && continue
    case "$src" in
      "$overlay_dir"/* | "$CLEAT_PROJECTS_DIR"/*)
        # Overlay files and the persistent per-project .claude.json are bind
        # sources mounted onto file destinations. If one was deleted, Docker
        # would auto-create it as a directory and the start would fail with an
        # opaque OCI error; recreate instead.
        [[ -f "$src" ]] || return 1
        ;;
    esac
  done <<< "$mounts"
  return 0
}

# Return failure when any of the container's bind-mount sources no longer exist
# on the host. Bind sources are baked in at `docker run` (creation) and cannot
# be changed; `docker start` re-mounts the SAME recorded sources, and if one has
# vanished it aborts with an opaque OCI error:
#   error mounting "<src>" to rootfs at "<dst>" ... not a directory:
#   Are you trying to mount a directory onto a file (or vice-versa)?
#
# The classic trigger is the macOS SSH agent socket (the `ssh` cap). launchd
# regenerates its socket directory (…/com.apple.launchd.XXXX/Listeners) on every
# boot, so SSH_AUTH_SOCK rotates and the path baked into the container points at
# a directory that no longer exists: every `ssh`-cap box fails to restart after
# a reboot. Detect it here so the caller can recreate transparently (cheap: the
# container is disposable; auth, sessions, and the project all live in other
# mounts). Only `bind` mounts are checked: volumes/tmpfs have no host source to
# stat. Unreadable inspect (no daemon, gone container) → treat as present (0):
# the start path that follows surfaces the real error.
_container_bind_sources_present() {
  local cname="$1"
  local mounts line typ src
  mounts="$(docker inspect "$cname" \
    --format '{{range .Mounts}}{{.Type}}|{{.Source}}{{"\n"}}{{end}}' 2>/dev/null)" || return 0
  [[ -n "$mounts" ]] || return 0
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    typ="${line%%|*}"
    src="${line#*|}"
    [[ "$typ" == "bind" ]] || continue
    [[ -n "$src" ]] || continue
    [[ -e "$src" ]] || return 1
  done <<< "$mounts"
  return 0
}

# Build a per-project ~/.claude.json for the container, isolated from the shared
# host file. Mounting the host ~/.claude.json directly (the old behavior) caused
# two problems, because every container runs at CWD /workspace and writes back
# to the same host file:
#   1. Corruption: concurrent/interrupted writes from parallel containers
#      truncate the file → Claude greets the user with "Configuration Error /
#      Unexpected EOF" on startup.
#   2. Cross-project bleed: all containers share projects["/workspace"], so
#      trust-dialog / MCP / allowedTools approvals leak between unrelated projects.
#
# Strategy (per-project, host-as-base): on each (re)create take the host file
# WHOLE as the base, preserving Claude's global identity, onboarding, migration
# flags, and whatever schema the installed host version writes (no drift), then
# overlay this project's persisted projects["/workspace"] block on top. Global
# identity/onboarding keys fall back to the persisted copy when the host lacks
# them, so onboarding done inside a container on a fresh machine still sticks.
# The result is written ATOMICALLY (temp + mv) to a persistent, project-keyed
# file that the container mounts. The container never writes the host file, so
# the corruption race and the cross-project bleed are gone by construction.
#
# jq-free sanity check: does a file look like a JSON object? After stripping all
# whitespace it must be non-empty and start with `{` and end with `}`. This is a
# heuristic, not a parser: it can't catch interior damage, but it reliably
# catches the dominant corruption mode (a truncated write → Claude's "Unexpected
# EOF"), which never ends in `}`. Used only when jq is unavailable on the host.
_looks_like_json_object() {
  local content
  content="$(tr -d '[:space:]' < "$1" 2>/dev/null)" || return 1
  [[ -n "$content" && "${content:0:1}" == "{" && "${content: -1}" == "}" ]]
}

# Args: $1 = output path (the mount source / persisted per-project file)
_build_project_claude_json() {
  local out="$1"
  mkdir -p "$(dirname "$out")"

  # Defensive: a stray directory at the output path (e.g. Docker auto-created a
  # missing bind source as a dir on a prior run) would make the atomic mv fail
  # and then break the file→file mount. Clear anything that isn't a regular file.
  [[ -e "$out" && ! -f "$out" ]] && rm -rf "$out"

  local host="${HOME}/.claude.json"
  local host_src="$host"

  # Corruption guard: never feed a broken host file into the build, and never
  # silently reset it to {}. "Broken" = not parseable JSON (the common case is a
  # truncated file → Claude's "Unexpected EOF") OR valid JSON that isn't an
  # object (a malformed shape that would crash the merge). Back the bad file up
  # and warn so the user can recover it; proceed from the persisted project copy
  # (onboarding preserved). The guard runs WITHOUT jq too: jq gives a precise
  # check, otherwise a pure-bash heuristic (must be {…}) catches truncation, the
  # dominant corruption mode, so a jq-less host can't propagate a corrupt file.
  local host_broken=false
  if [[ -f "$host" && -s "$host" ]]; then
    if command -v jq &>/dev/null; then
      jq -e 'type=="object"' "$host" >/dev/null 2>&1 || host_broken=true
    else
      _looks_like_json_object "$host" || host_broken=true
    fi
  fi
  if $host_broken; then
    cp "$host" "${host}.bak" 2>/dev/null || true
    warn "Host ${BOLD}~/.claude.json${RESET} is corrupt, backed up to ${BOLD}~/.claude.json.bak${RESET}."
    echo -e "    ${DIM}Container uses last-known project state; the host file is left untouched.${RESET}"
    host_src=""
  fi

  if command -v jq &>/dev/null; then
    local tmp="${out}.tmp.$$"
    local hf pf
    if [[ -n "$host_src" && -f "$host_src" && -s "$host_src" ]]; then hf="$host_src"; else hf=/dev/null; fi
    if [[ -f "$out" && -s "$out" ]]; then pf="$out"; else pf=/dev/null; fi
    # slurpfile reads each input fully before output is written, so reading $out
    # while writing $tmp is safe; mv makes the swap atomic.
    if jq -n --slurpfile h "$hf" --slurpfile p "$pf" '
        ($h[0] // {}) as $host |
        ($p[0] // {}) as $proj |
        (($host.projects // {}) + ($proj.projects // {})) as $projects |
        # What a brand-new /workspace is born with INSIDE the cage. The sandbox
        # IS the trust boundary and cleat always launches claude with
        # --dangerously-skip-permissions, so pre-accepting folder trust, project
        # onboarding, and bypass mode for /workspace is correct, and it stops a
        # newer bundled Claude from re-running its first-run/onboarding flow (which
        # can surface as a login screen) in a fresh project that has no persisted
        # block. Defaults are on the LEFT of `+`, so any persisted/host /workspace
        # value wins per key (jq `+` is right-biased). Unknown future key names are
        # harmless extras; the real ones gate the prompts.
        ({hasTrustDialogAccepted:true, hasCompletedProjectOnboarding:true, bypassPermissionsModeAccepted:true}) as $wsdefaults |
        $host
        + { projects: ($projects + { "/workspace": ($wsdefaults + ($projects["/workspace"] // {})) }) }
        + ( ["oauthAccount","userID","lastOnboardingVersion"]
            | map({ (.): ($host[.] // $proj[.]) })
            | add
            | with_entries(select(.value != null)) )
        # Onboarding is complete by construction inside the cage (identity still
        # comes from oauthAccount above; a box with no token still shows login).
        # Forcing it stops a newer in-box Claude from re-onboarding a fresh
        # project whose host lastOnboardingVersion lags (or is absent).
        + { hasCompletedOnboarding: true }
        # The container always runs the native installer build (~/.local/bin/
        # claude → versions/), but this file is rebuilt from the host every run,
        # shadowing the installMethod the installer wrote at image-build time.
        # Without it, `claude doctor` warns "native installation but config
        # install method is unknown" and the updater logs install_failed. Force
        # it to match the real install so config agrees with the filesystem.
        + { installMethod: "native" }
      ' > "$tmp" 2>/dev/null; then
      mv -f "$tmp" "$out"
    else
      rm -f "$tmp" 2>/dev/null || true
      # jq failed unexpectedly: keep the persisted copy if present, else start clean.
      [[ -f "$out" && -s "$out" ]] || echo '{}' > "$out"
    fi
  else
    # No jq: best effort. Keep persisted copy, else seed from host, else empty.
    if [[ -f "$out" && -s "$out" ]]; then
      :
    elif [[ -n "$host_src" && -f "$host_src" && -s "$host_src" ]]; then
      cp "$host_src" "$out"
    else
      echo '{}' > "$out"
    fi
  fi
}

# Print a notice box with dynamic width. Each argument is a line of plain text.
# Supports {BOLD}...{/BOLD} for bold spans within lines.
_notice_box() {
  local lines=("$@")
  local width=0
  local i line stripped

  # Find widest line
  for line in "${lines[@]}"; do
    stripped="${line//{BOLD\}/}"
    stripped="${stripped//{\/BOLD\}/}"
    local len=${#stripped}
    [[ $len -gt $width ]] && width=$len
  done

  # Draw box
  local border=""
  for (( i = 0; i < width + 4; i++ )); do border+="─"; done

  echo ""
  echo -e "  ${CYAN}┌${border}┐${RESET}"
  for line in "${lines[@]}"; do
    stripped="${line//{BOLD\}/}"
    stripped="${stripped//{\/BOLD\}/}"
    local pad=""
    for (( i = ${#stripped}; i < width; i++ )); do pad+=" "; done
    # Replace {BOLD}/{/BOLD} with actual escape codes
    local formatted="${line//\{BOLD\}/${BOLD}}"
    formatted="${formatted//\{\/BOLD\}/${RESET}}"
    echo -e "  ${CYAN}│${RESET}  ${formatted}${pad}  ${CYAN}│${RESET}"
  done
  echo -e "  ${CYAN}└${border}┘${RESET}"
  echo ""
}

# Resolve configuration drift between the current config and the existing
# container. Triggers: a changed capability (`cleat config --enable <cap>`), a
# changed env key, or a changed EXPLICITLY-configured resource limit
# ([resources] memory/cpus in .cleat). On TTY: prompt to recreate; on accept,
# stop+rm container and clean tmp dirs so the caller's existing "no container"
# path (cmd_run) recreates with the new config. On non-TTY or declined: print a
# warning and continue with the stale container.
#
# Only hashes written in the current storage format (the v<N>: prefix) are
# comparable. A legacy or unlabelled hash can't be recomputed (we no longer know
# the old formula or the VM size at creation), so a mismatch against it would be
# a guess: such containers are NOT nagged, and silently adopt the current format
# the next time they're recreated for a real reason. This is what makes a CLI
# upgrade that changes the fingerprint formula recreate-free.
_resolve_config_drift() {
  local cname="$1"
  local project="${2:-}"

  container_exists "$cname" || return 0

  local stored_hash current_hash
  stored_hash="$(_container_config_hash "$cname")"
  [[ "$stored_hash" == "v${_CONFIG_FP_VERSION}:"* ]] || return 0
  current_hash="v${_CONFIG_FP_VERSION}:$(compute_config_fingerprint "$project")"
  [[ "$stored_hash" == "$current_hash" ]] && return 0

  if _is_tty; then
    info "${BOLD}Config changed${RESET} since ${BOLD}${cname}${RESET} was created: its capabilities, environment, or resource limits differ from your current setup"
    local yn=""
    _ask_yn yn "Recreate ${BOLD}${cname}${RESET} now? [Y/n] "
    if [[ -z "$yn" || "$yn" == [yY]* ]]; then
      info "Recreating container..."
      if is_running "$cname"; then
        docker stop "$cname" > /dev/null 2>&1 || true
      fi
      docker rm -f "$cname" > /dev/null 2>&1 || true
      rm -rf "$CLEAT_RUN_DIR/${cname}" 2>/dev/null || true
      success "Removed ${BOLD}${cname}${RESET}."
      return 0
    fi
    info "Skipped. Keeping existing container. Run ${BOLD}cleat rm && cleat${RESET} when ready."
    return 0
  fi

  info "${BOLD}Config changed${RESET} since ${BOLD}${cname}${RESET} was created. Recreate to apply: ${BOLD}cleat rm && cleat${RESET}"
}

# Image-content drift: the local image's baked content spec is OLDER than the
# spec this CLI ships, so it predates a real change under docker/ (entrypoint,
# clipboard/browser shims, the Dockerfile, a pinned base). Offer to refresh it
# as an interactive startup action, the same aligned Y/n prompt style (_ask_yn)
# as the other startup prompts. This is keyed to IMAGE CONTENT, not the CLI
# version: a version-only release leaves _IMAGE_SPEC_VERSION untouched and never
# nags. See concept/24-image-spec-versioning.md.
#
# Pre-stamping images (built before sh.cleat.image-spec existed) carry no spec
# label; their content is inferred from the version they were built at, so an
# image already at today's content stays silent and the cutover to this scheme
# forces no recreate. An image with neither label is left alone (fail open).
#
# On accept: acquire the current image, then drop this project's container so the
# normal start flow recreates it from the fresh image (the same mechanism
# _resolve_config_drift uses). Runs at most once per process, TTY-only, and only
# when the image content is strictly OLDER (never nags an equal-or-newer image).
_REBUILD_PROMPTED=0
_maybe_prompt_image_rebuild() {
  local cname="$1"
  _is_tty || return 0
  [[ "$_REBUILD_PROMPTED" == "1" ]] && return 0
  image_exists || return 0

  # Resolve the local image's content spec. Newer images carry an explicit
  # integer label; pre-stamping images infer it from their build version against
  # _IMAGE_SPEC_INTRO_VERSION (at/after intro == today's content == spec 1). An
  # image with no spec AND no version is exotic/hand-built: fail open, never nag.
  local stored_spec
  stored_spec="$(_image_spec_version)"
  if [[ -z "$stored_spec" ]]; then
    local image_version
    image_version="$(_image_cleat_version)"
    [[ -n "$image_version" ]] || return 0
    if _version_ge "$image_version" "$_IMAGE_SPEC_INTRO_VERSION"; then
      stored_spec=1
    else
      stored_spec=0
    fi
  fi
  # Guard a malformed label, then prompt only when the image content is strictly
  # older than what this CLI ships. Equal (current) or greater (a dev image
  # pulled ahead of the CLI) never nags. The 10# forces base 10 so a tampered
  # leading-zero label (e.g. 08) can't be misread as invalid octal and leak an
  # arithmetic error to stderr on the otherwise-silent start path.
  [[ "$stored_spec" =~ ^[0-9]+$ ]] || return 0
  (( 10#$stored_spec < 10#$_IMAGE_SPEC_VERSION )) || return 0
  _REBUILD_PROMPTED=1

  info "Cleat image is out of date: its setup predates this release ${DIM}(image content changed, not just the version)${RESET}"
  local yn=""
  _ask_yn yn "Refresh the image now? ${DIM}(downloads the prebuilt v${VERSION}, or builds it locally; recreates this project's container, discarding its writable layer)${RESET} [Y/n] "
  if [[ -z "$yn" || "$yn" == [yY]* ]]; then
    # Prefer pulling the released multi-arch image for THIS version: it ships
    # the exact tested setup and Claude build, and a download beats a ~2 min
    # local rebuild. Fall back to a local build only when the prebuilt image
    # isn't published (e.g. an unreleased dev VERSION). Same chain as cmd_run's
    # acquisition path, so an outdated image is refreshed the same way a missing
    # one is acquired. See concept/22 (multi-arch publish).
    _do_pull "$VERSION" || _do_build
    # Drop the existing container so the start flow recreates it from the fresh
    # image (its bind mounts and base layer are baked in at creation time).
    if container_exists "$cname"; then
      is_running "$cname" && docker stop "$cname" > /dev/null 2>&1 || true
      docker rm -f "$cname" > /dev/null 2>&1 || true
      rm -rf "$CLEAT_RUN_DIR/${cname}" 2>/dev/null || true
    fi
  fi
}

# Reaper drift: containers created before Cleat passed --init have `su` as
# PID 1, which never reaps re-parented children. Orphans from agent subshells
# accumulate as zombies until the box hits its pids cap, fork() fails, and the
# session wedges mid-keystroke (`docker stop` also burns its full timeout,
# `su` doesn't forward SIGTERM either). Detect such boxes on start and offer a
# recreate, which picks up --init from the current creation flags. Same prompt
# family as _maybe_prompt_image_rebuild: TTY-only, once per process, fail-open.
_INIT_RECREATE_PROMPTED=0
_maybe_prompt_init_recreate() {
  local cname="$1"
  _is_tty || return 0
  [[ "$_INIT_RECREATE_PROMPTED" == "1" ]] && return 0
  container_exists "$cname" || return 0
  # {{json .HostConfig}} is version-portable: Init serializes as true / false /
  # null (very old daemons omit the key). Only an explicit true means a reaper
  # is present; an inspect failure stays silent: never block a start on it.
  local hostconfig
  hostconfig="$(docker inspect --format '{{json .HostConfig}}' "$cname" 2>/dev/null)" || return 0
  [[ -n "$hostconfig" ]] || return 0
  [[ "$hostconfig" == *'"Init":true'* ]] && return 0
  _INIT_RECREATE_PROMPTED=1

  info "Box ${BOLD}${cname}${RESET} predates the zombie reaper ${DIM}(long sessions can freeze at the pids cap)${RESET}"
  local yn=""
  _ask_yn yn "Recreate it now? ${DIM}(project files and Claude state survive; /tmp and apt installs don't)${RESET} [Y/n] "
  if [[ -z "$yn" || "$yn" == [yY]* ]]; then
    is_running "$cname" && { docker stop "$cname" > /dev/null 2>&1 || true; }
    docker rm -f "$cname" > /dev/null 2>&1 || true
    rm -rf "${CLEAT_RUN_DIR:?}/${cname}" 2>/dev/null || true
  fi
}

# ── First-run tip ──────────────────────────────────────────────────────────
_first_run_tip_file="$CLEAT_CONFIG_DIR/.tip-shown"

show_first_run_tip() {
  # Show tip if no config file and tip hasn't been shown
  if [[ ! -f "$CLEAT_GLOBAL_CONFIG" && ! -f "$_first_run_tip_file" ]]; then
    info "Tip: run ${BOLD}cleat config${RESET} to enable git access, env passthrough, and more"
    mkdir -p "$CLEAT_CONFIG_DIR"
    touch "$_first_run_tip_file"
  fi
}

# ── Startup output ─────────────────────────────────────────────────────────
#
# Caps display groups active caps by behavior: same UI on the landing page.
#   mount   green   git, ssh, env, hooks, gh    auth/identity, no install
#   sandbox amber   docker                      breaks isolation (host socket)
#
# When only one category has active caps the line collapses to the legacy
# single-line form (`Caps:    git, ssh`). With caps in two categories the
# renderer breaks them into a labeled block: the categorization itself
# teaches the user that the docker cap behaves differently.

# Map a single cap name to its display category. Stdout: mount|sandbox.
_cap_category() {
  case "$1" in
    docker) echo "sandbox" ;;
    *)      echo "mount" ;;
  esac
}

# Bucket ACTIVE_CAPS into _CAPS_MOUNT/_CAPS_SANDBOX globals.
_caps_bucket_active() {
  _CAPS_MOUNT=()
  _CAPS_SANDBOX=()
  local cap
  for cap in "${ACTIVE_CAPS[@]+"${ACTIVE_CAPS[@]}"}"; do
    case "$(_cap_category "$cap")" in
      sandbox) _CAPS_SANDBOX+=("$cap") ;;
      mount)   _CAPS_MOUNT+=("$cap") ;;
    esac
  done
}

# Render the active caps. Indent prefix, top-level label, single-line pad,
# and label color are parameters so the same renderer drives both the
# summary block (DIM label) and `cleat status` (BOLD label).
_print_caps() {
  local indent="${1:-  }"
  local label="${2:-Caps:}"
  local pad="${3:-      }"
  local label_color="${4:-$DIM}"

  [[ ${#ACTIVE_CAPS[@]} -eq 0 ]] && return 0
  _caps_bucket_active

  local cats=0
  [[ ${#_CAPS_MOUNT[@]}   -gt 0 ]] && cats=$((cats + 1))
  [[ ${#_CAPS_SANDBOX[@]} -gt 0 ]] && cats=$((cats + 1))

  if [[ $cats -le 1 ]]; then
    local color s
    if [[ ${#_CAPS_SANDBOX[@]} -gt 0 ]]; then
      color="$AMBER"; s="$(printf '%s, ' "${_CAPS_SANDBOX[@]}")"
    else
      color="$GREEN"; s="$(printf '%s, ' "${_CAPS_MOUNT[@]}")"
    fi
    s="${s%, }"
    echo -e "${indent}${label_color}${label}${RESET}${pad}${color}${BOLD}${s}${RESET}"
    return 0
  fi

  echo -e "${indent}${label_color}${label}${RESET}"
  local s
  if [[ ${#_CAPS_MOUNT[@]} -gt 0 ]]; then
    s="$(printf '%s, ' "${_CAPS_MOUNT[@]}")"; s="${s%, }"
    echo -e "${indent}  ${DIM}mount:${RESET}    ${GREEN}${BOLD}${s}${RESET}"
  fi
  if [[ ${#_CAPS_SANDBOX[@]} -gt 0 ]]; then
    s="$(printf '%s, ' "${_CAPS_SANDBOX[@]}")"; s="${s%, }"
    echo -e "${indent}  ${DIM}sandbox:${RESET}  ${AMBER}${BOLD}${s}${RESET} ${DIM}(breaks isolation)${RESET}"
  fi
}

# Legacy entry point retained for tests and possible future inline use.
_print_startup_caps() {
  _print_caps "  " "Caps:" "      "
}

_print_summary_block() {
  local cname="$1"
  local project="${2:-}"
  echo ""
  echo -e "  ${DIM}Container:${RESET}  ${BLUE}${cname}${RESET}"
  if [[ -n "$project" ]]; then
    local _tilde='~'
    local display_path="${project/#$HOME/$_tilde}"
    # With the docker cap the container's workdir IS the host path (mounted at
    # its own path so $(pwd) and `docker run -v $(pwd)` resolve on the host
    # daemon; see the docker-cap mount block). Without it, the project lives at
    # /workspace. Show the truth for each case.
    if cap_is_active docker; then
      echo -e "  ${DIM}Project:${RESET}    ${display_path} ${DIM}(same path, sandboxed)${RESET}"
    else
      echo -e "  ${DIM}Project:${RESET}    ${display_path} ${DIM}→${RESET} /workspace"
    fi
  fi
  _print_caps "  " "Caps:" "       "
  _env_summary_inline "$project"
}

_env_summary_inline() {
  local project="${1:-}"
  local global_count=0
  local project_count=0
  local global_exists=false
  local project_exists=false

  if cap_is_active env 2>/dev/null; then
    if [[ -f "$CLEAT_GLOBAL_ENV" ]]; then
      global_exists=true
      global_count=$(_parse_env_file "$CLEAT_GLOBAL_ENV" | wc -l)
      global_count=$((global_count + 0))
    fi
    local _env_file
    _env_file="$(_project_env_file "$project" "${_BOX:-main}")"
    if [[ -n "$project" && -f "$_env_file" ]]; then
      project_exists=true
      project_count=$(_parse_env_file "$_env_file" | wc -l)
      project_count=$((project_count + 0))
    fi
  fi

  if $global_exists || $project_exists; then
    local msg=""
    if $global_exists; then
      msg+="${global_count} from ~/.config/cleat/env"
    fi
    if $project_exists; then
      [[ -n "$msg" ]] && msg+=", "
      msg+="${project_count} from $(basename "$_env_file")"
    fi
    echo -e "  ${DIM}Env:${RESET}        ${msg}"
  fi
}

# ── Clipboard bridge ──────────────────────────────────────────────────────
# DISABLE_AUTOUPDATER=1 turns off Claude Code's launch-time/background self-
# updater inside the container. Cleat owns Claude's version (it's baked into the
# image and updated via `cleat upgrade-claude`); an in-container self-update is
# ephemeral (reverts on recreate) AND has been observed to hang the TUI at launch
# on a freshly-(re)created container. Manual `claude update` / `claude doctor`
# still work. See docs.claude.com/en/setup#disable-auto-updates.
CLAUDE_ENV=(-e HOME=/home/coder -e DISABLE_AUTOUPDATER=1 -e PATH="/home/coder/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin")

# TERM/COLORTERM are the two DELIBERATE host-templated entries: docker exec -t
# does not propagate the attached terminal's type, so without these the box's
# terminfo can mismatch the real terminal (wrong key sequences, degraded
# colors in iTerm2/Ghostty/tmux). Everything else from the host stays out,
# the exec_claude tests pin the exact key set.
CLAUDE_ENV+=(-e "TERM=${TERM:-xterm-256color}")
if [[ -n "${COLORTERM:-}" ]]; then
  CLAUDE_ENV+=(-e "COLORTERM=${COLORTERM}")
fi

_host_clip_cmd() {
  if command -v pbcopy &>/dev/null; then echo pbcopy
  elif command -v xclip &>/dev/null; then echo "xclip -selection clipboard"
  elif command -v xsel &>/dev/null; then echo "xsel --clipboard"
  elif command -v wl-copy &>/dev/null; then echo wl-copy
  else echo ""
  fi
}

_clipboard_watcher() {
  local clip_dir="$1"
  local clip_cmd="$2"
  trap 'exit 0' TERM INT HUP
  # Same orphan story as _browser_watcher: a watcher whose cleat process died
  # without the cleanup trap (terminal closed, SIGKILL) must not keep writing
  # a dead session's box clipboard over the host clipboard. Checked at the
  # single copy choke point so all three watch modes are covered.
  local _cw_parent=$$

  touch "$clip_dir/.host-ready"

  _do_copy() {
    kill -0 "$_cw_parent" 2>/dev/null || exit 0
    [ -f "$clip_dir/clipboard" ] && eval "$clip_cmd" < "$clip_dir/clipboard" 2>/dev/null || true
  }

  if command -v inotifywait &>/dev/null; then
    while inotifywait -qq -e moved_to "$clip_dir" 2>/dev/null; do
      _do_copy
    done
    return
  fi

  if command -v fswatch &>/dev/null; then
    fswatch --event Updated --event Created -0 "$clip_dir" 2>/dev/null \
      | while IFS= read -r -d '' path; do
          case "$(basename "$path")" in clipboard) _do_copy ;; esac
        done
    return
  fi

  local last_ts=""
  while true; do
    kill -0 "$_cw_parent" 2>/dev/null || exit 0
    if [ -f "$clip_dir/clipboard" ]; then
      local cur_ts
      cur_ts=$(stat -c '%Y%N' "$clip_dir/clipboard" 2>/dev/null \
            || stat -f '%m' "$clip_dir/clipboard" 2>/dev/null || echo "")
      if [ -n "$cur_ts" ] && [ "$cur_ts" != "$last_ts" ]; then
        last_ts="$cur_ts"
        _do_copy
      fi
    fi
    sleep 1
  done
}

# ── Browser bridge ────────────────────────────────────────────────────────
# Watches for URLs written by the container's open-bridge shim and opens them
# on the host. Reuses the clipboard bridge dir ($CLEAT_RUN_DIR/<cname>/clip).

_host_open_cmd() {
  if command -v open &>/dev/null; then echo "open"
  elif command -v xdg-open &>/dev/null; then echo "xdg-open"
  else echo ""
  fi
}

# Extracts the localhost port from a redirect_uri in an OAuth URL.
# Returns 0 and prints the port if found, returns 1 otherwise.
_extract_callback_port() {
  local url="$1"

  case "$url" in
    *redirect_uri=*) ;;
    *) return 1 ;;
  esac

  # Isolate the redirect_uri value
  local encoded="${url#*redirect_uri=}"
  encoded="${encoded%%&*}"
  encoded="${encoded%%#*}"

  # URL-decode (%XX → bytes)
  local decoded
  decoded=$(printf '%b' "${encoded//%/\\x}" 2>/dev/null) || return 1

  # Extract port from localhost:PORT or 127.0.0.1:PORT
  local port=""
  case "$decoded" in
    *localhost:*)  port="${decoded#*localhost:}" ;;
    *127.0.0.1:*) port="${decoded#*127.0.0.1:}" ;;
    *) return 1 ;;
  esac
  port="${port%%[^0-9]*}"

  [ -n "$port" ] && echo "$port" && return 0
  return 1
}

# TCP proxy: forwards one connection from host:PORT to container:PORT.
# Enables OAuth callbacks to reach Claude Code's HTTP server inside Docker.
# Uses socat on host if available, falls back to python3.
_auth_callback_proxy() {
  local port="$1"
  local cname="$2"
  local log_file="${3:-}"

  _proxy_log() { [ -n "$log_file" ] && echo "[proxy $(date +%H:%M:%S)] $*" >> "$log_file"; }

  trap 'exit 0' TERM INT HUP

  _proxy_log "starting: port=$port container=$cname"

  # Prefer socat on host → docker exec socat in container
  # Try IPv6 first (Node.js binds to ::1 when given "localhost"), fall back to IPv4
  # Use ignoreeof on the container side so stdin EOF doesn't kill the TCP read
  # Retry bind up to 30s if the port is temporarily busy
  if command -v socat &>/dev/null; then
    _proxy_log "using socat on host"
    local socat_rc=0 _attempt
    for _attempt in $(seq 1 30); do
      socat "TCP-LISTEN:${port},bind=127.0.0.1,reuseaddr" \
        "EXEC:sh -c 'docker exec -i ${cname} socat -,ignoreeof TCP6\\:localhost\\:${port} 2>/dev/null || docker exec -i ${cname} socat -,ignoreeof TCP\\:localhost\\:${port}'" \
        2>>"${log_file:-/dev/null}" && { socat_rc=0; break; } || socat_rc=$?
      [[ $socat_rc -eq 1 ]] || break
      [[ $_attempt -eq 1 ]] && _proxy_log "socat bind failed, retrying..."
      sleep 1
    done
    _proxy_log "socat exited with status $socat_rc"
    return
  fi

  # Fallback: python3 HTTP-aware proxy with retry
  if command -v python3 &>/dev/null; then
    _proxy_log "using python3 fallback"
    local py_rc=0
    python3 - "$port" "$cname" "$log_file" <<'PYEOF' || py_rc=$?
import socket, subprocess, sys, signal, os, time
log_file = sys.argv[3] if len(sys.argv) > 3 else None
def _log(msg):
    if log_file:
        try:
            with open(log_file, 'a') as f: f.write(f"[proxy-py {msg}]\n")
        except: pass
def _term(*_): os._exit(0)
signal.signal(signal.SIGTERM, _term)
signal.signal(signal.SIGINT, _term)
def _send_generic_success(conn):
    body = (b"<!doctype html><html><head><title>Authentication Successful</title>"
            b"<style>body{font-family:system-ui,-apple-system,sans-serif;max-width:32em;"
            b"margin:4em auto;padding:2em;text-align:center;color:#222}"
            b"h1{color:#22863a}</style></head><body>"
            b"<h1>Authentication Successful</h1>"
            b"<p>You can close this window and return to Claude Code.</p>"
            b"</body></html>")
    resp = (b"HTTP/1.1 200 OK\r\n"
            b"Content-Type: text/html; charset=utf-8\r\n"
            b"Content-Length: " + str(len(body)).encode() + b"\r\n"
            b"Connection: close\r\n\r\n" + body)
    try: conn.sendall(resp)
    except Exception: pass
port, cname = int(sys.argv[1]), sys.argv[2]
srv = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
srv.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
if hasattr(socket, 'SO_REUSEPORT'):
    try: srv.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEPORT, 1)
    except OSError: pass
# Retry bind: the port may be briefly held by another process
bound = False
for bind_attempt in range(30):
    try:
        srv.bind(('127.0.0.1', port))
        bound = True
        break
    except OSError as e:
        if bind_attempt == 0:
            _log(f"bind attempt 1 failed: {e}, retrying...")
        time.sleep(1)
if not bound:
    _log(f"bind failed after 30 attempts, giving up")
    sys.exit(0)
_log(f"listening on 127.0.0.1:{port}")
srv.listen(1)
srv.settimeout(300)
try:
    cli, addr = srv.accept()
    _log(f"accepted connection from {addr}")
    # Read the full HTTP request from the browser
    cli.settimeout(5)
    req_data = b""
    while True:
        try:
            chunk = cli.recv(4096)
            if not chunk: break
            req_data += chunk
            # HTTP request ends with \r\n\r\n (GET has no body)
            if b"\r\n\r\n" in req_data: break
        except socket.timeout: break
    _log(f"got {len(req_data)} bytes from browser")
    # Rewrite Connection: keep-alive → close so the container's server will
    # close the TCP connection after its response.
    req_data = req_data.replace(b"Connection: keep-alive", b"Connection: close      ")
    req_data = req_data.replace(b"connection: keep-alive", b"connection: close      ")
    # Forward to the container: try IPv6 first (Node.js binds to ::1), fall back to IPv4
    # Use `-,ignoreeof` so socat doesn't propagate stdin EOF to the TCP socket,
    # giving the container server time to write its response before closing.
    ok = False
    for proto in ['TCP6', 'TCP']:
        proc = subprocess.Popen(
            ['docker', 'exec', '-i', cname, 'socat', '-,ignoreeof', f'{proto}:localhost:{port}'],
            stdin=subprocess.PIPE, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
        try:
            stdout, stderr = proc.communicate(input=req_data, timeout=30)
            errtxt = stderr.decode(errors='replace').strip() if stderr else ''
            if stdout:
                _log(f"forwarded OK via {proto}, got {len(stdout)} bytes back")
                cli.sendall(stdout)
                ok = True
                break
            if proc.returncode == 0:
                # Connection succeeded, request delivered, but no response bytes.
                _log(f"delivered via {proto} (empty response, assuming success)")
                _send_generic_success(cli)
                ok = True
                break
            if 'refused' in errtxt.lower():
                _log(f"{proto} connection refused, trying next")
                continue
            _log(f"{proto} failed rc={proc.returncode} stderr={errtxt}")
        except subprocess.TimeoutExpired:
            proc.kill()
            try: proc.wait(timeout=2)
            except subprocess.TimeoutExpired: pass
            _log(f"{proto} timed out, assuming code was delivered")
            _send_generic_success(cli)
            ok = True
            break
    if not ok:
        _log("forwarding failed on both IPv6 and IPv4")
        cli.sendall(b"HTTP/1.1 502 Bad Gateway\r\nContent-Type: text/html\r\n\r\n"
                    b"<h1>Cleat: callback forwarding failed</h1>"
                    b"<p>Could not reach Claude Code's auth server inside the container.</p>"
                    b"<p>Check <code>/tmp/cleat-clip/.proxy-log</code> for details.</p>")
    cli.close()
except socket.timeout:
    _log("timeout waiting for callback (300s)")
except Exception as e:
    _log(f"error: {e}")
finally: srv.close()
PYEOF
    _proxy_log "python3 proxy exited with status $py_rc"
    return
  fi

  _proxy_log "FAILED: neither socat nor python3 available on host"
}

# Atomically claim the URL pending in the bridge file. Prints the URL and returns
# 0 if THIS caller won the claim; returns 1 if there was nothing to claim. The
# rename is atomic, so when several watchers race on the same bridge file (e.g.
# an orphan left by a crashed/SIGKILL'd session plus the current one) exactly
# ONE wins per written URL. That makes a single in-container `open` open exactly
# one host tab instead of one-per-watcher (the duplicate-tab bug). Consuming the
# file also retires the old mtime-second dedup, which silently dropped a second
# URL written in the same wall-clock second.
_browser_claim_url() {
  local bridge_file="$1"
  [ -f "$bridge_file" ] || return 1
  local claim="${bridge_file}.opening.$$.${RANDOM}"
  mv "$bridge_file" "$claim" 2>/dev/null || return 1
  cat "$claim" 2>/dev/null || true
  rm -f "$claim" 2>/dev/null || true
  return 0
}

# Epoch mtime of a path, or 0 when it can't be read. GNU stat (-c) first, then
# BSD/macOS (-f), mirroring the clipboard watcher's probe above.
_path_mtime() {
  local m
  # Trailing `|| echo ""` guarantees a zero exit (and empty output) when both
  # stats fail, so the binary's `set -e` can't trip on this assignment if the
  # marker is removed between the glob and the stat (mirrors the clipboard probe).
  m="$(stat -c %Y "$1" 2>/dev/null || stat -f %m "$1" 2>/dev/null || echo "")"
  case "$m" in ''|*[!0-9]*) m=0 ;; esac
  printf '%s' "$m"
}

# Same-URL debounce, shared across watchers via per-URL marker dirs in the clip
# dir. The atomic claim above makes each WRITE open exactly once, but one user
# action can produce SEVERAL writes: a TUI link click fires the open shim on both
# press and release, and tools retry. With a single watcher the 0.5s poll
# collapses rapid rewrites (the second write lands before the first is claimed);
# with overlapping watchers (a login alongside a session, two shells on one box,
# or an orphan from a crashed session) each watcher claims one write, so two
# writes become two tabs unless the debounce is shared.
#
# The debounce MUST be atomic. The earlier design read a `.last-open` stamp,
# decided "not seen", then wrote it: two watchers could both read "not seen"
# before either wrote, and both opened (the one-click-two-tabs bug that the
# atomic claim alone did not fix, seen with concurrent sessions). Here the
# test-and-set is a single `mkdir`: it succeeds for exactly ONE racer and fails
# with EEXIST for the rest, so only the winner opens, no matter how many watchers
# are live. The marker's own mtime (set atomically by mkdir, so there is no
# create-then-stamp gap a concurrent sweep could misread) is the clock; markers
# older than the window are swept on each claim, so the same URL opens again
# later and stale markers can't accumulate. Different URLs hash to different
# markers and never dedupe.
_BROWSER_DEBOUNCE_SECS=2
_browser_recently_opened() {
  local clip_dir="$1" url="$2"
  local now hash lock d
  now="$(date +%s)"
  # Sweep markers past the window (runs only when a URL was actually claimed, over
  # a handful of recent markers, so the cost is negligible).
  for d in "$clip_dir"/.open.*; do
    [ -d "$d" ] || continue
    if [ $(( now - $(_path_mtime "$d") )) -gt "$_BROWSER_DEBOUNCE_SECS" ]; then
      rm -rf "$d" 2>/dev/null || true
    fi
  done
  # Filesystem-safe per-URL key. cksum is POSIX (present on macOS and Linux); a
  # collision would only over-dedupe two URLs fired within the same 2s, which
  # never happens in practice.
  hash="$(printf '%s' "$url" | cksum 2>/dev/null)"; hash="${hash// /_}"
  lock="$clip_dir/.open.$hash"
  if mkdir "$lock" 2>/dev/null; then
    return 1   # we won the atomic claim → open it
  fi
  return 0     # a fresh marker exists → another watcher already opened this URL
}

# Resolve the bridge open policy from CLEAT_BROWSER_BRIDGE. An unknown value
# falls back to the safe default rather than erroring, so a typo never wedges a
# session. Echoes one of: auto | always | off.
#   auto   (default): open auth/callback URLs always; defer PLAIN links to the
#                     host terminal when one is attached (it opens a clicked or
#                     autodetected URL itself), so the bridge never makes a
#                     duplicate tab. Off a terminal (piped) the bridge opens
#                     plain links too, since nothing else will.
#   always:           open every claimed http(s) URL (the pre-toggle behavior).
#   off:              never open a browser; the auth callback proxy still runs
#                     so `cleat login` works when the URL is opened by hand.
_browser_bridge_mode() {
  case "${CLEAT_BROWSER_BRIDGE:-auto}" in
    always) printf 'always' ;;
    off)    printf 'off' ;;
    *)      printf 'auto' ;;
  esac
}

# Decide whether the bridge should open a claimed URL on the host. Pure (no I/O)
# so it is exhaustively unit-tested. Returns 0 to OPEN, 1 to DEFER.
# Args: $1 mode (auto|always|off), $2 host_opens_clicks (1 when an interactive
# host terminal is attached and will open the link itself), $3 is_auth (1 when
# the URL carries a localhost OAuth callback the user does not click).
_browser_should_open() {
  local mode="$1" host_opens_clicks="${2:-0}" is_auth="${3:-0}"
  case "$mode" in
    always) return 0 ;;
    off)    return 1 ;;
    *)  # auto
        [ "$is_auth" = 1 ] && return 0            # auth URL: the bridge owns it
        [ "$host_opens_clicks" = 1 ] && return 1  # plain link, terminal owns it
        return 0 ;;                               # plain link, no terminal: open
  esac
}

_browser_watcher() {
  local clip_dir="$1"
  local open_cmd="$2"
  local cname="${3:-}"
  local bridge_mode="${4:-auto}"
  local host_opens_clicks="${5:-0}"   # 1 when an interactive host terminal is attached
  local bridge_file="$clip_dir/.browser-open"
  local _proxy_pid=""
  # $$ is the spawning cleat process even inside this backgrounded function,
  # used below to reap orphans (see the liveness check in the loop).
  local _bw_parent=$$

  _bw_cleanup() {
    if [ -n "$_proxy_pid" ]; then
      kill "$_proxy_pid" 2>/dev/null || true
      wait "$_proxy_pid" 2>/dev/null || true
      _proxy_pid=""
    fi
  }
  trap '_bw_cleanup; exit 0' TERM INT HUP

  # Remove any URL left over from a previous session
  rm -f "$bridge_file"
  while true; do
    # If the session's run dir was removed (cleat rm/clean/nuke), this watcher is
    # an orphan from a now-gone session: stop polling instead of spinning forever.
    [ -d "$clip_dir" ] || { _bw_cleanup; exit 0; }
    # If the cleat process that spawned this watcher is gone (terminal closed,
    # SIGKILL, anything that skips the cleanup trap), exit instead of polling
    # the box's clip dir forever. Leaked watchers are how one click became one
    # tab PER crashed session.
    kill -0 "$_bw_parent" 2>/dev/null || { _bw_cleanup; exit 0; }
    local url
    if url="$(_browser_claim_url "$bridge_file")"; then
      if _browser_recently_opened "$clip_dir" "$url"; then
        url=""   # duplicate of a just-opened URL; drop it
      fi
      if [[ "$url" == http://* ]] || [[ "$url" == https://* ]]; then
        local _is_auth=0 cb_port
        # Start auth callback proxy if URL has a localhost redirect_uri. This
        # runs in every mode (off included): the proxy forwards the OAuth
        # callback into the box, so `cleat login` completes even when the user
        # opens the URL by hand.
        if [ -n "$cname" ]; then
          local proxy_log="$clip_dir/.proxy-log"
          cb_port=$(_extract_callback_port "$url" 2>/dev/null) && {
            _is_auth=1
            _bw_cleanup  # kill any previous proxy
            echo "[browser-watcher $(date +%H:%M:%S)] extracted callback port=$cb_port from URL" >> "$proxy_log"
            _auth_callback_proxy "$cb_port" "$cname" "$proxy_log" &
            _proxy_pid=$!
            sleep 0.5  # let proxy bind before opening browser
          } || {
            echo "[browser-watcher $(date +%H:%M:%S)] no redirect_uri port found in URL" >> "$clip_dir/.proxy-log"
          }
        fi
        # Open on the host unless the policy defers to the terminal. A plain link
        # the user clicked is already opened by the host terminal itself; opening
        # it again here is the duplicate tab the maintainer reported. Auth URLs
        # and non-interactive sessions always open here (nothing else does).
        if _browser_should_open "$bridge_mode" "$host_opens_clicks" "$_is_auth"; then
          $open_cmd "$url" >/dev/null 2>&1 || true
        fi
      fi
    fi
    sleep 0.5
  done
}

# ── Host-side hook bridge ─────────────────────────────────────────────────
# Tails forwarded events and executes the user's host-defined command hooks.
# The settings overlay replaces hook commands with an event forwarder inside
# the container; this bridge reads those events and runs the real commands.
_HOOK_BRIDGE_PID=""
_HOOK_BRIDGE_CHILDREN=()

_has_host_hooks() {
  local f
  for f in "${HOME}/.claude/settings.json" "${_RESOLVED_PROJECT:-.}/.claude/settings.json" "${_RESOLVED_PROJECT:-.}/.claude/settings.local.json"; do
    if [[ -s "$f" ]] && jq -e '.hooks // empty | length > 0' "$f" >/dev/null 2>&1; then
      return 0
    fi
  done
  return 1
}

_hook_bridge_watcher() {
  local hooks_file="$1"
  # Orphan guard, as in _browser_watcher: a bridge whose cleat process died
  # without the cleanup trap must not keep executing host hooks for a dead
  # session. $$ is the spawning cleat process even in this backgrounded call.
  local _hb_parent=$$
  # Collect all settings files that define hooks (global + project)
  local settings_files=()
  local f
  for f in "${HOME}/.claude/settings.json" "${_RESOLVED_PROJECT:-.}/.claude/settings.json" "${_RESOLVED_PROJECT:-.}/.claude/settings.local.json"; do
    [[ -s "$f" ]] && settings_files+=("$f")
  done
  # On exit: kill all child hook processes
  trap '_hook_bridge_cleanup; exit 0' TERM INT HUP
  trap '_hook_bridge_cleanup' EXIT

  # Wait for hooks file to appear
  local waited=0
  while [[ ! -f "$hooks_file" ]] && [[ $waited -lt 30 ]]; do
    kill -0 "$_hb_parent" 2>/dev/null || return 0
    sleep 1
    waited=$((waited + 1))
  done
  [[ -f "$hooks_file" ]] || return 0

  # Tail new lines and execute matching host hooks.
  # We track our byte offset to avoid wc -l / tail race conditions.
  # Start from the current end of the file to skip events from prior sessions.
  local byte_offset
  byte_offset=$(wc -c < "$hooks_file" 2>/dev/null || echo 0)
  byte_offset=$((byte_offset + 0))
  while true; do
    # Liveness BEFORE processing: an orphaned bridge must not run one last
    # batch of host hooks for a session whose cleat process is already gone.
    kill -0 "$_hb_parent" 2>/dev/null || { _hook_bridge_cleanup; exit 0; }
    local file_size
    file_size=$(wc -c < "$hooks_file" 2>/dev/null || echo 0)
    file_size=$((file_size + 0))

    if [[ $file_size -gt $byte_offset ]]; then
      # Reap finished children
      _hook_bridge_reap

      # Read new lines since last offset
      while IFS= read -r line; do
        [[ -n "$line" ]] || continue
        _execute_host_hook_bg "$line" "${settings_files[@]}"
      done < <(tail -c +"$((byte_offset + 1))" "$hooks_file" 2>/dev/null)

      byte_offset=$file_size
    fi
    sleep 0.5
  done
}

# Reap finished child processes from the tracking array
_hook_bridge_reap() {
  local alive=()
  for pid in "${_HOOK_BRIDGE_CHILDREN[@]+"${_HOOK_BRIDGE_CHILDREN[@]}"}"; do
    if kill -0 "$pid" 2>/dev/null; then
      alive+=("$pid")
    else
      wait "$pid" 2>/dev/null || true
    fi
  done
  _HOOK_BRIDGE_CHILDREN=("${alive[@]+"${alive[@]}"}")
}

# Kill all tracked children.
# These run inside the bridge's process group (which is disowned from the parent).
# We kill them directly: no wait needed since they're in our own process tree.
_hook_bridge_cleanup() {
  for pid in "${_HOOK_BRIDGE_CHILDREN[@]+"${_HOOK_BRIDGE_CHILDREN[@]}"}"; do
    kill "$pid" 2>/dev/null || true
  done
  # Brief pause to let children exit, then reap
  sleep 0.1 2>/dev/null || true
  for pid in "${_HOOK_BRIDGE_CHILDREN[@]+"${_HOOK_BRIDGE_CHILDREN[@]}"}"; do
    wait "$pid" 2>/dev/null || true
  done
  _HOOK_BRIDGE_CHILDREN=()
}

# Execute a single event's host hooks in a tracked background subprocess.
_execute_host_hook_bg() {
  local event_json="$1"
  shift
  local settings_files=("$@")

  ( _execute_host_hooks "$event_json" "${settings_files[@]}" ) &
  _HOOK_BRIDGE_CHILDREN+=("$!")
}

_execute_host_hooks() {
  local event_json="$1"
  shift
  local settings_files=("$@")

  local event_name
  event_name="$(echo "$event_json" | jq -r '.hook_event_name // empty' 2>/dev/null)" || return 0
  [[ -n "$event_name" ]] || return 0

  # Get the tool name for matcher support
  local tool_name
  tool_name="$(echo "$event_json" | jq -r '.tool_name // empty' 2>/dev/null)" || true

  # Process hooks from all settings files (global + project)
  local settings
  for settings in "${settings_files[@]}"; do
    local hook_entries
    hook_entries="$(jq -c ".hooks.\"$event_name\" // [] | .[]" "$settings" 2>/dev/null)" || continue
    [[ -n "$hook_entries" ]] || continue

    while IFS= read -r entry; do
      [[ -n "$entry" ]] || continue

      # Check matcher (regex against tool_name for tool events)
      local matcher
      matcher="$(echo "$entry" | jq -r '.matcher // empty' 2>/dev/null)" || true
      if [[ -n "$matcher" && -n "$tool_name" ]]; then
        echo "$tool_name" | grep -qE "$matcher" 2>/dev/null || continue
      fi

      # Execute each command hook in the entry
      while IFS= read -r hook; do
        [[ -n "$hook" ]] || continue
        local cmd
        cmd="$(echo "$hook" | jq -r '.command // empty' 2>/dev/null)" || continue
        [[ -n "$cmd" ]] || continue

        # Execute on the host with event JSON on stdin.
        # Timeout after 30s to prevent hung hooks from blocking the bridge.
        if command -v timeout >/dev/null 2>&1; then
          echo "$event_json" | timeout 30 bash -c "$cmd" >/dev/null 2>&1 || true
        else
          echo "$event_json" | bash -c "$cmd" >/dev/null 2>&1 || true
        fi
      done < <(echo "$entry" | jq -c '.hooks // [] | .[] | select(.type == "command")' 2>/dev/null)
    done <<< "$hook_entries"
  done
}

# Block until the container's entrypoint has finished remapping the `coder`
# user from the image-baked UID to the host UID, before we exec a session into
# it. `docker exec` works the instant PID 1 exists, which can be BEFORE the
# entrypoint rewrites /etc/passwd. If we exec into that window, `runuser -u
# coder` resolves the STALE uid, so clip-daemon and claude run as the wrong
# user: claude can't write its host-owned config/auth (it hangs), and clip-daemon
# stamps its runtime files with the wrong owner, which later, correctly-mapped
# sessions can't clean from the sticky /tmp (the historical clip-EPERM storm).
# Best-effort gate: a running container's `id -u coder` is always numeric, so an
# empty/non-numeric reply means "can't determine" (broken exec) and we proceed
# rather than stall; a valid-but-mismatched uid means the remap is still in
# flight, so we keep polling (≤5s).
_wait_for_coder_remap() {
  local cname="$1" want got i=0
  want="$(id -u)"
  while [ "$i" -lt 50 ]; do
    got="$(docker exec "$cname" id -u coder 2>/dev/null)"
    case "$got" in
      ''|*[!0-9]*) return 0 ;;
    esac
    [ "$got" = "$want" ] && return 0
    i=$((i + 1))
    sleep 0.1
  done
  return 0
}

# Docker-capability session-start hardening (see concept/15-docker-capability.md).
# _heal_docker_sock: re-resolve the docker.sock owning GID and re-add coder to
# that group, AS ROOT, before each session exec. The entrypoint does this once
# at container start, but a Docker Desktop restart / daemon update can change the
# socket GID under a long-running (days-of-uptime) container, and a bare
# `docker exec` never re-runs the entrypoint, so `cleat`/`cleat shell` then fail
# with "permission denied /var/run/docker.sock". Inlined (not a baked image
# script) so it heals already-running containers without a rebuild; the following
# `runuser -u coder` re-runs initgroups and picks up the new group. Idempotent:
# groupmod re-points docker-host across GID changes instead of accreting groups.
_heal_docker_sock() {
  local cname="$1" _to=""
  command -v timeout >/dev/null 2>&1 && _to="timeout 10"
  $_to docker exec -u 0 "$cname" sh -c '
    [ -S /var/run/docker.sock ] || exit 0
    g=$(stat -c %g /var/run/docker.sock 2>/dev/null) || exit 0
    case "$g" in ""|*[!0-9]*) exit 0 ;; esac
    [ "$g" = "$(id -g coder)" ] && exit 0
    owner=$(getent group "$g" | cut -d: -f1)
    if [ -z "$owner" ]; then
      if getent group docker-host >/dev/null 2>&1; then groupmod -g "$g" docker-host 2>/dev/null || true
      else groupadd -g "$g" docker-host 2>/dev/null || true; fi
      owner=$(getent group "$g" | cut -d: -f1)
    fi
    [ -n "$owner" ] && usermod -aG "$owner" coder 2>/dev/null || true
  ' >/dev/null 2>&1 || true
}

# Ensure the docker cap can reach the daemon before a session. No-op unless the
# docker cap is active. Runs the per-exec GID self-heal, then probes as root: if
# even root can't reach the daemon, the socket bind is a stale inode (Docker
# replaced /var/run/docker.sock under the running container): no group fix can
# repair that in place, so guide the user to the re-bind recovery rather than
# silently failing. We do NOT auto-restart: a restart would kill any live
# session sharing this container.
_ensure_docker_access() {
  local cname="$1"
  cap_is_active docker 2>/dev/null || return 0
  _heal_docker_sock "$cname"
  local _to=""
  command -v timeout >/dev/null 2>&1 && _to="timeout 8"
  if ! $_to docker exec -u 0 "$cname" docker version >/dev/null 2>&1; then
    warn "Docker socket unreachable in this container ${DIM}(the daemon likely restarted)${RESET}"
    echo -e "    ${DIM}A stale socket bind can't be repaired in place. Recover with:${RESET}"
    echo -e "    ${BOLD}cleat stop && cleat resume${RESET}${DIM}  re-binds the socket; your session is preserved.${RESET}"
  fi
}

exec_claude() {
  local cname="$1"
  shift

  _CLIP_DIR="$CLEAT_RUN_DIR/${cname}/clip"
  _CLIP_WATCHER_PID=""
  _BROWSER_WATCHER_PID=""
  _HOOK_BRIDGE_PID=""
  mkdir -p "$_CLIP_DIR"
  # Stamp this box's run dir with an ATTACH timestamp for the idle sweep's grace
  # gate. The dir's own mtime would otherwise freeze at creation (writes go into
  # the clip/ subdir, not the dir itself), so the grace would measure age-since
  # -creation, not idle-since-detach. _cleanup_session re-stamps it on detach, so
  # `now - mtime(run dir)` is the true time since the session last had a host
  # process. Fail-soft.
  touch "$CLEAT_RUN_DIR/${cname}" 2>/dev/null || true

  # On macOS, bridge the host Keychain's OAuth token into the box before Claude
  # launches (the ~/.claude mount is live, so a write here is visible inside the
  # running container). No-op off macOS or once the box already has a token.
  _seed_macos_credentials

  _cleanup_session() {
    # Kill clipboard watcher
    if [ -n "${_CLIP_WATCHER_PID:-}" ]; then
      kill "$_CLIP_WATCHER_PID" 2>/dev/null || true
      wait "$_CLIP_WATCHER_PID" 2>/dev/null || true
      _CLIP_WATCHER_PID=""
    fi
    # Kill browser watcher (and its callback proxy child)
    if [ -n "${_BROWSER_WATCHER_PID:-}" ]; then
      kill "$_BROWSER_WATCHER_PID" 2>/dev/null || true
      wait "$_BROWSER_WATCHER_PID" 2>/dev/null || true
      _BROWSER_WATCHER_PID=""
    fi
    # Kill hook bridge: its EXIT/TERM trap kills child hook processes
    if [ -n "${_HOOK_BRIDGE_PID:-}" ]; then
      kill "$_HOOK_BRIDGE_PID" 2>/dev/null || true
      wait "$_HOOK_BRIDGE_PID" 2>/dev/null || true
      _HOOK_BRIDGE_PID=""
    fi
    _cleanup_spin
    rm -f "${_CLIP_DIR:?}/.clipboard."*
    rm -f "${_CLIP_DIR:?}/.browser-open"
    rm -f "$_CLIP_DIR/.watcher.$$"
    if ! ls "$_CLIP_DIR"/.watcher.* >/dev/null 2>&1; then
      rm -f "$_CLIP_DIR/.host-ready"
    fi
    # Re-stamp the run dir on detach so the idle sweep's grace measures time since
    # THIS session let go, not since the container was created (see the attach
    # touch above). Fail-soft.
    touch "$CLEAT_RUN_DIR/${cname}" 2>/dev/null || true
  }

  local clip_cmd
  clip_cmd="$(_host_clip_cmd)"
  if [ -n "$clip_cmd" ]; then
    touch "$_CLIP_DIR/.watcher.$$"
    _clipboard_watcher "$_CLIP_DIR" "$clip_cmd" &
    _CLIP_WATCHER_PID=$!
    disown "$_CLIP_WATCHER_PID" 2>/dev/null || true
  fi

  # Start browser watcher (always-on, like host connectivity). Pass whether an
  # interactive host terminal is attached: if so, it opens clicked links itself,
  # so the bridge defers plain links (no duplicate tab). See _browser_should_open.
  local open_cmd
  open_cmd="$(_host_open_cmd)"
  if [ -n "$open_cmd" ]; then
    local _bw_interactive=0
    _is_tty && _bw_interactive=1
    _browser_watcher "$_CLIP_DIR" "$open_cmd" "$cname" "$(_browser_bridge_mode)" "$_bw_interactive" &
    _BROWSER_WATCHER_PID=$!
    disown "$_BROWSER_WATCHER_PID" 2>/dev/null || true
  fi

  # Start host-side hook bridge if user has hooks and hooks cap is active
  local hooks_file="$CLEAT_RUN_DIR/${cname}/hooks/events.jsonl"
  if cap_is_active hooks 2>/dev/null && _has_host_hooks 2>/dev/null; then
    _hook_bridge_watcher "$hooks_file" &
    _HOOK_BRIDGE_PID=$!
    disown "$_HOOK_BRIDGE_PID" 2>/dev/null || true
  fi

  trap _cleanup_session EXIT INT TERM HUP

  # Don't launch the session until the UID remap has landed (see helper above).
  _wait_for_coder_remap "$cname"

  local rc=0
  _ensure_docker_access "$cname"
  # Use `runuser -u coder` rather than `docker exec --user coder` because the
  # latter sets UID/GID but skips initgroups(3), so supplementary groups from
  # /etc/group aren't loaded. This matters for the docker capability, where
  # the entrypoint adds coder to the host docker socket's owning group.
  # Pin node's heap to the box's real memory budget. Node sizes its default
  # heap ceiling from the cgroup limit, so before the limits were right-sized
  # it believed ~8g was available inside a 7.75g VM. 60% of the box limit
  # leaves headroom for non-heap memory (buffers, workers, the shell). A
  # user-supplied NODE_OPTIONS via env passthrough appears LATER on the exec
  # command line and wins: this is a default, not a straitjacket.
  local _heap_env=()
  local _mem_bytes _heap_mb
  _mem_bytes="$(docker inspect "$cname" --format '{{.HostConfig.Memory}}' 2>/dev/null)" || _mem_bytes=""
  if [[ "$_mem_bytes" =~ ^[0-9]+$ ]] && (( _mem_bytes > 0 )); then
    _heap_mb=$(( _mem_bytes * 60 / 100 / 1048576 ))
    (( _heap_mb > 0 )) && _heap_env=(-e "NODE_OPTIONS=--max-old-space-size=${_heap_mb}")
  fi

  # The inner script must exit with CLAUDE's status, not the clip-daemon
  # cleanup's: `wait` on the TERM-trapped daemon reports 0, which used to mask
  # a crashed claude (SIGSEGV=139, SIGABRT=134) as a clean session end, and
  # the rc==0 branch below then ERASED the crash message bash had just printed.
  # Host-side docker errors ('exec failed' during fork lockup, daemon resets)
  # go to a temp file and surface on failure instead of vanishing.
  local _exec_err="/tmp/cleat-exec-err.$$"
  docker exec -it "${CLAUDE_ENV[@]}" \
    "${_heap_env[@]+"${_heap_env[@]}"}" \
    "${_RESOLVED_ENV_ARGS[@]+"${_RESOLVED_ENV_ARGS[@]}"}" "$cname" \
    runuser -u coder -- bash -c '
      clip-daemon &
      _MY_CLIP_DAEMON=$!
      for i in 1 2 3 4 5; do [ -S "${CLEAT_CLIP_DIR:-/tmp/cleat-run-$(id -u)}/clip.sock" ] && break; sleep 0.1; done
      claude "$@"
      _CLAUDE_RC=$?
      kill "$_MY_CLIP_DAEMON" 2>/dev/null
      wait "$_MY_CLIP_DAEMON" 2>/dev/null
      exit "$_CLAUDE_RC"
    ' _ "$@" 2>"$_exec_err" || rc=$?

  _cleanup_session
  trap - EXIT INT TERM HUP
  _restore_terminal

  if [[ $rc -eq 0 ]]; then
    # Reclaim claude's leftover trailing line (cursor up, erase it), drop back
    # down, then clear the line success is about to write on. Without that final
    # \033[2K, success() prints from column 0 without erasing to end-of-line, so
    # stale bytes a heavily-used terminal left on that row survive past the
    # message (observed: a stray hash tail after "cleat resume"). TTY-gated so
    # no escapes ever reach a pipe.
    _is_tty && printf '\033[A\033[2K\r\n\033[2K'
    success "Session ended. Resume with: ${BOLD}cleat resume${RESET}"
  elif [[ $rc -ne 130 ]]; then
    warn "Claude exited with code $rc"
    [[ -s "$_exec_err" ]] && error "${DIM}$(cat "$_exec_err")${RESET}"
    _maybe_explain_oom "$cname" "$rc" "${_mem_bytes:-}"
  fi
  rm -f "$_exec_err"
}

# When a session dies from memory pressure, name it and say what to do: an
# unexplained exit-137/crash sends users hunting in the wrong place. Two
# signals: the box's cgroup OOM flag (State.OOMKilled, set when its own process
# tree is OOM-killed) or exit 137 (SIGKILL, the kernel OOM-killer's signature
# when it picks Claude itself). The classic trigger is a test runner: jest and
# vitest size their worker pool to the CPU count, and a box sees ALL host cores
# (CPU is unconfigured by default; concept/22), so a 2 GB box can spawn ~one
# node worker per core and blow its ceiling. There is no swap to absorb the
# spike (by design), so the spike is killed, not paged. This is guidance, not a
# fix: the user picks more memory, fewer workers, or a CPU cap. Fail-soft: an
# unreadable inspect just falls back to the exit-code signal.
_maybe_explain_oom() {
  local cname="$1" rc="$2" mem_bytes="${3:-}"
  local oomkilled=""
  oomkilled="$(docker inspect --format '{{.State.OOMKilled}}' "$cname" 2>/dev/null || true)"
  [[ "$oomkilled" == "true" || "$rc" == "137" ]] || return 0
  local mem_note=""
  if [[ "$mem_bytes" =~ ^[0-9]+$ ]] && (( mem_bytes > 0 )); then
    mem_note=" ${DIM}(box limit: $(( mem_bytes / 1073741824 )) GB)${RESET}"
  fi
  echo ""
  warn "${BOLD}Out of memory${RESET}. The box hit its memory ceiling${mem_note} and the kernel killed the process."
  echo -e "    ${DIM}Test runners are the usual cause: jest/vitest start one worker per CPU, and a box${RESET}"
  echo -e "    ${DIM}sees every host core. Pick one:${RESET}"
  echo -e "    ${DIM}•${RESET} More memory: add ${BOLD}[resources]${RESET} then ${BOLD}memory = 8g${RESET} to ${BOLD}.cleat${RESET} ${DIM}(or your global config)${RESET}"
  echo -e "    ${DIM}•${RESET} Fewer workers: ${BOLD}jest --maxWorkers=2${RESET}, ${BOLD}vitest --poolOptions.threads.maxThreads=2${RESET}"
  echo -e "    ${DIM}•${RESET} Cap CPU so runners self-limit: add ${BOLD}cpus = 2${RESET} under ${BOLD}[resources]${RESET}"
}

# ── Update check (every 10 minutes) ─────────────────────────────────────────
UPDATE_CHECK_FILE="$REPO_DIR/.update_check"
# Records the last VERSION whose on-start release highlight was shown (one line).
# Absent or different from VERSION => the highlight shows once on the next launch.
LAST_SEEN_VERSION_FILE="$REPO_DIR/.last_seen_version"
UPDATE_CHECK_INTERVAL=600   # 10 minutes; a release cut minutes after a launch
                            # should surface on the next run, not up to a day
                            # later. The lookup is one `git ls-remote --tags`
                            # (refs only, no objects), so this cadence is cheap;
                            # the declined-version field still prevents re-nagging.

# Claude Code update check: separate cadence/cache from the cleat self-update
# check above. The channel defaults to `latest` to match `cleat upgrade-claude`
# (so the on-start prompt and the action it triggers agree); override with
# CLEAT_CLAUDE_CHANNEL (stable|latest|VERSION). Disable the whole on-start
# prompt with CLEAT_NO_CLAUDE_UPDATE_CHECK=1.
# Docker pressure check (bloat → prune offer; overload → notice), throttled
# like the update checks, but daily: image bloat grows by the day, not the
# minute, and the check costs a handful of docker calls.
PRESSURE_CHECK_FILE="$REPO_DIR/.pressure_check"
PRESSURE_CHECK_INTERVAL=86400
# Idle-session sweep: on every interactive start, stop OTHER cleat boxes that are
# provably safe to stop (detached, no agent running, idle past the grace window),
# so a day of closed-terminal boxes stops silently reserving Docker VM memory.
# Closing a terminal ends the foreground exec but leaves the container running;
# this reclaims those. Grace defaults to 30 min so a box you stepped away from
# and will resume in a minute is left alone. Override with CLEAT_IDLE_GRACE_MINS;
# disable the whole sweep with CLEAT_NO_IDLE_SWEEP=1. See concept/25.
_IDLE_SWEEP_GRACE_SECS=1800
# Docker Desktop resources advisory (the VM memory/swap/file-sharing tuning the
# `docker` CLI cannot change). A box and a worktree are the same thing here:
# each is one session with its own quarter-of-VM ceiling (4-8g). 16 GiB is a comfortable default
# (a handful of sessions can each spike near their ceiling at once and still fit),
# NOT a hard cap: ceilings aren't reservations, so you can run many more sessions
# than that, and only simultaneous genuinely-heavy memory work across them swaps
# the VM, which is rare and no different from Claude Code outside Docker. The
# target is capped at half the host's RAM (leave the rest for macOS + apps). The
# advisory fires when the VM is below the target; a generous VM never nags, and it
# recurs on the daily check while the VM stays small, then stops once fixed. Host
# RAM unknown → conservative 8 GiB floor (don't over-recommend a VM the machine
# may not be able to back). See _recommended_vm_gb. User-facing copy never names a
# session count (it would read as a limit that isn't real); it says "many".
_PRESSURE_TARGET_VM_GB=16                     # comfortable default VM, not a session cap
_PRESSURE_VM_ADVISORY_BYTES=8589934592        # 8 GiB fallback floor (host RAM unknown)
# Minimum healthy Docker VM swap. Memory can be sized right while swap is left at
# the Docker Desktop default (often 1 GB): too little overflow for a brief spike,
# so a session can freeze instead of paging out. Matches the "Swap ≥ 2 GB" target
# the fix steps already recommend. Keep this value and that copy in sync.
_SWAP_ADVISORY_BYTES=2147483648               # 2 GiB

# Set to 1 by an on-start notice (the Docker pressure block) once it has emitted
# its own trailing blank line, so the release highlight below it knows the gap
# is already open and won't double the blank. When it stays 0 (no notice
# printed, or a non-Docker-Desktop engine where the fix block is skipped), the
# highlight opens the gap itself, guaranteeing exactly one blank line above the
# "New in …" news no matter what preceded it. See _maybe_show_release_highlight.
_ONSTART_GAP_OPEN=0

# Set to 1 by the pressure check when it printed a VM warning (overload or
# undersized) this run, so the positive "Docker tuned" line stays silent and the
# two can never both appear (or contradict). See _maybe_announce_docker_ready.
_VM_ADVISORY_SHOWN=0

CLAUDE_CHECK_FILE="$REPO_DIR/.claude_update_check"
CLAUDE_CHECK_INTERVAL=600   # 10 minutes; the lookup is a tiny GET; the only
                            # real per-check cost is one throwaway container to
                            # read the image's version, bounded to once/interval.
CLAUDE_RELEASES_URL="https://downloads.claude.ai/claude-code-releases"

latest_remote_tag() {
  git -C "$REPO_DIR" ls-remote --tags --refs origin 2>/dev/null \
    | awk '{print $2}' \
    | sed 's|refs/tags/v\{0,1\}||' \
    | grep -E '^[0-9]+\.[0-9]+\.[0-9]+$' \
    | sort -t. -k1,1n -k2,2n -k3,3n \
    | tail -1
}

# Return success only when $REPO_DIR is a git work tree with NO uncommitted
# changes, i.e. a pristine release install onto which `git checkout v<tag>` is
# safe. A dirty tree is a developer/contributor checkout (the maintainer's daily
# state): there `git checkout` would fail on the very file that differs between
# tags (bin/cleat), so offering the auto-update would just nag "Update failed" on
# every launch. Skip it for them; `cleat update` stays available explicitly.
_repo_is_clean() {
  git -C "$REPO_DIR" diff --quiet 2>/dev/null \
    && git -C "$REPO_DIR" diff --cached --quiet 2>/dev/null
}

# Checkout the given release tag and invalidate the update caches. Does NOT pull
# the image or exit: the re-exec'd new CLI handles image/build itself. Returns
# nonzero on any git failure so the caller can continue on the current version.
# Separated from the prompt so tests can stub it.
_apply_cli_update() {
  local target="$1"
  [[ -d "$REPO_DIR/.git" ]] || return 1
  git -C "$REPO_DIR" fetch --tags --force --quiet 2>/dev/null || return 1
  git -C "$REPO_DIR" checkout "v${target}" --quiet 2>/dev/null || return 1
  # Re-check against the fresh checkout next launch (and re-evaluate the bundled
  # Claude Code, since the new release image ships its own).
  rm -f "$UPDATE_CHECK_FILE" "$CLAUDE_CHECK_FILE" 2>/dev/null || true
  return 0
}

# Re-exec the (now-updated) CLI with the ORIGINAL argv so the new version drives
# the rest of this run. CLEAT_SKIP_CLI_UPDATE stops the new process from
# re-prompting (belt-and-suspenders; the version check already wouldn't fire).
# Isolated so tests can override it: exec replaces the process and can't be run
# under bats.
_reexec_cli() {
  export CLEAT_SKIP_CLI_UPDATE=1
  # `exec` only returns if it FAILED (e.g. $0 no longer resolves). `execfail`
  # lets it return instead of the shell exiting, and `|| true` keeps `set -e`
  # from aborting, so a user who just opted into an update is never stranded
  # with no session. The fallback re-enters main in-process (old in-memory code,
  # but a working session); CLEAT_SKIP_CLI_UPDATE prevents a re-prompt loop.
  shopt -s execfail 2>/dev/null || true
  exec "$0" "${_CLEAT_ORIG_ARGV[@]+"${_CLEAT_ORIG_ARGV[@]}"}" || true
  warn "Could not restart automatically. Continuing in this session."
  main "${_CLEAT_ORIG_ARGV[@]+"${_CLEAT_ORIG_ARGV[@]}"}"
  exit $?
}

# Interactive CLI self-update preflight. TTY-only, throttled, opt-out-able. When
# a newer RELEASED Cleat is available, offer to update and re-exec as that
# version. Runs before any docker work so the new version drives the whole run.
# Declined / non-interactive / offline → silently continue on the current
# version. Disable entirely with CLEAT_NO_UPDATE_CHECK=1.
_maybe_prompt_cli_update() {
  _is_tty || return 0
  [[ "${CLEAT_SKIP_CLI_UPDATE:-}" == "1" ]] && return 0
  [[ "${CLEAT_NO_UPDATE_CHECK:-}" == "1" ]] && return 0
  [[ -d "$REPO_DIR/.git" ]] || return 0

  # Don't offer an auto-`git checkout` onto a developer's dirty tree: it would
  # fail every launch (see _repo_is_clean). They can still run `cleat update`.
  _repo_is_clean || return 0

  # Cache layout: "<timestamp> <latest-version> [declined-version]". Field 3 (if
  # present) is the version the user last declined; we don't re-nag for it.
  local now last_check=0 cached_version="" declined_version=""
  now=$(date +%s)
  if [[ -f "$UPDATE_CHECK_FILE" ]]; then
    last_check=$(awk 'NR==1 {print $1}' "$UPDATE_CHECK_FILE" 2>/dev/null || echo 0)
    cached_version=$(awk 'NR==1 {print $2}' "$UPDATE_CHECK_FILE" 2>/dev/null || echo "")
    declined_version=$(awk 'NR==1 {print $3}' "$UPDATE_CHECK_FILE" 2>/dev/null || echo "")
    [[ "$last_check" =~ ^[0-9]+$ ]] || last_check=0
  fi
  # Throttle the network lookup to once per interval; CLEAT_FORCE_UPDATE_CHECK
  # bypasses (tests). Within the window we reuse the cached version, so a known
  # newer release still prompts without hitting the network every start. Preserve
  # the recorded decline across the refresh.
  if [[ -n "${CLEAT_FORCE_UPDATE_CHECK:-}" ]] || (( now - last_check >= UPDATE_CHECK_INTERVAL )); then
    cached_version=$(latest_remote_tag || true)
    echo "$now $cached_version $declined_version" > "$UPDATE_CHECK_FILE" 2>/dev/null || true
  fi

  [[ -n "$cached_version" && "$cached_version" != "$VERSION" ]] || return 0
  # Already declined THIS exact version → stay quiet until an even newer one ships.
  [[ -n "$declined_version" && "$cached_version" == "$declined_version" ]] && return 0
  # Only prompt when the remote release is strictly newer: never nag to
  # downgrade (e.g. running a local prerelease ahead of the latest tag). Compare
  # on the numeric base, stripping any prerelease/build suffix, so the sort's
  # whole-line tiebreak can't mis-rank `X.Y.Z-rc1` against `X.Y.Z`.
  local base_cur="${VERSION%%[-+]*}" base_new="${cached_version%%[-+]*}"
  local newest
  newest=$(printf '%s\n%s\n' "$base_cur" "$base_new" \
    | sort -t. -k1,1n -k2,2n -k3,3n | tail -1)
  [[ "$newest" == "$base_new" && "$base_new" != "$base_cur" ]] || return 0

  echo ""
  info "Cleat update available: ${DIM}v${VERSION}${RESET} → ${BOLD}v${cached_version}${RESET}"
  local yn=""
  _ask_yn yn "Upgrade now? ${DIM}(re-runs as the new version)${RESET} [Y/n] "
  if [[ -z "$yn" || "$yn" == [yY]* ]]; then
    if _apply_cli_update "$cached_version"; then
      success "Updated to v${cached_version}"
      info "Restarting with the new version…"
      _reexec_cli
    else
      warn "Update failed. Continuing on v${VERSION}."
    fi
  else
    # Record the decline so we don't re-prompt for this version every launch.
    echo "$now $cached_version $cached_version" > "$UPDATE_CHECK_FILE" 2>/dev/null || true
  fi
}

# Non-blocking release highlight. On the first RELEASE_HIGHLIGHT_MAX_SHOWS
# interactive, session-launching runs after VERSION changes, print a short note
# about the release's flagship feature, then go quiet for that version. Bounded
# repetition (not once, not forever): people miss a one-time note, and a
# forever-repeating one trains the eye to skip the startup block where the
# actionable drift/update/security notices live. Purely local (no network →
# CI/offline-safe) and NEVER prompts: the update check is the only thing allowed
# to ask at startup. State is "<version> <shown_count>" in $LAST_SEEN_VERSION_FILE.
# The copy below is the maintainer's editorial "what's new" news: written by
# hand, NOT auto-generated, and its version label is the feature's introduction
# version (a big feature may stay highlighted across several releases). Leave it
# as-is unless you have new news to announce; bump RELEASE_HIGHLIGHT_VERSION at
# tag time to re-surface it. A version mismatch shows nothing: fail-safe.
_maybe_show_release_highlight() {
  _is_tty || return 0
  # Only fire for the exact version this copy was written for.
  [[ "$RELEASE_HIGHLIGHT_VERSION" == "$VERSION" ]] || return 0

  local last_seen="" shown=0
  if [[ -f "$LAST_SEEN_VERSION_FILE" ]]; then
    last_seen=$(awk 'NR==1 {print $1}' "$LAST_SEEN_VERSION_FILE" 2>/dev/null || echo "")
    shown=$(awk 'NR==1 {print $2+0}' "$LAST_SEEN_VERSION_FILE" 2>/dev/null || echo 0)
  fi
  # Already shown the cap for this version → stay quiet.
  [[ "$last_seen" == "$VERSION" && "$shown" -ge "$RELEASE_HIGHLIGHT_MAX_SHOWS" ]] && return 0

  # A fresh version resets the counter; the same version increments it.
  local next=1
  [[ "$last_seen" == "$VERSION" ]] && next=$(( shown + 1 ))

  # Record the bumped count BEFORE printing so a Ctrl-C or write race can never
  # under-count (which would over-show). Brace-wrap so a redirect-open failure's
  # own stderr is suppressed too (plain `echo ... 2>/dev/null` doesn't catch the
  # shell's "Permission denied"). If the bump can't be persisted (read-only
  # install dir, unwritable stale file), the read-back fails and we stay SILENT
  # rather than show forever: "fail to silence, never to a permanent nag."
  { echo "$VERSION $next" > "$LAST_SEEN_VERSION_FILE"; } 2>/dev/null || true
  local confirm=""
  [[ -f "$LAST_SEEN_VERSION_FILE" ]] && confirm=$(awk 'NR==1 {print $1" "($2+0)}' "$LAST_SEEN_VERSION_FILE" 2>/dev/null || echo "")
  [[ "$confirm" == "$VERSION $next" ]] || return 0

  # Exactly one blank line above the news, no matter what preceded it. An
  # on-start notice (the Docker pressure block) sets _ONSTART_GAP_OPEN once it
  # has printed its own trailing blank, then we don't double it. Otherwise
  # (nothing printed, or a non-Docker-Desktop engine where the fix block is
  # skipped) we open the gap ourselves, so "New in …" never sits flush against a
  # warning or the shell prompt. The earlier design leaned on the advisory's
  # trailing blank for this, which vanished whenever the advisory's fix block was
  # gated out, leaving the news crammed against the warn line (observed
  # v0.16.1). We still own our OWN trailing blank below, so the bring-up that
  # follows needs none.
  [[ "${_ONSTART_GAP_OPEN:-0}" == "1" ]] || echo ""
  info "${BOLD}New in v1.0.0${RESET}. The first ${CYAN}stable${RESET} release is out."
  echo -e "    ${DIM}The cage is solid. Your keys still never enter it.${RESET}"
  echo -e "    ${DIM}Leave it running, walk away. Upgrades stay quiet.${RESET}"
  # A clickable, version-anchored changelog link. The /changelog page IDs each
  # release `id="vX.Y.Z"` (changelog.astro), so #v1.0.0 deep-links to the 1.0.0
  # release; _hyperlink makes it a real OSC 8 link where supported (clean short
  # text), else a bare clickable URL. Blue + underline reads as a link either
  # way. Keep the anchor version in lockstep with the "New in vX.Y.Z" label above.
  # printf, not `echo -e`: _hyperlink emits real escape bytes, and piping those
  # back through `echo -e` would re-interpret the OSC 8 string-terminator's
  # trailing `\` against ${RESET}'s leading `\033`. %b expands the colour vars;
  # %s passes the already-rendered link through untouched.
  printf '    %bChangelog:%b %b%b%s%b\n' \
    "$DIM" "$RESET" "$BLUE" "$UNDERLINE" \
    "$(_hyperlink "https://cleat.sh/changelog#v1.0.0" "cleat.sh/changelog#v1.0.0")" "$RESET"
  # Trailing blank: the highlight owns its own separation from whatever follows
  # (the bring-up, or the "Docker tuned"/swap line that runs after it), so flag
  # the gap open. Without this, a post-upgrade start with a well-sized VM (pressure
  # check silent, so it never set the flag) doubled the blank: the highlight's
  # trailing blank PLUS the confirmation's own leading blank. Same convention the
  # pressure block follows.
  echo ""
  _ONSTART_GAP_OPEN=1
}

# Fetch the newest released Claude Code version for a channel from the public
# releases endpoint (the same one the official installer reads). Stdout: a bare
# version like `2.1.149`, or empty on any failure. Tests inject a value via
# CLEAT_FAKE_REMOTE_CLAUDE so they never hit the network.
_claude_remote_version() {
  local channel="${1:-latest}"
  if [[ -n "${CLEAT_FAKE_REMOTE_CLAUDE:-}" ]]; then
    printf '%s' "$CLEAT_FAKE_REMOTE_CLAUDE"
    return 0
  fi
  command -v curl >/dev/null 2>&1 || return 0
  local v
  v="$(curl -fsSL "$CLAUDE_RELEASES_URL/$channel" 2>/dev/null)" || return 0
  # Take only the first line and strip surrounding whitespace, then require a
  # clean, fully-anchored semver. This rejects HTML/error pages and stops any
  # trailing or multiline bytes (e.g. ANSI escapes from a compromised/MITM'd
  # endpoint) from reaching the terminal display or the cache file.
  v="$(printf '%s' "$v" | head -n1 | tr -d '[:space:]')"
  [[ "$v" =~ ^[0-9]+\.[0-9]+\.[0-9]+([.-][0-9A-Za-z.]+)?$ ]] || return 0
  printf '%s' "$v"
}

# On an interactive `cleat` start, check at most once every 10 minutes whether a newer
# Claude Code than the one baked into the image is available, and if so offer
# to upgrade the image before starting. "Yes" runs the durable image-commit
# upgrade (NOT an in-container `claude update`, which would be ephemeral), then
# cmd_run continues and starts a fresh container from the updated image.
# Designed never to block: non-interactive, opted-out, throttled, offline, or
# version-read failures all fall through silently.
_maybe_prompt_claude_update() {
  _is_tty || return 0
  [[ "${CLEAT_NO_CLAUDE_UPDATE_CHECK:-}" == "1" ]] && return 0
  image_exists || return 0

  local now last_check=0
  now="$(date +%s)"
  if [[ -f "$CLAUDE_CHECK_FILE" ]]; then
    last_check="$(awk 'NR==1 {print $1}' "$CLAUDE_CHECK_FILE" 2>/dev/null || echo 0)"
    [[ "$last_check" =~ ^[0-9]+$ ]] || last_check=0
  fi
  # Throttle to once per interval. CLEAT_FORCE_CLAUDE_CHECK bypasses (tests).
  if [[ -z "${CLEAT_FORCE_CLAUDE_CHECK:-}" ]] && (( now - last_check < CLAUDE_CHECK_INTERVAL )); then
    return 0
  fi

  # Resolve and STRICTLY validate the channel before it touches a URL or the
  # in-container shell command: CLEAT_CLAUDE_CHANNEL is user-controlled, so a
  # value like `2.1.0; rm -rf ~` must not slip through to _upgrade_claude_image.
  local channel="${CLEAT_CLAUDE_CHANNEL:-latest}"
  local _semver='^[0-9]+\.[0-9]+\.[0-9]+([.-][0-9A-Za-z.]+)?$'
  case "$channel" in
    stable|latest) ;;
    *) [[ "$channel" =~ $_semver ]] || channel="latest" ;;
  esac

  local remote
  remote="$(_claude_remote_version "$channel")"
  # Record the attempt regardless of outcome so a flaky network can't nag on
  # every single start.
  echo "$now $remote" > "$CLAUDE_CHECK_FILE" 2>/dev/null || true
  [[ -n "$remote" ]] || return 0

  local local_v
  local_v="$(_image_claude_version)"
  [[ -n "$local_v" ]] || return 0
  [[ "$remote" != "$local_v" ]] || return 0
  # Only prompt when the remote version is strictly newer: never nag to
  # downgrade (e.g. when the image already runs a newer build than `stable`).
  # Compare on the numeric base, stripping any prerelease suffix (`-rc.1`), so a
  # pinned-prerelease channel doesn't mis-rank against a plain release.
  local base_local="${local_v%%[-]*}" base_remote="${remote%%[-]*}"
  local newest
  newest="$(printf '%s\n%s\n' "$base_local" "$base_remote" | sort -t. -k1,1n -k2,2n -k3,3n | tail -1)"
  [[ "$newest" == "$base_remote" ]] || return 0

  echo ""
  info "New Claude Code available: ${DIM}${local_v}${RESET} → ${BOLD}${remote}${RESET} ${DIM}(${channel})${RESET}"
  local yn=""
  _ask_yn yn "Update the image before starting? ${DIM}(downloads the new build)${RESET} [Y/n] "
  if [[ -z "$yn" || "$yn" == [yY]* ]]; then
    _upgrade_claude_image "$channel" || warn "Update failed. Starting with the current version."
  fi
  # Close the block with one blank line: this prompt opened with a leading blank
  # (above), so the bring-up that follows (Container started → Auth shared → …)
  # reads as its own contiguous group instead of sitting flush against the
  # "Claude Code upgraded" confirmation. Only reached when the prompt fired (all
  # the no-op early returns are above), so a start with no Claude update prints
  # neither blank.
  echo ""
}

# ── Commands ────────────────────────────────────────────────────────────────
cmd_build() {
  if image_exists; then
    # An image of the wrong architecture (e.g. an amd64 pull cached on an
    # Apple Silicon machine) counts as missing: every box created from it
    # would run emulated. Re-acquire a native one instead.
    if _image_arch_ok; then
      success "Image ready ${RESET}${DIM}(cached)"
      return
    fi
    _warn_image_emulated
  fi
  _do_pull || _do_build
}

_human_bytes() {
  local b="${1:-0}"
  [[ "$b" =~ ^[0-9]+$ ]] || { echo "?"; return; }
  [[ "$b" == "0" ]] && { echo "?"; return; }
  awk -v b="$b" 'BEGIN{
    split("B KB MB GB", u, " "); i=1
    while (b>=1024 && i<4) { b/=1024; i++ }
    printf("%.0f %s", b, u[i])
  }'
}

# Pull the prebuilt image from GHCR for a specific version (default: $VERSION),
# retagging it as $IMAGE_NAME on success. Returns 1 if the remote image isn't
# available so callers can fall back to a local build.
#
# Short-circuits when ${REGISTRY_BASE}:v${target_version} is already on disk:
# the only thing a pull would do in that case is verify cache freshness, and
# a transient registry/network error there shouldn't kick a perfectly good
# cached image out into a 2-5 min local build.
_do_pull() {
  local target_version="${1:-$VERSION}"
  local target_image="${REGISTRY_BASE}:v${target_version}"
  local log rc=0

  # Pin the pull to the daemon's architecture. A single-arch manifest of the
  # WRONG arch then fails loudly ('no matching manifest') and the caller's
  # `_do_pull || _do_build` falls back to a native local build, instead of
  # the pre-multi-arch behavior where docker pulled it anyway with a warning
  # the CLI discarded, and every box silently ran emulated. Empty daemon arch
  # (unreachable, exotic) omits the flag: today's behavior, fail-open.
  local arch platform_args=()
  arch="$(_daemon_arch)"
  [[ -n "$arch" ]] && platform_args=(--platform "linux/${arch}")
  local arch_note="${arch:+, ${arch}}"

  # Cache short-circuit: if the version-tagged prebuilt image is already on
  # disk AND matches the daemon arch, retag it as $IMAGE_NAME and skip the
  # network entirely. An arch-mismatched cache entry (an amd64 image pulled
  # before multi-arch publishing) must NOT short-circuit: fall through to
  # the platform-pinned pull so the native half of the manifest replaces it.
  # A failure to retag (rare: disk full, denied, etc.) must also fall
  # through so we never lie about success.
  if docker image inspect "$target_image" > /dev/null 2>&1 && _image_arch_ok "$target_image"; then
    if docker tag "$target_image" "$IMAGE_NAME" > /dev/null 2>&1; then
      local size_bytes size_human
      size_bytes=$(docker image inspect "$IMAGE_NAME" --format '{{.Size}}' 2>/dev/null || echo 0)
      size_human=$(_human_bytes "$size_bytes")
      success "Image ready ${RESET}${DIM}(cached v${target_version}${arch_note}, ${size_human})"
      return 0
    fi
    warn "Cached prebuilt image found but could not be tagged as ${IMAGE_NAME}; falling through to pull"
  fi

  log="$(mktemp)"

  if ! _is_tty; then
    info "Pulling image from ghcr.io ${DIM}(v${target_version}${arch_note})${RESET}"
    docker pull "${platform_args[@]+"${platform_args[@]}"}" "$target_image" > /dev/null 2>&1 || rc=$?
    if [[ $rc -ne 0 ]]; then
      warn "Prebuilt image unavailable for v${target_version}, building locally"
      rm -f "$log"
      return 1
    fi
    docker tag "$target_image" "$IMAGE_NAME" > /dev/null 2>&1 || true
    success "Image ready ${RESET}${DIM}(pulled v${target_version}${arch_note})"
    # Routine GC: drop superseded prebuilt tags and orphaned builds so each
    # update doesn't accrete another ~1-2 GB. Silent and fail-soft: images
    # still referenced by a container are kept.
    cmd_prune > /dev/null 2>&1 || true
    rm -f "$log"
    return 0
  fi

  # TTY: run docker pull in the background and animate progress by tailing
  # its line-per-event output (non-TTY docker pull writes one line per layer
  # event: "Pulling fs layer", "Downloading", "Extracting", "Pull complete").
  ( docker pull "${platform_args[@]+"${platform_args[@]}"}" "$target_image" > "$log" 2>&1 ) &
  local pull_pid=$!

  local frames
  if _has_unicode; then
    frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
  else
    frames=('-' '\' '|' '/')
  fi

  { command -v tput &>/dev/null && tput civis 2>/dev/null; } || true

  local i=0 total=0 complete=0 status
  while kill -0 "$pull_pid" 2>/dev/null; do
    if [[ -s "$log" ]]; then
      total=$(grep -c 'Pulling fs layer' "$log" 2>/dev/null || true)
      complete=$(grep -c 'Pull complete' "$log" 2>/dev/null || true)
      total="${total:-0}"
      complete="${complete:-0}"
    fi
    if (( total > 0 )); then
      status="${complete}/${total} layers"
    else
      status="connecting…"
    fi
    printf "\r\033[K  ${BLUE}%s${RESET} Pulling ${BOLD}cleat:v%s${RESET} from ghcr.io ${DIM}(%s)${RESET}" \
      "${frames[$i]}" "$target_version" "$status"
    i=$(( (i + 1) % ${#frames[@]} ))
    sleep 0.08
  done

  wait "$pull_pid"
  rc=$?
  { command -v tput &>/dev/null && tput cnorm 2>/dev/null; } || true

  if [[ $rc -ne 0 ]]; then
    printf "\r\033[K  ${AMBER}!${RESET} Prebuilt image unavailable for v%s, building locally\n" \
      "$target_version"
    rm -f "$log"
    return 1
  fi

  docker tag "$target_image" "$IMAGE_NAME" > /dev/null 2>&1 || true

  local size_bytes size_human
  size_bytes=$(docker image inspect "$IMAGE_NAME" --format '{{.Size}}' 2>/dev/null || echo 0)
  size_human=$(_human_bytes "$size_bytes")

  printf "\r\033[K  ${GREEN}✔${RESET} Image ready ${DIM}(pulled v%s%s, %s)${RESET}\n" \
    "$target_version" "$arch_note" "$size_human"
  # Routine GC: see the non-TTY path above.
  cmd_prune > /dev/null 2>&1 || true
  rm -f "$log"
  return 0
}

_do_build() {
  local build_log
  build_log="$(mktemp)"
  spin "Building image..."
  local rc=0
  docker build -f "$REPO_DIR/docker/Dockerfile" -t "$IMAGE_NAME" \
    --label "sh.cleat.version=$VERSION" \
    --label "sh.cleat.image-spec=$_IMAGE_SPEC_VERSION" "$REPO_DIR/docker" >"$build_log" 2>&1 || rc=$?
  spin_stop "$rc" "Image ready" "Image build failed"
  if [[ $rc -ne 0 ]]; then
    echo ""
    echo -e "  ${DIM}Build log:${RESET}"
    tail -20 "$build_log" | sed 's/^/    /'
    rm -f "$build_log"
    exit 1
  fi
  rm -f "$build_log"
  # Routine GC: the build that was just replaced is now a dangling
  # sh.cleat.version image (1.5-2.5 GB). Silent, fail-soft, keeps anything a
  # container still references.
  cmd_prune > /dev/null 2>&1 || true
}

cmd_rebuild() {
  local build_log
  build_log="$(mktemp)"
  spin "Rebuilding image..."
  local rc=0
  docker build --no-cache -f "$REPO_DIR/docker/Dockerfile" -t "$IMAGE_NAME" \
    --label "sh.cleat.version=$VERSION" \
    --label "sh.cleat.image-spec=$_IMAGE_SPEC_VERSION" "$REPO_DIR/docker" >"$build_log" 2>&1 || rc=$?
  spin_stop "$rc" "Image rebuilt" "Image build failed"
  if [[ $rc -ne 0 ]]; then
    echo ""
    echo -e "  ${DIM}Build log:${RESET}"
    tail -20 "$build_log" | sed 's/^/    /'
    rm -f "$build_log"
    exit 1
  fi
  rm -f "$build_log"
  # Routine GC: see _do_build. Drift rebuilds are the main bloat source: a
  # maintainer's image churns daily and every rebuild orphaned the previous.
  cmd_prune > /dev/null 2>&1 || true
}

# Upgrade the Claude Code build bundled inside the shared image.
#
# Claude Code lives at ~/.local/share/claude/versions/<v> in the image and is
# NOT host-mounted, so it's frozen at image build/pull time. This re-runs the
# official installer in a throwaway container from the current image and
# `docker commit`s the result back, durably baking the new version into
# $IMAGE_NAME (fast: only the new binary is downloaded).
#
# The upgrade is local-only: `cleat rebuild`, `cleat update`, and `cleat nuke`
# reset $IMAGE_NAME to a fresh release image (which already bundles a current
# Claude Code) and discard this commit. That's intentional: a CLI release
# supersedes a manual bump. Re-run this if a release happens to bundle an older
# Claude Code than you had.
#
# Usage: cleat upgrade-claude [stable|latest|VERSION]   (default: latest)
cmd_upgrade_claude() {
  local channel="${1:-latest}"

  # Validate strictly. The channel is interpolated into the container's shell
  # command, so anything but `stable`, `latest`, or a bare semver would be a
  # command-injection vector (e.g. `2.1.0; rm -rf ~`). The regex admits an
  # optional prerelease/build suffix (`-rc.1`, `.20240101`) but no shell
  # metacharacters, whitespace, or slashes.
  local _semver='^[0-9]+\.[0-9]+\.[0-9]+([.-][0-9A-Za-z.]+)?$'
  case "$channel" in
    stable|latest) ;;
    *)
      if [[ ! "$channel" =~ $_semver ]]; then
        error "Invalid version: ${BOLD}${channel}${RESET}."
        echo -e "    ${DIM}Use ${BOLD}stable${RESET}${DIM}, ${BOLD}latest${RESET}${DIM}, or a version like ${BOLD}2.1.156${RESET}${DIM}.${RESET}"
        exit 1
      fi
      ;;
  esac

  _upgrade_claude_image "$channel" || exit 1

  # Existing containers were created from the old image and still run the old
  # Claude Code. Recreate the current project's container so the upgrade takes
  # effect immediately (sessions live on the host and are preserved).
  local project cname
  project="$(resolve_project)"
  cname="$(container_name_for "$project")"
  if container_exists "$cname"; then
    if _is_tty; then
      local yn=""
      _ask_yn yn "Recreate ${BOLD}${cname}${RESET} now to use it? [Y/n] "
      if [[ -z "$yn" || "$yn" == [yY]* ]]; then
        if is_running "$cname"; then
          docker stop "$cname" > /dev/null 2>&1 || true
        fi
        docker rm -f "$cname" > /dev/null 2>&1 || true
        rm -rf "$CLEAT_RUN_DIR/${cname}" 2>/dev/null || true
        success "Removed ${BOLD}${cname}${RESET}."
        cmd_run "$project"
        return
      fi
    fi
    info "Run ${BOLD}cleat rm && cleat${RESET} to use the new Claude Code in ${BOLD}${cname}${RESET}."
  fi
  echo -e "  ${DIM}Other projects pick up the new Claude Code next time their container is recreated.${RESET}"
}

# Core upgrade: re-install Claude Code into the local image for <channel> and
# commit the result back over the image. The channel MUST be pre-validated by
# the caller (it is interpolated into the in-container shell command). Returns
# 0 on success, 1 on failure: it never exits the process and never recreates
# a container, so the on-start update prompt can update the image in place and
# then let cmd_run continue starting a fresh container from it.
_upgrade_claude_image() {
  local channel="$1"

  # Need an image to upgrade: build or pull one first if missing.
  if ! image_exists; then
    info "No image yet. Preparing one first..."
    _do_pull || _do_build
  fi
  # Defensive: if pull+build still left us without an image, stop here rather
  # than spawning a container against a non-existent reference.
  if ! image_exists; then
    error "No ${BOLD}${IMAGE_NAME}${RESET} image available to upgrade."
    return 1
  fi

  local before old_id
  before="$(_image_claude_version)"
  old_id="$(docker image inspect "$IMAGE_NAME" --format '{{.Id}}' 2>/dev/null || true)"

  local tmp="cleat-claude-upgrade"
  # Self-heal a leftover container from a previously interrupted run.
  docker rm -f "$tmp" > /dev/null 2>&1 || true

  local log
  log="$(mktemp 2>/dev/null)" || log="/tmp/cleat-upgrade.$$"
  : > "$log" 2>/dev/null || true

  # Build the in-container command. Notes on why each piece matters:
  #   set -euo pipefail  (without pipefail, a failed `curl` feeds empty input
  #                        to `bash` which exits 0, so a network failure would
  #                        silently commit an UNCHANGED image. This makes the
  #                        installer download failure abort the whole run.
  #   absolute paths     (HOME is always /home/coder in the image; hardcoding
  #                        avoids any empty-$HOME `rm -rf /...` surprise.
  #   test -x readlink   (verifies the installer actually produced a runnable
  #                        claude binary before we commit it. A broken/partial
  #                        install fails here instead of being baked in.
  # `$channel` is safe to interpolate: validated above.
  local install_cmd
  install_cmd='set -euo pipefail; curl -fsSL https://claude.ai/install.sh | bash -s -- '"$channel"'; rm -rf /home/coder/.claude/downloads; test -x "$(readlink -f /home/coder/.local/bin/claude)"'

  spin "Upgrading Claude Code (${channel})..."
  local rc=0
  # The image ENTRYPOINT remaps UID/GID as root then drops to the coder user.
  # Pass the host UID/GID so the installer writes ~/.local owned by the SAME uid
  # the runtime container will remap coder to. Without this the throwaway defaults
  # to the image-baked uid (1000), baking a 1000-owned ~/.local that a host-uid
  # (e.g. macOS 501) runtime can't write, breaking manual `claude update`.
  docker run --name "$tmp" -e "HOST_UID=$(id -u)" -e "HOST_GID=$(id -g)" "$IMAGE_NAME" bash -c "$install_cmd" > "$log" 2>&1 || rc=$?

  if [[ $rc -eq 0 ]]; then
    # Commit the updated filesystem over the working image. Restore the default
    # CMD: the throwaway container overrode it with the install command, and
    # `docker commit` would otherwise bake that in (breaking `cleat run`, which
    # relies on the image's `["bash"]` CMD to keep the container alive).
    docker commit --change 'CMD ["bash"]' "$tmp" "$IMAGE_NAME" >> "$log" 2>&1 || rc=$?
  fi
  docker rm -f "$tmp" > /dev/null 2>&1 || true

  # Fold the version delta straight into the success line so the result is a
  # single row, "Claude Code upgraded (2.1.156 → 2.1.161)", instead of a green
  # check followed by a separate version line. Read the new version BEFORE
  # spin_stop, and keep the message plain text: spin_stop's TTY path prints it
  # with printf %s, which would NOT interpret embedded color escapes.
  local after="" ok_msg="Claude Code upgraded"
  if [[ $rc -eq 0 ]]; then
    after="$(_image_claude_version)"
    if [[ -n "$before" && -n "$after" && "$before" != "$after" ]]; then
      ok_msg="Claude Code upgraded (${before} → ${after})"
    elif [[ -n "$after" && "$before" == "$after" ]]; then
      ok_msg="Claude Code already at ${after} (no change)"
    elif [[ -n "$after" ]]; then
      ok_msg="Claude Code upgraded (now ${after})"
    fi
  fi
  spin_stop "$rc" "$ok_msg" "Upgrade failed"

  if [[ $rc -ne 0 ]]; then
    echo ""
    echo -e "  ${DIM}Upgrade log:${RESET}"
    tail -20 "$log" 2>/dev/null | sed 's/^/    /'
    rm -f "$log"
    return 1
  fi
  rm -f "$log"

  if [[ -z "$after" ]]; then
    warn "Upgrade committed, but could not read the installed Claude Code version."
  fi

  # Drop the now-orphaned pre-commit layer so repeated upgrades don't stack
  # dangling images. Best-effort and heavily guarded: only when the old id is
  # truly untagged (a version tag like cleat:vX.Y.Z would keep it) and not
  # referenced by any container: `docker rmi` refuses both, harmlessly.
  if [[ -n "$old_id" ]]; then
    local new_id old_tags
    new_id="$(docker image inspect "$IMAGE_NAME" --format '{{.Id}}' 2>/dev/null || true)"
    if [[ "$old_id" != "$new_id" ]]; then
      old_tags="$(docker image inspect "$old_id" --format '{{len .RepoTags}}' 2>/dev/null || echo 1)"
      [[ "$old_tags" == "0" ]] && docker rmi "$old_id" > /dev/null 2>&1 || true
    fi
  fi

  return 0
}

cmd_run() {
  local project box
  project="$(resolve_project "${1:-}")"
  box="${_BOX:-main}"
  _RESOLVED_PROJECT="$project"
  local cname
  cname="$(container_name_for "$project" "$box")"

  if is_running "$cname"; then
    warn "Container ${BOLD}${cname}${RESET} already running for this project."
    return
  fi

  if container_exists "$cname"; then
    docker rm "$cname" > /dev/null
  fi

  if ! image_exists; then
    _do_pull || _do_build
  elif ! _image_arch_ok; then
    # Wrong-arch image (e.g. an amd64 pull cached on Apple Silicon) counts as
    # missing: a box created from it would run emulated. Re-acquire native.
    _warn_image_emulated
    _do_pull || _do_build
  else
    # No leading blank: the bring-up block (Image ready/rebuilt → Container
    # started → …) stays one contiguous coloured group. Separation from the
    # preceding notices is owned by those notices (the release highlight emits
    # a trailing blank), so a rebuild's "Image rebuilt" flows straight into
    # this line instead of being split by a stray blank. See concept/21.
    success "Image ready ${RESET}${DIM}(cached)"
  fi

  # If the image was built by an older Cleat, offer to rebuild it before we
  # create the container (so the fresh container picks up the new setup).
  _maybe_prompt_image_rebuild "$cname"

  # If a newer Claude Code than the image ships is available, offer to bump it
  # (durably, by committing into the image) before we start the container.
  _maybe_prompt_claude_update

  if [[ ! -d "$project" ]]; then
    error "Project directory does not exist: ${BOLD}${project}${RESET}"
    exit 1
  fi

  # Resolve capabilities and env for this run
  resolve_caps "$project"
  resolve_env_args "$project"

  spin "Starting container..."

  # Clipboard bridge
  local clip_dir="$CLEAT_RUN_DIR/${cname}/clip"
  mkdir -p "$clip_dir"

  # ── Settings overlay ──────────────────────────────────────────────────────
  # When hooks OFF: strip hooks from settings (they'd fail in the container).
  # When hooks ON:  replace hook commands with an event forwarder; the host-side
  #                 bridge reads forwarded events and executes the real commands.
  local settings_overlay_dir="$CLEAT_RUN_DIR/${cname}/settings"
  rm -rf "$settings_overlay_dir"
  mkdir -p "$settings_overlay_dir"
  local _overlay_ok=false
  if [[ -f "${HOME}/.claude/settings.json" ]] && [[ -s "${HOME}/.claude/settings.json" ]]; then
    if command -v jq &>/dev/null; then
      if cap_is_active hooks; then
        # Replace hook commands with forwarder; preserve event types and matchers
        local _forwarded
        _forwarded="$(jq '
          if .hooks then
            .hooks |= with_entries(.value |= [.[] |
              .hooks = [.hooks[] | select(.type == "command") |
                .command = "cat >> /var/log/cleat/events.jsonl" | .async = true
              ]
            ])
          else . end
        ' "${HOME}/.claude/settings.json" 2>/dev/null)" || true
        if [[ -n "$_forwarded" ]]; then
          echo "$_forwarded" > "$settings_overlay_dir/settings.json"
          _overlay_ok=true
        fi
      else
        local _stripped
        _stripped="$(jq 'del(.hooks)' "${HOME}/.claude/settings.json" 2>/dev/null)" || true
        if [[ -n "$_stripped" ]]; then
          echo "$_stripped" > "$settings_overlay_dir/settings.json"
          _overlay_ok=true
        fi
      fi
    fi
  fi
  if ! $_overlay_ok; then
    echo '{}' > "$settings_overlay_dir/settings.json"
  fi

  # ── Per-project session isolation ──────────────────────────────────────
  # Claude Code stores sessions under ~/.claude/projects/<key>/ where key
  # is derived from the CWD. Inside containers CWD is always /workspace,
  # so all containers write to ~/.claude/projects/-workspace/. We overlay
  # that path with a per-project directory so each container sees only its
  # own sessions. Input history (arrow-up) lives in ~/.claude/history.jsonl.
  # We overlay that too so each project has its own history.
  # The base ~/.claude mount provides auth and global config.
  local project_session_key
  project_session_key="$(_derive_project_session_key "$project" "$box")"
  local project_session_dir="${HOME}/.claude/projects/${project_session_key}"
  mkdir -p "$project_session_dir"
  # Ensure per-project history file exists (Docker needs the source for bind mounts)
  touch "$project_session_dir/history.jsonl"
  # Also ensure host history.jsonl exists (macOS virtiofs rejects nested mounts
  # when the target file is missing inside the parent bind mount's source)
  touch "${HOME}/.claude/history.jsonl"
  # Also ensure the overlay target exists in the base mount (Docker needs it)
  mkdir -p "${HOME}/.claude/projects/-workspace"

  local mount_args=(
    -v "$project":/workspace
    -v "${HOME}/.claude:/home/coder/.claude"
    -v "$settings_overlay_dir/settings.json:/home/coder/.claude/settings.json"
    -v "${project_session_dir}:/home/coder/.claude/projects/-workspace"
    -v "${project_session_dir}/history.jsonl:/home/coder/.claude/history.jsonl"
    -v "$clip_dir":/tmp/cleat-clip
  )

  # ── hooks capability: shared directory for event forwarding to host bridge
  if cap_is_active hooks; then
    local hooks_dir="$CLEAT_RUN_DIR/${cname}/hooks"
    mkdir -p "$hooks_dir"
    mount_args+=(-v "$hooks_dir":/var/log/cleat)
  fi

  # ── Project-level settings overlays ──────────────────────────────────────
  # When hooks ON:  replace hook commands with forwarder (host bridge executes originals)
  # When hooks OFF: strip hooks entirely (prevent container from running host commands)
  # Without an overlay, project .claude/settings*.json files are visible via the
  # workspace bind mount and Claude Code would try to run host commands (like
  # osascript) inside the container where they don't exist.
  if [[ -d "$project/.claude" ]]; then
    local pf
    for pf in "$project/.claude/settings.json" "$project/.claude/settings.local.json"; do
      [[ -f "$pf" ]] || continue
      local _base _overlay_name
      _base="$(basename "$pf")"
      _overlay_name="project-$_base"
      if cap_is_active hooks; then
        # Replace hook commands with event forwarder
        if [[ -s "$pf" ]] && jq -e '.hooks // empty | length > 0' "$pf" >/dev/null 2>&1; then
          jq '
            if .hooks then
              .hooks |= with_entries(.value |= [.[] |
                .hooks = [.hooks[] | select(.type == "command") |
                  .command = "cat >> /var/log/cleat/events.jsonl" | .async = true
                ]
              ])
            else . end
          ' "$pf" > "$settings_overlay_dir/$_overlay_name" 2>/dev/null || cp "$pf" "$settings_overlay_dir/$_overlay_name"
        else
          cp "$pf" "$settings_overlay_dir/$_overlay_name"
        fi
      else
        # Strip hooks so container can't run host-specific commands
        if [[ -s "$pf" ]] && command -v jq &>/dev/null && jq -e '.hooks // empty | length > 0' "$pf" >/dev/null 2>&1; then
          jq 'del(.hooks)' "$pf" > "$settings_overlay_dir/$_overlay_name" 2>/dev/null || cp "$pf" "$settings_overlay_dir/$_overlay_name"
        else
          cp "$pf" "$settings_overlay_dir/$_overlay_name"
        fi
      fi
      mount_args+=(-v "$settings_overlay_dir/$_overlay_name:/workspace/.claude/$_base")
    done
  fi

  # ── Per-project Claude global-state (.claude.json) isolation ──────────────
  # Build an isolated, persistent per-project ~/.claude.json instead of mounting
  # the shared host file directly. The shared mount let concurrent containers
  # truncate the file (→ "Configuration Error / Unexpected EOF") and leaked
  # trust/MCP approvals across projects. See _build_project_claude_json.
  local project_claude_json="$CLEAT_PROJECTS_DIR/${project_session_key}/claude.json"
  _build_project_claude_json "$project_claude_json"
  mount_args+=(-v "$project_claude_json:/home/coder/.claude.json")

  # ── git capability: mount gitconfig (read-only) for commit identity
  if cap_is_active git; then
    if [[ -f "${HOME}/.gitconfig" ]]; then
      mount_args+=(-v "${HOME}/.gitconfig:/home/coder/.gitconfig:ro")
    fi
  fi

  # ── ssh capability: mount SSH keys (read-only) and forward agent
  if cap_is_active ssh; then
    if [[ -d "${HOME}/.ssh" ]]; then
      mount_args+=(-v "${HOME}/.ssh:/home/coder/.ssh:ro")
    fi
  fi

  local ssh_args=()
  if cap_is_active ssh && [[ -S "${SSH_AUTH_SOCK:-}" ]]; then
    ssh_args+=(-v "${SSH_AUTH_SOCK}:/tmp/ssh-agent.sock" -e "SSH_AUTH_SOCK=/tmp/ssh-agent.sock")
  fi

  # ── gh capability: mount GitHub CLI config (read-write) for token auth
  # Read-write so `gh auth login` inside the container writes tokens back to the
  # host, same model as ~/.claude. Create dir if missing so users can auth from
  # inside the container even without gh installed on the host.
  if cap_is_active gh; then
    mkdir -p "${HOME}/.config/gh"
    mount_args+=(-v "${HOME}/.config/gh:/home/coder/.config/gh")
  fi

  # ── docker capability: mount the host Docker socket so the container can
  # build, run, and manage Docker workloads against the host daemon. Also
  # bind-mount the project at its HOST path (in addition to /workspace) and
  # set workdir there, so $(pwd) returns a host-valid path and bind-mount
  # sources in `docker run -v $(pwd):/app` resolve on the host daemon.
  # Full rationale: concept/15-docker-capability.md.
  local docker_args=()
  if cap_is_active docker; then
    mount_args+=(-v /var/run/docker.sock:/var/run/docker.sock)
    mount_args+=(-v "$project:$project")
    docker_args+=(--workdir "$project" -e "CLEAT_HOST_PROJECT=$project")
    # Session-dir unification: with the docker cap, workdir is the host path
    # (not /workspace), so Claude Code encodes its session directory from
    # that path ('/Users/marcin/proj' → 'projects/-Users-marcin-proj/')
    # instead of the v0.8.0-assumed 'projects/-workspace/'. Overlay the
    # per-project session dir at the host-path-derived location too, so
    # sessions land in the same place regardless of which cap was active
    # when they were created. Slashes become dashes to match Claude's key.
    local _host_project_key="${project//\//-}"
    mkdir -p "${HOME}/.claude/projects/${_host_project_key}"
    mount_args+=(-v "${project_session_dir}:/home/coder/.claude/projects/${_host_project_key}")
  fi

  # ── Per-box memory ceiling. --memory-swap equal to --memory disables swap
  # for the box: a runaway process OOMs inside its own cgroup instead of
  # dragging the whole VM (and every other session) into swap-thrash.
  local box_memory
  box_memory="$(resolve_box_memory "$project" "$box")"

  # ── Per-box CPU ceiling, only when configured ([resources] cpus). No
  # default: CPU is work-conserving, so an unconfigured box keeps all cores.
  local box_cpus cpu_args=()
  box_cpus="$(resolve_box_cpus "$project" "$box")"
  [[ -n "$box_cpus" ]] && cpu_args=(--cpus "$box_cpus")

  # ── Compute config fingerprint and store as label, prefixed with the storage
  # format version so a later formula change is detectable (see _CONFIG_FP_VERSION).
  local config_hash
  config_hash="v${_CONFIG_FP_VERSION}:$(compute_config_fingerprint "$project")"

  local label_args=(
    --label "sh.cleat.config-hash=$config_hash"
    --label "sh.cleat.version=$VERSION"
    --label "sh.cleat.box=$box"
  )

  # ── Host connectivity: always-on so user-defined hooks and MCP servers work
  local host_args=()
  if ! _is_docker_desktop 2>/dev/null; then
    host_args+=(--add-host "host.docker.internal:host-gateway")
  fi

  local _docker_err="/tmp/cleat-err.$$"
  local run_rc=0
  docker run -d \
    --name "$cname" \
    "${mount_args[@]}" \
    "${ssh_args[@]+"${ssh_args[@]}"}" \
    "${docker_args[@]+"${docker_args[@]}"}" \
    "${host_args[@]+"${host_args[@]}"}" \
    "${_RESOLVED_ENV_ARGS[@]+"${_RESOLVED_ENV_ARGS[@]}"}" \
    "${label_args[@]}" \
    -e "HOST_UID=$(id -u)" \
    -e "HOST_GID=$(id -g)" \
    -e "HOME=/home/coder" \
    --pids-limit 4096 \
    --memory "$box_memory" \
    --memory-swap "$box_memory" \
    "${cpu_args[@]+"${cpu_args[@]}"}" \
    --init \
    -it \
    "$IMAGE_NAME" > /dev/null 2>"$_docker_err" || run_rc=$?
  spin_stop "$run_rc" "Container started" "Container failed to start"
  if [[ $run_rc -ne 0 ]]; then
    [[ -s "$_docker_err" ]] && error "${DIM}$(cat "$_docker_err")${RESET}"
    rm -f "$_docker_err"
    # Clean up any partial container state so the next attempt starts fresh
    docker rm -f "$cname" > /dev/null 2>&1 || true
    exit 1
  fi
  rm -f "$_docker_err"

  # A --desc set at creation time (host-side, keyed by cname; never recreates).
  if [[ "${_CLI_DESC_SET:-0}" == "1" ]]; then
    _box_desc_write "$cname" "$_CLI_DESC"
  fi
}

cmd_start() {
  local project box
  project="$(resolve_project "${1:-}")"
  box="${_BOX:-main}"
  _RESOLVED_PROJECT="$project"
  local cname
  cname="$(container_name_for "$project" "$box")"

  # Resolve caps early for startup output and drift detection
  resolve_caps "$project"
  resolve_env_args "$project"

  # Config drift (caps/env keys changed since container was created): prompt
  # to recreate before any docker operations. On accept this removes the
  # container so the branches below fall into cmd_run with the new settings.
  _resolve_config_drift "$cname" "$project"

  # Image-version drift: offer to rebuild before any docker operations. On
  # accept it removes the container too, so the branches below recreate it
  # from the freshly-built image.
  _maybe_prompt_image_rebuild "$cname"

  # Reaper drift: a box created without --init wedges on long sessions; offer
  # a recreate (the branches below then recreate it with the current flags).
  _maybe_prompt_init_recreate "$cname"

  # Start container if not running (restart stopped ones)
  if ! is_running "$cname"; then
    if container_exists "$cname"; then
      # Detect stale mounts. The container's bind sources are baked in at
      # creation and `docker start` re-mounts them as-is, so if any has moved
      # or vanished the start aborts with an opaque OCI error; recreate
      # instead. Two independent classes: a missing/wrong-type settings overlay
      # (_settings_overlay_intact), and any vanished bind source, most often
      # the macOS SSH agent socket, whose launchd path rotates every reboot
      # (_container_bind_sources_present).
      if ! _settings_overlay_intact "$cname" || ! _container_bind_sources_present "$cname"; then
        info "Recreating container ${DIM}(host paths changed)"
        docker rm -f "$cname" > /dev/null 2>&1 || true
        cmd_run "$project"
      else
        # Restarting a stopped container: image already exists
        success "Image ready ${RESET}${DIM}(cached)"
        spin "Starting container..."
        local _docker_err="/tmp/cleat-err.$$"
        local start_rc=0
        docker start "$cname" > /dev/null 2>"$_docker_err" || start_rc=$?
        spin_stop "$start_rc" "Container started" "Container failed to start"
        if [[ $start_rc -ne 0 ]]; then
          [[ -s "$_docker_err" ]] && error "${DIM}$(cat "$_docker_err")${RESET}"
          rm -f "$_docker_err"
          if _is_tty; then
            echo ""
            local yn=""
            _ask_yn yn "Remove container and start fresh? [Y/n] "
            if [[ -z "$yn" || "$yn" == [yY]* ]]; then
              docker rm -f "$cname" > /dev/null 2>&1 || true
              success "Removed ${BOLD}$cname${RESET}."
              cmd_run "$project"
            else
              exit 1
            fi
          else
            error "Try ${BOLD}cleat rm${RESET} then ${BOLD}cleat${RESET} to recreate."
            exit 1
          fi
        fi
        rm -f "$_docker_err" 2>/dev/null
      fi
    else
      cmd_run "$project"
    fi
  else
    success "Image ready ${RESET}${DIM}(cached)"
    success "Container started"
  fi

  success "Auth shared"

  # Docker cap is the only capability that breaks the sandbox: loud warning.
  if cap_is_active docker; then
    warn_sandbox "Docker socket mounted. Container can create host-level processes"
  fi

  show_first_run_tip

  success "Claude launched"
  _print_summary_block "$cname" "$project"
  echo ""
  exec_claude "$cname" --dangerously-skip-permissions
}

cmd_resume() {
  local project box
  project="$(resolve_project "${1:-}")"
  box="${_BOX:-main}"
  _RESOLVED_PROJECT="$project"
  local cname
  cname="$(container_name_for "$project" "$box")"

  # Resolve caps for startup output and drift detection
  resolve_caps "$project"
  resolve_env_args "$project"

  # Config drift: prompt to recreate before refreshing overlays. If the user
  # accepts, the container and tmp dirs are gone; the missing-container path
  # below will call cmd_run, which rebuilds the overlay from scratch.
  _resolve_config_drift "$cname" "$project"

  # Image-version drift: offer to rebuild (and recreate) before resuming.
  _maybe_prompt_image_rebuild "$cname"

  # Reaper drift: a box created without --init wedges on long sessions; offer
  # a recreate (the missing-container path below then recreates it).
  _maybe_prompt_init_recreate "$cname"

  # Refresh settings overlays (user may have changed hooks between stop/resume)
  local settings_overlay_dir="$CLEAT_RUN_DIR/${cname}/settings"
  if [[ -d "$settings_overlay_dir" ]] && command -v jq &>/dev/null; then
    # Global settings overlay
    if [[ -f "${HOME}/.claude/settings.json" ]]; then
      if cap_is_active hooks; then
        jq '
          if .hooks then
            .hooks |= with_entries(.value |= [.[] |
              .hooks = [.hooks[] | select(.type == "command") |
                .command = "cat >> /var/log/cleat/events.jsonl" | .async = true
              ]
            ])
          else . end
        ' "${HOME}/.claude/settings.json" > "$settings_overlay_dir/settings.json" 2>/dev/null || true
      else
        jq 'del(.hooks)' "${HOME}/.claude/settings.json" > "$settings_overlay_dir/settings.json" 2>/dev/null || true
      fi
    fi
    # Project-level settings overlays (only when .claude/ exists)
    if cap_is_active hooks && [[ -d "$project/.claude" ]]; then
      local pf
      for pf in "$project/.claude/settings.json" "$project/.claude/settings.local.json"; do
        local _base _overlay_name
        _base="$(basename "$pf")"
        _overlay_name="project-$_base"
        if [[ -s "$pf" ]] && jq -e '.hooks // empty | length > 0' "$pf" >/dev/null 2>&1; then
          jq '
            if .hooks then
              .hooks |= with_entries(.value |= [.[] |
                .hooks = [.hooks[] | select(.type == "command") |
                  .command = "cat >> /var/log/cleat/events.jsonl" | .async = true
                ]
              ])
            else . end
          ' "$pf" > "$settings_overlay_dir/$_overlay_name" 2>/dev/null || cp "$pf" "$settings_overlay_dir/$_overlay_name"
        elif [[ -f "$pf" ]]; then
          cp "$pf" "$settings_overlay_dir/$_overlay_name"
        else
          echo '{}' > "$settings_overlay_dir/$_overlay_name"
        fi
      done
    fi
  fi

  # Start container if stopped
  if ! is_running "$cname"; then
    if container_exists "$cname"; then
      # Detect stale mounts and recreate transparently (sessions live on the
      # host, so --continue below still resumes the conversation). A missing
      # settings overlay (_settings_overlay_intact) or any vanished bind source,
      # most often the macOS SSH agent socket, whose launchd path rotates
      # every reboot (_container_bind_sources_present), would otherwise make
      # `docker start` abort with an opaque OCI error.
      if ! _settings_overlay_intact "$cname" || ! _container_bind_sources_present "$cname"; then
        info "Recreating container ${DIM}(host paths changed)${RESET}"
        docker rm -f "$cname" > /dev/null 2>&1 || true
        cmd_run "$project"
      else
        local _docker_err="/tmp/cleat-err.$$"
        local resume_rc=0
        docker start "$cname" > /dev/null 2>"$_docker_err" || resume_rc=$?
        if [[ $resume_rc -ne 0 ]]; then
          error "Container failed to start."
          [[ -s "$_docker_err" ]] && error "${DIM}$(cat "$_docker_err")${RESET}"
          rm -f "$_docker_err"
          error "Try ${BOLD}cleat rm${RESET} then ${BOLD}cleat${RESET} to recreate."
          exit 1
        fi
        rm -f "$_docker_err" 2>/dev/null
      fi
    else
      # No container exists (e.g., after `cleat rm`). Session files live on
      # the host at ~/.claude/projects/<key>/, so `--continue` below will
      # pick up right where Claude left off. Create a fresh container and
      # fall through to the resume flow.
      info "No container for this project. Creating fresh ${DIM}(sessions will resume from host)${RESET}"
      cmd_run "$project"
    fi
  fi

  # Docker cap is the only capability that breaks the sandbox: loud warning.
  if cap_is_active docker; then
    warn_sandbox "Docker socket mounted. Container can create host-level processes"
  fi

  success "Session resumed"
  _print_summary_block "$cname" "$project"
  echo ""
  exec_claude "$cname" --dangerously-skip-permissions --continue
}

cmd_stop() {
  local project box
  project="$(resolve_project "${1:-}")"
  box="${_BOX:-main}"
  local cname
  cname="$(container_name_for "$project" "$box")"

  if is_running "$cname"; then
    docker stop "$cname" > /dev/null 2>&1
    success "Session ended. Resume with: ${BOLD}cleat resume${RESET}"
  else
    info "Container not running."
  fi
}

cmd_rm() {
  local project box
  project="$(resolve_project "${1:-}")"
  box="${_BOX:-main}"
  local cname
  cname="$(container_name_for "$project" "$box")"

  if is_running "$cname"; then
    docker stop "$cname" > /dev/null
  fi
  if container_exists "$cname"; then
    docker rm "$cname" > /dev/null
    # Clean up this container's runtime dir: sessions on the host are
    # intentionally NOT touched; they live at ~/.claude/projects/<key>/ and
    # survive cleat rm.
    rm -rf "$CLEAT_RUN_DIR/${cname}" 2>/dev/null || true
    success "Removed ${BOLD}${cname}${RESET}."
    echo -e "    ${DIM}Sessions preserved. Run ${BOLD}cleat resume${RESET}${DIM} to pick up where you left off.${RESET}"
  else
    info "No container to remove."
  fi
  # Remove the box's host-side description unconditionally: `cleat rm <box>` is
  # the documented removal path even for a box that was only ever describe'd.
  _box_desc_remove "$cname"
}

cmd_shell() {
  local project box
  project="$(resolve_project "${1:-}")"
  box="${_BOX:-main}"
  local cname
  cname="$(container_name_for "$project" "$box")"

  require_running "$cname"
  _wait_for_coder_remap "$cname"
  resolve_caps "$project"
  resolve_env_args "$project"
  _ensure_docker_access "$cname"
  info "Container ${BOLD}${cname}${RESET}"
  local shell_rc=0
  docker exec -it "${CLAUDE_ENV[@]}" \
    "${_RESOLVED_ENV_ARGS[@]+"${_RESOLVED_ENV_ARGS[@]}"}" "$cname" \
    runuser -u coder -- bash || shell_rc=$?
  _restore_terminal
  return "$shell_rc"
}

cmd_login() {
  local project box
  project="$(resolve_project "${1:-}")"
  box="${_BOX:-main}"
  local cname
  cname="$(container_name_for "$project" "$box")"

  require_running "$cname"
  _wait_for_coder_remap "$cname"
  resolve_caps "$project"
  resolve_env_args "$project"
  info "Authenticating with your Anthropic team account..."

  # Start browser bridge so auth URL opens automatically and callback works
  local _login_clip_dir="$CLEAT_RUN_DIR/${cname}/clip"
  local _login_browser_pid=""
  local _login_open_cmd
  _login_open_cmd="$(_host_open_cmd)"

  if [ -n "$_login_open_cmd" ]; then
    mkdir -p "$_login_clip_dir"
    local _login_bridge_mode
    _login_bridge_mode="$(_browser_bridge_mode)"
    # host_opens_clicks=0: this watcher only ever sees the auth URL `claude login`
    # launches programmatically through the open shim, never a link the user
    # clicked, so the terminal will NOT open it and deferral is never correct here.
    # The bridge must open it in auto/always (the console code-paste flow uses a
    # non-loopback redirect_uri, so it isn't even detected as an auth URL); only
    # CLEAT_BROWSER_BRIDGE=off withholds the auto-open (the callback proxy still runs).
    _browser_watcher "$_login_clip_dir" "$_login_open_cmd" "$cname" "$_login_bridge_mode" "0" &
    _login_browser_pid=$!
    disown "$_login_browser_pid" 2>/dev/null || true
    if [ "$_login_bridge_mode" = off ]; then
      echo -e "  ${DIM}A URL will appear. Open it in your browser to sign in ${RESET}${DIM}(CLEAT_BROWSER_BRIDGE=off).${RESET}"
    else
      echo -e "  ${DIM}Your browser will open automatically for sign-in.${RESET}"
    fi
  else
    echo -e "  ${DIM}A URL will appear. Open it in your browser to sign in.${RESET}"
  fi
  echo ""

  _ensure_docker_access "$cname"
  local login_rc=0
  docker exec -it "${CLAUDE_ENV[@]}" \
    "${_RESOLVED_ENV_ARGS[@]+"${_RESOLVED_ENV_ARGS[@]}"}" "$cname" \
    runuser -u coder -- claude login || login_rc=$?
  _restore_terminal

  # Cleanup browser bridge
  if [ -n "$_login_browser_pid" ]; then
    kill "$_login_browser_pid" 2>/dev/null || true
    wait "$_login_browser_pid" 2>/dev/null || true
  fi
  rm -f "$_login_clip_dir/.browser-open"

  if [[ $login_rc -eq 0 ]]; then
    success "Auth saved to ~/.claude (shared across all containers)."
  fi
}

cmd_claude() {
  local project box
  project="$(resolve_project "${1:-}")"
  box="${_BOX:-main}"
  local cname
  cname="$(container_name_for "$project" "$box")"

  require_running "$cname"
  _RESOLVED_PROJECT="$project"
  resolve_caps "$project"
  resolve_env_args "$project"

  # Config drift: prompt to recreate. If accepted the container is gone, so
  # call cmd_run to rebuild it before attaching.
  _resolve_config_drift "$cname" "$project"
  if ! container_exists "$cname"; then
    cmd_run "$project"
  fi

  # Refresh project-level settings overlays (hooks may have changed)
  local settings_overlay_dir="$CLEAT_RUN_DIR/${cname}/settings"
  if [[ -d "$settings_overlay_dir" ]] && command -v jq &>/dev/null && cap_is_active hooks && [[ -d "$project/.claude" ]]; then
    local pf
    for pf in "$project/.claude/settings.json" "$project/.claude/settings.local.json"; do
      local _base _overlay_name
      _base="$(basename "$pf")"
      _overlay_name="project-$_base"
      if [[ -s "$pf" ]] && jq -e '.hooks // empty | length > 0' "$pf" >/dev/null 2>&1; then
        jq '
          if .hooks then
            .hooks |= with_entries(.value |= [.[] |
              .hooks = [.hooks[] | select(.type == "command") |
                .command = "cat >> /var/log/cleat/events.jsonl" | .async = true
              ]
            ])
          else . end
        ' "$pf" > "$settings_overlay_dir/$_overlay_name" 2>/dev/null || cp "$pf" "$settings_overlay_dir/$_overlay_name"
      elif [[ -f "$pf" ]]; then
        cp "$pf" "$settings_overlay_dir/$_overlay_name"
      else
        echo '{}' > "$settings_overlay_dir/$_overlay_name"
      fi
    done
  fi

  if cap_is_active docker; then
    warn_sandbox "Docker socket mounted. Container can create host-level processes"
  fi

  success "Claude launched"
  _print_summary_block "$cname" "$project"
  echo ""
  exec_claude "$cname" --dangerously-skip-permissions
}

cmd_logs() {
  local project box
  project="$(resolve_project "${1:-}")"
  box="${_BOX:-main}"
  local cname
  cname="$(container_name_for "$project" "$box")"
  require_running "$cname"
  docker logs -f "$cname"
}

cmd_ps() {
  echo ""
  echo -e "  ${BOLD}Cleat containers:${RESET}"
  echo ""
  local found=false
  while IFS= read -r line; do
    if [[ -n "$line" ]]; then
      found=true
      local name status project_path color meta box_label running rest
      name="$(echo "$line" | awk -F'\t' '{print $1}' | xargs)"
      status="$(echo "$line" | awk -F'\t' '{print $2}' | xargs)"

      # Exit 255 is the Docker-restart signature (the VM went away under the
      # box); without the hint it reads as a crash. RestartPolicy is 'no' by
      # design, so a restarted Docker leaves every box stopped.
      [[ "$status" == *"Exited (255)"* ]] && status="${status}. Docker restarted; resume with: cleat resume"

      # One inspect per container yields everything this row renders: the box
      # label, the running state (dot colour) and the /workspace mount source.
      # Field order is box|running|path so a literal '|' in the project path
      # (legal on disk) falls into the trailing field and can't corrupt the
      # parse of the two fixed-charset fields ahead of it.
      meta="$(docker inspect "$name" --format '{{index .Config.Labels "sh.cleat.box"}}|{{.State.Running}}|{{range .Mounts}}{{if eq .Destination "/workspace"}}{{.Source}}{{end}}{{end}}' 2>/dev/null)"
      box_label="${meta%%|*}"
      rest="${meta#*|}"
      running="${rest%%|*}"
      project_path="${rest#*|}"

      if [[ "$running" == "true" ]]; then color="$GREEN"; else color="$YELLOW"; fi

      # Box column: read from the sh.cleat.box label (concept/20-boxes.md).
      # Containers created before boxes (or the default box) have no label or
      # "main"; either way show nothing extra to keep the default view clean.
      [[ -z "$box_label" || "$box_label" == "<no value>" ]] && box_label="main"

      if [[ "$box_label" != "main" ]]; then
        echo -e "    ${color}●${RESET} ${BOLD}${name}${RESET}  ${DIM}[box: ${box_label}]${RESET}"
      else
        echo -e "    ${color}●${RESET} ${BOLD}${name}${RESET}"
      fi
      echo -e "      ${DIM}${status}${RESET}"
      local box_desc
      box_desc="$(_box_desc_read "$name" | head -n 1)"
      if [[ -n "$box_desc" ]]; then printf '      %b%s%b\n' "$DIM" "$box_desc" "$RESET"; fi
      if [[ -n "$project_path" ]]; then
        echo -e "      ${DIM}${project_path}${RESET}"
      fi
    fi
  done < <(docker ps -a --filter "name=^cleat-" --format "{{.Names}}\t{{.Status}}" 2>/dev/null)

  if ! $found; then
    echo -e "    ${DIM}No containers found.${RESET}"
  fi
  echo ""
  echo -e "  ${DIM}Resume with: cd <project-dir> && cleat resume${RESET}"
  echo ""
}

cmd_stop_all() {
  info "Stopping all Cleat containers..."
  local containers
  containers=$(docker ps -a --filter "name=^cleat-" --format '{{.Names}}' 2>/dev/null)
  if [[ -z "$containers" ]]; then
    info "Nothing to stop."
    return
  fi
  echo "$containers" | while read -r c; do
    docker stop "$c" > /dev/null 2>&1 || true
    docker rm "$c" > /dev/null 2>&1 || true
    echo -e "    ${DIM}removed ${c}${RESET}"
  done
  # Box descriptions are keyed by container name; drop any whose container is now
  # gone (mirrors cmd_clean) so a stale label can't resurrect on box recreate.
  if [[ -d "$CLEAT_BOXES_DIR" ]]; then
    local _bf _bcn
    for _bf in "$CLEAT_BOXES_DIR"/*; do
      [[ -f "$_bf" ]] || continue
      _bcn="$(basename "$_bf")"
      if ! container_exists "$_bcn"; then rm -f "$_bf" 2>/dev/null || true; fi
    done
  fi
  success "All stopped."
}

cmd_status() {
  local project box
  project="$(resolve_project "${1:-}")"
  box="${_BOX:-main}"
  local cname
  cname="$(container_name_for "$project" "$box")"

  # Resolve caps for display only: never trigger a trust prompt from
  # a read-only status call.
  resolve_caps "$project" readonly

  echo ""
  echo -e "  ${BOLD}Project:${RESET}   ${project}"
  echo -e "  ${BOLD}Container:${RESET} ${cname}"

  if is_running "$cname"; then
    echo -e "  ${BOLD}Status:${RESET}    ${GREEN}● running${RESET}"
    # Zombie pressure: a pre---init box accumulates unreapable zombies until
    # fork() fails at the pids cap and the session freezes. Surface the count
    # while it's still a warning, not a wedge.
    local _zombies
    _zombies="$(_box_zombie_count "$cname")"
    if [[ "$_zombies" =~ ^[0-9]+$ ]] && (( _zombies > 0 )); then
      echo -e "  ${BOLD}Zombies:${RESET}   ${AMBER}● ${_zombies} unreaped${RESET} ${DIM}(recreate the box to get the --init reaper: cleat rm && cleat)${RESET}"
    fi
  elif container_exists "$cname"; then
    echo -e "  ${BOLD}Status:${RESET}    ${YELLOW}● stopped${RESET}"
  else
    echo -e "  ${BOLD}Status:${RESET}    ${DIM}○ not created${RESET}"
  fi

  if image_exists; then
    local size iarch darch
    size=$(docker images "$IMAGE_NAME" --format '{{.Size}}' | head -1)
    iarch="$(_image_arch "$IMAGE_NAME")"
    darch="$(_daemon_arch)"
    if [[ -n "$iarch" && -n "$darch" && "$iarch" != "$darch" ]]; then
      # Loud: an emulated image is the documented trigger for node crashes
      # and garbled TTYs, and the next `cleat start` will replace it anyway.
      echo -e "  ${BOLD}Image:${RESET}     ${AMBER}● ${IMAGE_NAME} (${iarch}, EMULATED on ${darch}; next start fetches native)${RESET} ${DIM}(${size})${RESET}"
    elif [[ -n "$iarch" ]]; then
      echo -e "  ${BOLD}Image:${RESET}     ${GREEN}● ${IMAGE_NAME}${RESET} ${DIM}(${iarch}, ${size})${RESET}"
    else
      echo -e "  ${BOLD}Image:${RESET}     ${GREEN}● ${IMAGE_NAME}${RESET} ${DIM}(${size})${RESET}"
    fi
  else
    echo -e "  ${BOLD}Image:${RESET}     ${DIM}○ not built${RESET}"
  fi

  if [[ -d "${HOME}/.claude" ]] && find "${HOME}/.claude" -name '.credentials*' -o -name 'credentials*' 2>/dev/null | grep -q .; then
    echo -e "  ${BOLD}Auth:${RESET}      ${GREEN}● logged in${RESET} ${DIM}(via ~/.claude)${RESET}"
  else
    echo -e "  ${BOLD}Auth:${RESET}      ${YELLOW}○ not configured${RESET} ${DIM}(cleat login)${RESET}"
  fi

  # Show active capabilities: same categorized renderer as the post-launch
  # summary block; status passes BOLD to match the other status labels.
  if [[ ${#ACTIVE_CAPS[@]} -gt 0 ]]; then
    _print_caps "  " "Caps:" "      " "$BOLD"
  else
    echo -e "  ${BOLD}Caps:${RESET}      ${DIM}none${RESET} ${DIM}(cleat config)${RESET}"
  fi

  # ── Boxes: every sandbox for this project (see concept/20-boxes.md). The
  # detail above is the main box; this lists all boxes (main + named) so you
  # can see what exists here. Boxes are discovered by the INVARIANT project hash
  # plus the sh.cleat.box label and the /workspace mount source, NOT the main
  # container-name prefix (container_name_for re-truncates the dir segment per
  # box, so a long project dir would otherwise HIDE named boxes here, and a
  # sibling project could collide on the prefix and show a phantom box). The
  # `< <(... || true)` form also keeps `set -euo pipefail` from aborting status
  # when the docker daemon is down. See concept/20-boxes.md.
  echo ""
  echo -e "  ${BOLD}Boxes:${RESET}"
  local _main_cname _hash _n _meta _b _rest _running _src
  _main_cname="$(container_name_for "$project" main)"
  _hash="$(echo -n "$project" | _md5 | head -c 8)"
  # Third arg is an OPTIONAL pre-resolved running state ("true"/"false"). The
  # named-box loop already learns this from its one discovery inspect, so it
  # passes it here to skip the is_running + container_exists docker calls. The
  # main row passes nothing and falls back to probing (it may not exist yet).
  _status_box_row() {
    local _bx="$1" _cn="$2" _known="${3:-}"
    if [[ "$_known" == "true" ]]; then
      echo -e "    ${GREEN}●${RESET} ${BOLD}${_bx}${RESET} ${DIM}running${RESET}"
    elif [[ "$_known" == "false" ]]; then
      echo -e "    ${YELLOW}●${RESET} ${BOLD}${_bx}${RESET} ${DIM}stopped${RESET}"
    elif is_running "$_cn"; then
      echo -e "    ${GREEN}●${RESET} ${BOLD}${_bx}${RESET} ${DIM}running${RESET}"
    elif container_exists "$_cn"; then
      echo -e "    ${YELLOW}●${RESET} ${BOLD}${_bx}${RESET} ${DIM}stopped${RESET}"
    else
      echo -e "    ${DIM}○ ${_bx}${RESET} ${DIM}not created${RESET}"
    fi
    # First line only: a multi-line description must not break the list layout.
    local _desc
    _desc="$(_box_desc_read "$_cn" | head -n 1)"
    if [[ -n "$_desc" ]]; then printf '        %b%s%b\n' "$DIM" "$_desc" "$RESET"; fi
  }
  _status_box_row "main" "$_main_cname"
  while IFS= read -r _n; do
    [[ -z "$_n" ]] && continue
    # Cheap pre-filter on the invariant hash; the mount-source check below is
    # authoritative (a sibling project could embed this hash in its dir name).
    case "$_n" in *"-${_hash}"*) ;; *) continue ;; esac
    # One inspect per candidate yields label|running|workspace-source. Field
    # order keeps the (possibly '|'-bearing) path trailing so it can't corrupt
    # the parse of the two fixed-charset fields ahead of it.
    _meta="$(docker inspect "$_n" --format '{{index .Config.Labels "sh.cleat.box"}}|{{.State.Running}}|{{range .Mounts}}{{if eq .Destination "/workspace"}}{{.Source}}{{end}}{{end}}' 2>/dev/null || true)"
    _b="${_meta%%|*}"
    _rest="${_meta#*|}"
    _running="${_rest%%|*}"
    _src="${_rest#*|}"
    if [[ -z "$_b" || "$_b" == "<no value>" ]]; then _b="main"; fi
    [[ "$_src" == "$project" ]] || continue
    [[ "$_b" == "main" ]] && continue
    # A candidate from `docker ps -a` always exists, so running/stopped is the
    # only distinction: pass the inspect's State.Running and skip re-probing.
    _status_box_row "$_b" "$_n" "$_running"
  done < <(docker ps -a --filter "name=^cleat-" --format '{{.Names}}' 2>/dev/null || true)

  # ── VM memory budget: running containers' limits vs what the VM actually
  # has. Overcommit means the limits can't bind and a runaway process swap-
  # thrashes EVERY session at once (counts all containers: the VM is shared).
  # Trigger AND display in the SAME whole-GB unit (the configured slider via
  # _docker_vm_display_gb), mirroring the on-start overload path: comparing raw
  # bytes against the kernel's MemTotal while PRINTING the rounded slider let the
  # line fire and then print parity ("promised 24 GB of a 24 GB VM") or even an
  # inverted "promised 23 GB of a 24 GB VM" whenever the sum landed in the gap
  # between MemTotal and the slider. One unit for both makes that impossible.
  local _vm_bytes _limit_sum _sum_gb _vm_gb
  _vm_bytes="$(_docker_vm_memory)"
  if [[ "$_vm_bytes" =~ ^[0-9]+$ ]] && (( _vm_bytes > 0 )); then
    _limit_sum="$(_running_memory_limits_sum)"
    if [[ "$_limit_sum" =~ ^[0-9]+$ ]]; then
      _sum_gb=$(( _limit_sum / 1073741824 ))
      _vm_gb="$(_docker_vm_display_gb "$_vm_bytes")"
      if (( _sum_gb > _vm_gb )); then
        echo ""
        echo -e "  ${BOLD}VM memory:${RESET} ${AMBER}● overcommitted${RESET}${DIM}: running containers reserve ${_sum_gb} GB of ceilings on a ${_vm_gb} GB VM${RESET}"
      fi
    fi
  fi
  echo ""
}

# ── Prune: cleat-owned image bloat ──────────────────────────────────────────
# Two artifact classes accrete in daily use (see concept/22):
#   1. Dangling images labeled sh.cleat.version: every drift rebuild orphans
#      the previous build (1.5-2.5 GB each, several per day for a maintainer).
#   2. Superseded ghcr.io prebuilt version tags: `cleat update` pulls the new
#      tag but never removed old ones (~1 GB per release; amd64-era tags can
#      never be used natively again on Apple Silicon).
# Boxes (even exited ones) are NEVER touched: a stopped box is a resumable
# session holding /tmp state. Other projects' images and caches are never
# touched. This is the safe middle ground between `clean` and `nuke`.

# Seams for cmd_prune/_cleat_prunable_stats (overridable in tests: the docker
# stub serves one canned `images` response for every query shape).
_dangling_cleat_images() {
  docker images -f dangling=true -f label=sh.cleat.version -q 2>/dev/null || true
}

# Prints "tag<TAB>size" per prebuilt image (size used by the stats helper).
_prebuilt_image_tags() {
  docker images "$REGISTRY_BASE" --format '{{.Repository}}:{{.Tag}}	{{.Size}}' 2>/dev/null || true
}

# Count and approximate size (MB) of prunable cleat artifacts: "count<TAB>mb".
# Sizes are docker's human strings (1.72GB / 971MB): close enough to decide
# whether a prune is worth offering.
_cleat_prunable_stats() {
  {
    local id
    while IFS= read -r id; do
      [[ -n "$id" ]] || continue
      # Unsizeable still counts: the artifact exists even if inspect hiccups.
      docker image inspect "$id" --format '{{.Size}}B' 2>/dev/null || echo "0B"
    done < <(_dangling_cleat_images)
    _prebuilt_image_tags | awk -F'\t' -v cur="${REGISTRY_BASE}:v${VERSION}" \
      '$1 != cur && $1 != "" {print $2}'
  } | awk '
    /GB$/ { sub(/GB$/,"");  mb += $0 * 1024;           n++; next }
    /MB$/ { sub(/MB$/,"");  mb += $0;                  n++; next }
    /B$/  { sub(/B$/,"");   mb += $0 / 1048576;        n++; next }
    { n++ }
    END { printf "%d\t%d", n, mb }
  '
}

cmd_prune() {
  local removed=0 failed=0

  # Superseded prebuilt version tags (everything but the current version's).
  local line tag
  while IFS= read -r line; do
    tag="${line%%	*}"
    [[ -z "$tag" ]] && continue
    [[ "$tag" == "${REGISTRY_BASE}:v${VERSION}" ]] && continue
    if docker rmi "$tag" > /dev/null 2>&1; then
      removed=$((removed + 1))
    else
      failed=$((failed + 1))   # in use by a container; leave it
    fi
  done < <(_prebuilt_image_tags)

  # Dangling cleat builds (label-filtered: other projects' dangling images
  # are not ours to delete).
  local id
  while IFS= read -r id; do
    [[ -z "$id" ]] && continue
    if docker rmi "$id" > /dev/null 2>&1; then
      removed=$((removed + 1))
    else
      failed=$((failed + 1))
    fi
  done < <(_dangling_cleat_images)

  if (( removed > 0 )); then
    success "Pruned ${removed} stale cleat image$( (( removed != 1 )) && echo s )."
  else
    info "Nothing to prune."
  fi
  if (( failed > 0 )); then
    echo -e "    ${DIM}${failed} kept (still referenced by a container).${RESET}"
  fi
}

# ── On-start Docker pressure check ──────────────────────────────────────────
# TTY-only, throttled to once per day, entirely local, fail-soft (a down
# daemon yields empty reads and silence). Two independent signals:
#   1. BLOAT: prunable cleat artifacts above ~5 GB → offer `cleat prune`
#      ([Y/n]; the fix is safe and one keypress away: users should never be
#      told to run manual docker cleanup).
#   2. OVERLOAD: running containers' memory limits overcommit the Docker VM
#      → a one-line notice. No auto-fix: resizing the VM or stopping boxes is
#      the user's call. Counts ALL running containers, not just cleat's: the
#      VM is shared, and a neighboring compose stack squeezes cleat boxes
#      just the same.
_PRESSURE_BLOAT_MB_THRESHOLD=5120

# Count zombie processes inside a running box by reading /proc directly (the
# image ships no `ps`). The comm field in /proc/N/stat may contain spaces, so
# strip through the closing paren before taking the state field. Empty output
# on any failure: callers treat that as "unknown", never as an error.
_box_zombie_count() {
  docker exec "$1" sh -c '
    z=0
    for f in /proc/[0-9]*/stat; do
      s=$(sed "s/^[^)]*) //" "$f" 2>/dev/null | cut -d" " -f1)
      [ "$s" = "Z" ] && z=$((z+1))
    done
    echo "$z"
  ' 2>/dev/null || true
}

# Sum of HostConfig.Memory over all RUNNING containers, in bytes.
_running_memory_limits_sum() {
  local ids=() id sum=0 mem
  while IFS= read -r id; do
    [[ -n "$id" ]] && ids+=("$id")
  done < <(docker ps -q 2>/dev/null || true)
  if [[ ${#ids[@]} -eq 0 ]]; then
    echo 0
    return
  fi
  while IFS= read -r mem; do
    [[ "$mem" =~ ^[0-9]+$ ]] || continue
    sum=$(( sum + mem ))
  done < <(docker inspect --format '{{.HostConfig.Memory}}' "${ids[@]}" 2>/dev/null || true)
  echo "$sum"
}

# Names of RUNNING cleat boxes, one per line (the sh.cleat.version label is on
# every box this CLI creates; non-cleat containers never carry it). Seam for the
# overload message's session count and the idle sweep. Empty on a down daemon.
_running_cleat_boxes() {
  docker ps --filter "label=sh.cleat.version" --format '{{.Names}}' 2>/dev/null || true
}

# Count of running cleat boxes (0 on any failure).
_running_cleat_box_count() {
  local n=0 name
  while IFS= read -r name; do
    [[ -n "$name" ]] && n=$(( n + 1 ))
  done < <(_running_cleat_boxes)
  echo "$n"
}

# Recommended Docker VM size in whole GB: the comfortable-default target
# (_PRESSURE_TARGET_VM_GB, 16 GiB, room for several sessions to each spike near
# their quarter-of-VM ceiling at once, NOT a session cap), but never more than half the
# host's RAM (leave the rest for macOS + apps). Host RAM unknown → just the
# target. Always ≥ 1. Arg: $1 = host RAM bytes (may be empty).
_recommended_vm_gb() {
  local host_bytes="${1:-}" rec="$_PRESSURE_TARGET_VM_GB" half
  if [[ "$host_bytes" =~ ^[0-9]+$ ]] && (( host_bytes > 0 )); then
    half=$(( host_bytes / 2 / 1073741824 ))
    (( half < rec )) && rec=$half
  fi
  (( rec < 1 )) && rec=1
  echo "$rec"
}

# Print the two concrete Docker-Desktop steps that fix the VM (the one knob the
# `docker` CLI cannot touch). The CALLER prints the lead-in line and guarantees
# this is Docker Desktop AND that growing the VM actually helps (recommended >
# current): on a host already near its safe max we steer to "fewer sessions"
# instead, so this never names a target SMALLER than the VM they already have.
#
# Colour discipline (kept consistent so the block reads as ONE thing, not a
# random mix): every line is a DIM bullet so none starts on a bold word (which
# read as a section break); BOLD marks only what you click or set (the menu
# paths, the memory/swap values, VirtioFS); DIM carries the connective prose.
# No amber in the body, that belongs to the `!` marker alone. No engine
# re-detection here (the caller detects once) and no trailing blank (the
# pressure block owns that, so the gap survives when this block is skipped).
# Args: $1 = host RAM bytes (may be empty), $2 = recommended GB.
_print_docker_vm_fix() {
  local host_bytes="${1:-}" rec_gb="${2:-$_PRESSURE_TARGET_VM_GB}" max_note=""
  if [[ "$host_bytes" =~ ^[0-9]+$ ]] && (( host_bytes > 0 )); then
    max_note="${DIM}   (max ≈ $(( host_bytes * 3 / 4 / 1073741824 )) GB)${RESET}"
  fi
  echo -e "    ${DIM}•${RESET} ${BOLD}Settings → Resources → Advanced${RESET}${DIM}: set ${RESET}${BOLD}Memory limit ${rec_gb} GB${RESET}${DIM} and ${RESET}${BOLD}Swap ≥ 2 GB${RESET}${DIM}, then Apply & restart${RESET}${max_note}"
  echo -e "    ${DIM}•${RESET} ${DIM}Faster I/O: ${RESET}${BOLD}Settings → General → Virtual Machine Options${RESET}${DIM} → ${RESET}${BOLD}VirtioFS${RESET}"
}

# ── Idle-session sweep ───────────────────────────────────────────────────────
# True when a real agent is running inside the box: claude (a node process) or a
# bare node shows in the container's process list. A DETACHED box (terminal
# closed, the foreground exec gone) runs only docker-init/su/bash, so this is
# false. A box working UNATTENDED keeps its host `docker exec` (and thus the
# claude/node process) alive, so this is TRUE and the sweep leaves it strictly
# alone (the "leave it running, walk away" promise). `docker top` reads the
# process list from the daemon (the image ships no `ps`), so no exec is needed.
# Fails SAFE: any error, or output we can't read, is treated as "live" → skip.
_box_has_live_agent() {
  local top
  top="$(docker top "$1" 2>/dev/null)" || return 0     # unreadable → assume live (safe)
  [[ -n "$top" ]] || return 0                          # empty → assume live (safe)
  printf '%s\n' "$top" | grep -qiE 'claude|node'
}

# Stop cleat boxes that are PROVABLY safe to stop: detached (no live agent) AND
# idle past the grace window. Never stops $1 (the box being launched now) or any
# box with a live agent. A stopped box is preserved on disk; running `cleat` in
# its project brings it right back, so the notice does not nag about resuming.
# Prints ONE summary line when it stops anything. Args: $1 = self cname to skip,
# $2 = grace seconds. Fail-soft; TTY-gating is the caller's job.
_sweep_idle_boxes() {
  local self="${1:-}" grace_secs="${2:-$_IDLE_SWEEP_GRACE_SECS}"
  local now name age mem victims=() freed=0
  now="$(date +%s)"
  while IFS= read -r name; do
    [[ -n "$name" ]] || continue
    [[ "$name" == "$self" ]] && continue
    # Grace gate FIRST (cheap, local, and decisive for cost): the run dir's mtime
    # is re-stamped on attach AND detach (exec_claude / _cleanup_session), so
    # `now - mtime` is the time since this box last had a host session. Skip boxes
    # inside the grace window, and skip an unknown age (0/unreadable) rather than
    # stop on an unknown clock. Running this before the `docker top` round-trip
    # avoids one daemon call per within-grace box AND shrinks the window where a
    # box another terminal just re-attached to (mtime freshly stamped) could be
    # caught during its bring-up, before claude shows up in the process list.
    age="$(_path_mtime "$CLEAT_RUN_DIR/$name")"
    [[ "$age" =~ ^[0-9]+$ ]] && (( age > 0 )) || continue
    (( now - age < grace_secs )) && continue
    # Liveness gate: a claude/node process means the box is attached or working
    # unattended → never touch it. Fail-safe (an unreadable `docker top` = live).
    _box_has_live_agent "$name" && continue
    mem="$(docker inspect --format '{{.HostConfig.Memory}}' "$name" 2>/dev/null)" || mem=0
    [[ "$mem" =~ ^[0-9]+$ ]] && (( mem > 0 )) && freed=$(( freed + mem ))
    victims+=("$name")
  done < <(_running_cleat_boxes)

  [[ ${#victims[@]} -gt 0 ]] || return 0
  docker stop "${victims[@]}" >/dev/null 2>&1 || true
  local n=${#victims[@]} gb=$(( (freed + 536870912) / 1073741824 )) freed_note=""
  (( gb > 0 )) && freed_note=", freed ${gb} GB"
  echo ""
  info "Stopped ${n} idle session$( (( n != 1 )) && printf s )${freed_note}. ${DIM}A detached box keeps its memory ceiling until stopped.${RESET}"
}

# On-start wrapper: TTY-only (never on a pipe or in cron), opt-out via
# CLEAT_NO_IDLE_SWEEP=1, grace override via CLEAT_IDLE_GRACE_MINS. Resolves the
# box being launched from the same [box] positional the dispatch passes, so the
# sweep never stops the session you are starting. Entirely fail-soft.
_maybe_sweep_idle_boxes() {
  _is_tty || return 0
  [[ "${CLEAT_NO_IDLE_SWEEP:-}" == "1" ]] && return 0
  command -v docker >/dev/null 2>&1 || return 0
  # Don't sweep for a malformed invocation that _set_box is about to reject (an
  # extra positional, or an invalid box name): a command that won't run must not
  # stop any box. Let validation error first.
  [[ $# -gt 1 ]] && return 0
  [[ -n "${1:-}" ]] && ! _validate_box_name "$1" 2>/dev/null && return 0
  local grace_secs="$_IDLE_SWEEP_GRACE_SECS"
  [[ "${CLEAT_IDLE_GRACE_MINS:-}" =~ ^[0-9]+$ ]] && grace_secs=$(( CLEAT_IDLE_GRACE_MINS * 60 ))
  local self_project self_box="main" self_cname=""
  self_project="$(resolve_project 2>/dev/null || printf '%s' "$PWD")"
  [[ -n "${1:-}" ]] && self_box="$1"   # already validated above
  self_cname="$(container_name_for "$self_project" "$self_box" 2>/dev/null || true)"
  _sweep_idle_boxes "$self_cname" "$grace_secs"
}

_maybe_check_docker_pressure() {
  _is_tty || return 0

  # Two cadences. The bloat→prune prompt and the OVERLOAD notice are PERIODIC
  # (throttled to once per interval): the first is an interactive prompt, the
  # second a transient runtime condition (a promise > VM compares ceilings, not
  # usage, and is often harmless), so neither should fire on every start. The
  # UNDERSIZED-VM advisory is different: an invalid Docker config (the VM memory
  # slider set too low) must surface on EVERY start until it is fixed, the same
  # way the positive "Docker tuned" line shows on every good start. So the daily
  # stamp gates only the periodic halves; the undersized advisory ignores it.
  local now last=0 bloat_due=true
  now="$(date +%s)"
  if [[ -f "$PRESSURE_CHECK_FILE" ]]; then
    last="$(head -1 "$PRESSURE_CHECK_FILE" 2>/dev/null || echo 0)"
    [[ "$last" =~ ^[0-9]+$ ]] || last=0
  fi
  (( now - last < PRESSURE_CHECK_INTERVAL )) && bloat_due=false

  # Whitespace model: every notice owns ONE blank line ABOVE it. For the first
  # notice that blank separates the section from the update/restart lines above;
  # for a later notice it separates it from the previous one (the prune prompt and
  # the VM advisory can both fire on the daily check, and ran flush together before
  # v0.16.4). The prune notice prints its leading blank only when nothing came
  # before it (`$printed || echo ""`); the VM advisories print theirs always (so
  # the prune→advisory gap is never lost). `printed` also gates a single TRAILING
  # blank after the last notice (owned HERE, not inside the Docker-Desktop fix
  # block, so the gap survives when that block is skipped), which flags
  # _ONSTART_GAP_OPEN so the highlight doesn't add a second.
  local printed=false

  # 1. Bloat → prune prompt (periodic; only on the daily check).
  if $bloat_due; then
    echo "$now" > "$PRESSURE_CHECK_FILE" 2>/dev/null || true
    local stats count mb
    stats="$(_cleat_prunable_stats)"
    count="${stats%%	*}"
    mb="${stats##*	}"
    if [[ "$count" =~ ^[0-9]+$ && "$mb" =~ ^[0-9]+$ ]] && (( mb >= _PRESSURE_BLOAT_MB_THRESHOLD )); then
      $printed || echo ""
      info "Docker is carrying ${BOLD}${count} stale cleat images${RESET} ${DIM}(~$(( (mb + 512) / 1024 )) GB of old builds and superseded pulls)${RESET}"
      printed=true
      local yn=""
      _ask_yn yn "Prune them now? ${DIM}(boxes and other projects are not touched)${RESET} [Y/n] "
      if [[ -z "$yn" || "$yn" == [yY]* ]]; then
        cmd_prune
      fi
    fi
  fi

  # 2. VM memory vs the host + the running sessions. A box and a worktree are
  #    the same thing here: one session, one quarter-of-VM ceiling. Both point at the one
  #    knob the `docker` CLI can't change: the Docker Desktop memory slider.
  local vm_bytes sum host_bytes vm_gb rec_gb is_dd=false host_note=""
  vm_bytes="$(_docker_vm_memory)"
  if [[ "$vm_bytes" =~ ^[0-9]+$ ]] && (( vm_bytes > 0 )); then
    vm_gb="$(_docker_vm_display_gb "$vm_bytes")"   # prefer the configured slider; fall back to rounding MemTotal
    sum="$(_running_memory_limits_sum)"
    host_bytes="$(_host_total_memory)"
    rec_gb="$(_recommended_vm_gb "$host_bytes")"
    # Detect the engine ONCE: every `docker info` is a round-trip to a daemon
    # that's slow precisely when this fires (under swap), so we never call it
    # again per-branch.
    _is_docker_desktop 2>/dev/null && is_dd=true
    [[ "$host_bytes" =~ ^[0-9]+$ ]] && (( host_bytes > 0 )) \
      && host_note=" of your ${BOLD}$(( host_bytes / 1073741824 )) GB${RESET}"

    # Compare in the SAME whole-GB unit the message prints (vm_gb, the configured
    # slider via _docker_vm_display_gb), not raw MemTotal bytes: a slider that
    # rounds UP relative to MemTotal would otherwise let the trigger fire while the
    # printed "promised X of Y" reads as parity (X == Y) or even inverted, the
    # "shows X but warns it's too small" contradiction _vm_gb_rounded forbids.
    local overloaded=false sum_gb=0
    [[ "$sum" =~ ^[0-9]+$ ]] && sum_gb=$(( sum / 1073741824 ))
    [[ "$sum" =~ ^[0-9]+$ ]] && (( sum_gb > vm_gb )) && overloaded=true

    # 2a. OVERLOAD (periodic): the sessions running RIGHT NOW are promised more
    #     memory than the VM has. Real on any engine, so the warn always fires and
    #     names the real RAM. The follow-up is honest about the host: where the VM
    #     can safely grow (recommended > current) we point at the Docker Desktop
    #     memory slider; where it can't (the VM is already near ~¾ of host RAM,
    #     e.g. a 7 GB VM on an 8 GB Mac) growing it is impossible/harmful, so we
    #     steer to running fewer sessions or lowering a box's own ceiling instead.
    #     Never suggests a VM target below the current. Shown on the daily check
    #     only (it's transient, not a config error worth nagging every start).
    if $overloaded && $bloat_due; then
      echo ""
      # Name the COUNT of running cleat sessions, not just a GB number: "promised
      # 25 GB" next to a 24 GB slider reads like an off-by-one rounding bug, when
      # it's really N boxes each reserving a quarter-of-VM ceiling. The GB clause
      # has a SEPARATE subject ("running containers"), because the sum spans ALL
      # running containers (the VM is shared) while the count is cleat-only: a
      # non-cleat stack must not be mislabeled as cleat sessions. "reserve
      # ceilings" (not "promised") also stops the number reading as a hard
      # reservation or live usage (idle boxes touch a fraction of their ceiling).
      # _s is computed with a standalone `(( )) && _s=s` (set -e safe: a failing
      # non-final command of a top-level &&-list is exempt), NOT inside the
      # assignment, where the substitution's exit 1 on the singular case would
      # abort `cleat start` under `set -euo pipefail`.
      local _n_boxes _who _s=""
      _n_boxes="$(_running_cleat_box_count)"
      if [[ "$_n_boxes" =~ ^[0-9]+$ ]] && (( _n_boxes > 0 )); then
        (( _n_boxes != 1 )) && _s="s"
        _who="${_n_boxes} session${_s} still running"
      else
        _who="Sessions are still running"
      fi
      warn "${_who}; running containers reserve ${sum_gb} GB of memory ceilings but the Docker VM holds only ${vm_gb} GB${host_note}. Under load they swap together and freeze."
      if $is_dd && (( rec_gb > vm_gb )); then
        echo -e "    ${DIM}Closing a terminal does not stop its box. Stop one you are done with, or give Docker more memory (Docker Desktop only):${RESET}"
        _print_docker_vm_fix "$host_bytes" "$rec_gb"
      else
        echo -e "    ${DIM}Closing a terminal does not stop its box. Stop ones you are done with (${RESET}${BOLD}cleat stop${RESET}${DIM}), or lower a box's ceiling with ${RESET}${BOLD}[resources] memory${RESET}${DIM} in .cleat.${RESET}"
      fi
      printed=true
      _VM_ADVISORY_SHOWN=1

    # 2b. UNDERSIZED VM for parallel work: Docker-Desktop-only (a native-Linux
    #     engine's "VM" is the host: nothing to resize). The recommendation is
    #     host-aware (the comfortable-default target, capped at half the host RAM).
    #     This is the invalid CONFIG, so it shows on EVERY start while the VM is
    #     below the target, until it's set right (not throttled: a once-a-day nudge
    #     is too easy to miss, and a smooth run depends on the VM being sized well).
    #     Host RAM unknown → conservative 8 GiB floor so we never over-recommend.
    elif $is_dd; then
      local bad=false
      # Compare in WHOLE rounded GB (vm_gb), never raw bytes: the kernel's
      # MemTotal undershoots the slider, so a byte compare against an exact GiB
      # target false-positives a correctly-sized VM (a 16 GB slider reads ~15.6
      # GiB < 16 GiB). vm_gb already rounds that back to 16. The announce-ready
      # all-clear mirrors this test exactly; keep the two in lockstep.
      if [[ "$host_bytes" =~ ^[0-9]+$ ]] && (( host_bytes > 0 )); then
        (( vm_gb < rec_gb )) && bad=true
      else
        (( vm_gb < _PRESSURE_VM_ADVISORY_BYTES / 1073741824 )) && bad=true
      fi
      if $bad; then
        echo ""
        warn "Docker VM memory is ${BOLD}${vm_gb} GB${RESET}${host_note}. Tight for parallel sessions."
        echo -e "    ${DIM}Each box reserves a memory ceiling (a quarter of the VM). Give Docker more memory (Docker Desktop only):${RESET}"
        _print_docker_vm_fix "$host_bytes" "$rec_gb"
        printed=true
        _VM_ADVISORY_SHOWN=1
      fi
    fi
  fi

  # One blank line separates whatever we printed from the release highlight (or
  # the bring-up) that follows. Flag the open gap so the highlight doesn't add a
  # second blank of its own.
  if $printed; then
    echo ""
    _ONSTART_GAP_OPEN=1
  fi
}

# The every-start, positive counterpart to the pressure advisory: when the Docker
# VM is sized right for parallel work, say so in ONE green line that sits directly
# above the bring-up. Runs on every session-launching start (NOT daily-gated like
# the warning: the reassurance is wanted each time), and is the exact inverse of
# the 2b "undersized" test, so the two are complementary, never both, never
# contradictory: a correctly sized VM shows this, an undersized one shows the
# warning. Costs a single `docker info` (MemTotal); the host read is local.
#
# One twist on top of the inverse: even with memory sized right, swap may be left
# at the Docker Desktop default. So when memory passes but swap reads below the
# target, this prints a focused swap advisory in place of the all-clear (memory is
# good, swap needs a nudge). Swap that can't be read falls through to the all-clear.
#
# Whitespace: one blank ABOVE unless an earlier notice already opened the gap, and
# NEVER a trailing blank, so "Image ready" flows straight on from this line and
# the two read as one contiguous block (the placement the maintainer asked for).
# Silent off a TTY, when the VM size can't be read, or when the VM is undersized
# (don't claim "tuned" when it isn't, and don't fight the warning).
_maybe_announce_docker_ready() {
  _is_tty || return 0
  # Defer to the warning: if the pressure check already flagged the VM (overload or
  # undersized) this run, stay silent so a "tuned" nod and a warning never both
  # appear (the overload case can fire even on an adequately sized VM).
  [[ "${_VM_ADVISORY_SHOWN:-0}" == "1" ]] && return 0
  local vm_bytes vm_gb host_bytes rec_gb
  vm_bytes="$(_docker_vm_memory)"
  [[ "$vm_bytes" =~ ^[0-9]+$ ]] && (( vm_bytes > 0 )) || return 0
  vm_gb="$(_docker_vm_display_gb "$vm_bytes")"   # prefer the configured slider (see _docker_vm_display_gb)
  host_bytes="$(_host_total_memory)"
  rec_gb="$(_recommended_vm_gb "$host_bytes")"
  # Adequately sized? Mirror the 2b "bad" test EXACTLY: compare WHOLE rounded GB
  # (host-aware target when host RAM is known, else the conservative 8 GiB floor)
  # so this and the warning are perfect complements. A byte compare here would
  # disagree with the rounded vm_gb the warning shows (a 16 GB slider reading
  # ~15.6 GiB would stay silent here AND trip the warning there). Anything below
  # the target is "undersized" and stays silent.
  if [[ "$host_bytes" =~ ^[0-9]+$ ]] && (( host_bytes > 0 )); then
    (( vm_gb < rec_gb )) && return 0
  else
    (( vm_gb < _PRESSURE_VM_ADVISORY_BYTES / 1073741824 )) && return 0
  fi

  # Memory is sized right. One more check before the all-clear: swap. The memory
  # slider and the swap slider are separate, so a user who bumps memory (often on
  # our own advice) can leave swap at the Docker Desktop default, too little
  # overflow for a brief spike, so a session freezes instead of paging out. When
  # swap reads below the target, say what's right (memory) AND what still needs a
  # nudge (swap) rather than a blanket "tuned". `docker info` can't report swap,
  # so this reads Docker Desktop's settings file; a value we can't trust returns
  # empty and falls through to the all-clear (never warn on a guess). Same
  # whitespace as the tuned line: one blank above unless a gap is open, none below.
  local swap_bytes
  swap_bytes="$(_docker_vm_swap_bytes)"
  if [[ "$swap_bytes" =~ ^[0-9]+$ ]] && (( swap_bytes < _SWAP_ADVISORY_BYTES )); then
    [[ "${_ONSTART_GAP_OPEN:-0}" == "1" ]] || echo ""
    # Describe the shortfall honestly. NOT _human_bytes here: it rounds (%.0f), so
    # 1.5 GB would read "2 GB" and contradict the "set Swap ≥ 2 GB" step below, and
    # 0 would render "?". Floored GB never rounds a sub-2 GB value up; sub-GB shows
    # MB; 0 reads as "disabled".
    if (( swap_bytes == 0 )); then
      warn "Docker memory is sized right, but swap is ${BOLD}disabled${RESET}. A memory spike can freeze a session instead of paging out."
    else
      local swap_human
      if (( swap_bytes < 1073741824 )); then
        swap_human="$(( swap_bytes / 1048576 )) MB"
      else
        swap_human="$(( swap_bytes / 1073741824 )) GB"
      fi
      warn "Docker memory is sized right, but its swap is only ${BOLD}${swap_human}${RESET}. A memory spike can freeze a session instead of paging out."
    fi
    echo -e "    ${DIM}Add overflow headroom (Docker Desktop only):${RESET}"
    echo -e "    ${DIM}•${RESET} ${BOLD}Settings → Resources → Advanced${RESET}${DIM}: set ${RESET}${BOLD}Swap ≥ 2 GB${RESET}${DIM}, then Apply & restart${RESET}"
    _VM_ADVISORY_SHOWN=1   # defensive symmetry with the pressure check; no on-start step reads it after this today
    return 0
  fi

  [[ "${_ONSTART_GAP_OPEN:-0}" == "1" ]] || echo ""
  # No session count: "many" is honest (light sessions run dozens), a number reads
  # as a hard cap and isn't true. A box can OOM only if it does genuinely heavy
  # memory work, the same way Claude Code can outside Docker, and that is rare.
  success "Docker tuned for Cleat ${RESET}${DIM}(${vm_gb} GB VM, room for many parallel sessions)${RESET}"
}

cmd_clean() {
  cmd_stop_all
  if image_exists; then
    info "Removing image..."
    docker rmi "$IMAGE_NAME" > /dev/null
    success "Image removed."
  else
    info "No image to remove."
  fi

  # Prune orphaned box descriptions (boxes whose container no longer exists).
  if [[ -d "$CLEAT_BOXES_DIR" ]]; then
    local _bf _bcn
    for _bf in "$CLEAT_BOXES_DIR"/*; do
      [[ -f "$_bf" ]] || continue
      _bcn="$(basename "$_bf")"
      if ! container_exists "$_bcn"; then rm -f "$_bf" 2>/dev/null || true; fi
    done
  fi

  # Prune orphaned per-container runtime dirs: overlays for containers that no
  # longer exist (project dir moved/deleted, or the container was removed
  # outside cleat). cmd_stop_all only stops containers, so live ones still
  # exist and their dirs are kept. Kept LAST so its if/fi guard remains
  # cmd_clean's final statement (a trailing false `[[ ]] &&` would exit 1).
  if [[ -d "$CLEAT_RUN_DIR" ]]; then
    local _d _cn _pruned=0
    for _d in "$CLEAT_RUN_DIR"/*/; do
      [[ -d "$_d" ]] || continue
      _cn="$(basename "$_d")"
      if ! container_exists "$_cn"; then
        rm -rf "$_d" 2>/dev/null || true
        _pruned=$((_pruned + 1))
      fi
    done
    # Use if/fi, not `[[ ]] &&`: a trailing false test would make cmd_clean
    # (the last statement in main) exit 1 on a successful run with 0 orphans.
    if [[ $_pruned -gt 0 ]]; then info "Pruned ${_pruned} orphaned runtime dir(s)."; fi
  fi
}

cmd_nuke() {
  echo ""
  warn "This will remove ${BOLD}ALL${RESET} Cleat containers, images, and volumes."
  echo -e "  ${DIM}Your project files and ~/.claude auth are safe (they live on the host).${RESET}"
  echo ""
  read -rp "  Type 'nuke' to confirm: " confirm
  if [[ "$confirm" != "nuke" ]]; then
    info "Aborted."
    return
  fi
  echo ""

  local containers
  containers=$(docker ps -a --filter "name=^cleat-" --format '{{.Names}}' 2>/dev/null)
  if [[ -n "$containers" ]]; then
    info "Removing containers..."
    echo "$containers" | while read -r c; do
      docker rm -f "$c" > /dev/null 2>&1
      echo -e "    ${DIM}removed ${c}${RESET}"
    done
  fi

  if image_exists; then
    info "Removing image..."
    docker rmi -f "$IMAGE_NAME" > /dev/null 2>&1
  fi

  # Per-container runtime dirs (overlays / clipboard / hook spool) are persistent
  # now, so /tmp rotation won't reclaim them: wipe them explicitly.
  if [[ -d "$CLEAT_RUN_DIR" ]]; then
    info "Removing per-container runtime dirs..."
    rm -rf "$CLEAT_RUN_DIR" 2>/dev/null || true
  fi

  # Per-project persistent .claude.json store (trust/MCP approvals): nuke
  # removes everything Cleat-related, so clear it too. (cleat rm preserves it.)
  if [[ -d "$CLEAT_PROJECTS_DIR" ]]; then
    info "Removing per-project Claude state..."
    rm -rf "$CLEAT_PROJECTS_DIR" 2>/dev/null || true
  fi

  if [[ -d "$CLEAT_BOXES_DIR" ]]; then
    rm -rf "$CLEAT_BOXES_DIR" 2>/dev/null || true
  fi

  local dangling
  dangling=$(docker images -f "dangling=true" -q 2>/dev/null)
  if [[ -n "$dangling" ]]; then
    info "Pruning dangling images..."
    docker image prune -f > /dev/null 2>&1
  fi

  info "Pruning build cache..."
  docker builder prune -f > /dev/null 2>&1 || true

  echo ""
  success "Nuked. Everything Cleat-related is gone from Docker."
  echo -e "  ${DIM}Run ${BOLD}cleat start${RESET}${DIM} to rebuild from scratch.${RESET}"
  echo ""
}

cmd_install() {
  local target="/usr/local/bin"
  local script_path
  script_path="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"

  info "Installing CLI symlink..."

  if [[ -w "$target" ]]; then
    ln -sf "$script_path" "$target/cleat"
  else
    sudo ln -sf "$script_path" "$target/cleat"
  fi

  success "Installed! You can now use ${BOLD}cleat${RESET} from anywhere."
  echo ""
  echo -e "  ${DIM}Try it:${RESET}"
  echo -e "    ${BOLD}cd ~/some-project && cleat start${RESET}"
  echo ""
}

cmd_uninstall() {
  local target="/usr/local/bin"
  info "Removing CLI symlinks..."
  if [[ -w "$target" ]]; then
    rm -f "$target/cleat"
  else
    sudo rm -f "$target/cleat"
  fi
  success "Uninstalled."
}

# ── cleat config ────────────────────────────────────────────────────────────
_cap_description() {
  case "$1" in
    git)    echo "Mount ~/.gitconfig (read-only) for commit identity" ;;
    ssh)    echo "Mount ~/.ssh (read-only) and forward SSH agent" ;;
    env)    echo "Load env vars from ~/.config/cleat/env and .cleat.env" ;;
    hooks)  echo "Run your Claude Code hooks on the host (global + project)" ;;
    gh)     echo "GitHub CLI auth (persists across rm/nuke/rebuild)" ;;
    docker) echo "Host Docker socket (breaks sandbox) to test Docker apps" ;;
    *)      echo "(unknown capability)" ;;
  esac
}

_scaffold_cleat_env() {
  local project="${1:-$PWD}"
  local env_file="$project/.cleat.env"
  [[ -f "$env_file" ]] && return 0
  cat > "$env_file" << 'ENVEOF'
# .cleat.env: project environment variables for Cleat
# Loaded when the "env" capability is enabled.
# Add to .gitignore: do not commit secrets.
#
# KEY=VALUE  set explicitly
# KEY        inherit from host environment
#
# Example:
# GH_TOKEN
# DATABASE_URL=postgres://localhost:5432/myapp
ENVEOF
  success "Created ${DIM}${env_file}${RESET} (add to .gitignore)"
}

# ── TUI config picker ──────────────────────────────────────────────────────

_config_picker_draw() {
  local cursor="$1"
  local toggled="$2"
  local cap_count=${#KNOWN_CAPS[@]}
  local i=0
  while [[ $i -lt $cap_count ]]; do
    local cap="${KNOWN_CAPS[$i]}"
    local marker="${DIM}·${RESET}"
    case ",${toggled}," in *,"$cap",*) marker="${GREEN}✔${RESET}" ;; esac
    printf '\033[2K' # clear line
    if [[ $i -eq $cursor ]]; then
      echo -e "  ${CYAN}▸${RESET} [${marker}] ${BOLD}${cap}${RESET}  $(_cap_description "$cap")"
    else
      echo -e "    [${marker}] ${cap}  ${DIM}$(_cap_description "$cap")${RESET}"
    fi
    i=$((i + 1))
  done
}

_config_picker_tui() {
  local config_file="$1"
  local scope="$2"

  echo ""
  echo -e "  ${BOLD}Cleat Capabilities${RESET}"
  echo ""
  local scope_label
  if [[ "$scope" == "project" ]]; then
    scope_label="project ($(pwd)/.cleat)"
  else
    scope_label="global (~/.config/cleat/config)"
  fi
  echo -e "  ${DIM}Scope: ${scope_label}${RESET}"
  echo ""

  local toggled=""
  local cap
  while IFS= read -r cap; do
    [[ -n "$cap" ]] && toggled="${toggled:+${toggled},}${cap}"
  done < <(_read_caps_from_file "$config_file")

  local cursor=0
  local cap_count=${#KNOWN_CAPS[@]}

  tput civis 2>/dev/null || true

  _config_picker_draw "$cursor" "$toggled"
  echo ""
  echo -e "  ${DIM}↑/↓ navigate  ␣ toggle  ⏎ save  q cancel${RESET}"

  # Move back above list for redraw
  printf '\033[%dA' "$((cap_count + 2))"

  while true; do
    local key
    key="$(_read_keypress)"

    case "$key" in
      UP)
        [[ $cursor -gt 0 ]] && cursor=$((cursor - 1))
        ;;
      DOWN)
        [[ $cursor -lt $((cap_count - 1)) ]] && cursor=$((cursor + 1))
        ;;
      SPACE)
        local current_cap="${KNOWN_CAPS[$cursor]}"
        case ",${toggled}," in
          *,"$current_cap",*)
            local _new=""
            local _c
            for _c in $(echo "$toggled" | tr ',' ' '); do
              [[ "$_c" == "$current_cap" ]] && continue
              _new="${_new:+${_new},}${_c}"
            done
            toggled="$_new"
            ;;
          *)
            toggled="${toggled:+${toggled},}${current_cap}"
            ;;
        esac
        ;;
      ENTER)
        tput cnorm 2>/dev/null || true
        printf '\033[%dB' "$((cap_count + 2))"
        printf '\033[2K'
        echo ""

        local final_caps=()
        for cap in "${KNOWN_CAPS[@]}"; do
          case ",${toggled}," in *,"$cap",*) final_caps+=("$cap") ;; esac
        done
        _write_caps_to_file "$config_file" "${final_caps[@]+"${final_caps[@]}"}"
        success "Saved to ${config_file}"

        case ",${toggled}," in
          *,env,*)
            if [[ ! -f "$(pwd)/.cleat.env" ]]; then
              echo ""
              local yn=""
              _ask_yn yn "Create .cleat.env in current project? [Y/n] "
              if [[ -z "$yn" || "$yn" == [yY]* ]]; then
                _scaffold_cleat_env "$(pwd)"
              fi
            fi
            ;;
        esac
        return
        ;;
      QUIT|ESC)
        tput cnorm 2>/dev/null || true
        printf '\033[%dB' "$((cap_count + 2))"
        printf '\033[2K'
        echo ""
        info "Cancelled."
        return
        ;;
    esac

    _config_picker_draw "$cursor" "$toggled"
    printf '\033[%dA' "$cap_count"
  done
}

_config_picker_text() {
  local config_file="$1"
  local scope="$2"

  echo ""
  echo -e "  ${BOLD}Cleat Capabilities${RESET}"
  echo ""
  local scope_label
  if [[ "$scope" == "project" ]]; then
    scope_label="project ($(pwd)/.cleat)"
  else
    scope_label="global (~/.config/cleat/config)"
  fi
  echo -e "  ${DIM}Scope: ${scope_label}${RESET}"
  echo ""

  local _active=""
  local cap
  while IFS= read -r cap; do
    [[ -n "$cap" ]] && _active="${_active:+${_active},}${cap}"
  done < <(_read_caps_from_file "$config_file")

  for cap in "${KNOWN_CAPS[@]}"; do
    local marker="${DIM}·${RESET}"
    case ",${_active}," in *,"$cap",*) marker="${GREEN}✔${RESET}" ;; esac
    echo -e "    [${marker}] ${BOLD}${cap}${RESET}     $(_cap_description "$cap")"
  done

  echo ""
  echo -e "  ${DIM}Toggle: type name to flip, \"done\" to save, \"q\" to cancel${RESET}"

  while true; do
    echo -n "  > "
    local input
    read -r input
    input="${input#"${input%%[![:space:]]*}"}"
    input="${input%"${input##*[![:space:]]}"}"

    case "$input" in
      done)
        local final_caps=()
        for cap in "${KNOWN_CAPS[@]}"; do
          case ",${_active}," in *,"$cap",*) final_caps+=("$cap") ;; esac
        done
        _write_caps_to_file "$config_file" "${final_caps[@]+"${final_caps[@]}"}"
        success "Saved to ${config_file}"

        case ",${_active}," in
          *,env,*)
            if [[ ! -f "$(pwd)/.cleat.env" ]]; then
              echo ""
              local yn=""
              _ask_yn yn "Create .cleat.env in current project? [Y/n] "
              if [[ -z "$yn" || "$yn" == [yY]* ]]; then
                _scaffold_cleat_env "$(pwd)"
              fi
            fi
            ;;
        esac
        return
        ;;
      q|quit)
        info "Cancelled."
        return
        ;;
      *)
        local found=false
        for known in "${KNOWN_CAPS[@]}"; do
          if [[ "$known" == "$input" ]]; then
            found=true
            case ",${_active}," in
              *,"$input",*)
                local _new_active=""
                local _c
                for _c in $(echo "$_active" | tr ',' ' '); do
                  [[ "$_c" == "$input" ]] && continue
                  _new_active="${_new_active:+${_new_active},}${_c}"
                done
                _active="$_new_active"
                success "${input} disabled"
                ;;
              *)
                _active="${_active:+${_active},}${input}"
                success "${input} enabled"
                ;;
            esac
            break
          fi
        done
        if ! $found; then
          warn "Unknown capability: ${input}. Available: ${KNOWN_CAPS[*]}"
        fi
        ;;
    esac
  done
}

cmd_config() {
  local scope="global"
  local action=""
  local cap_name=""
  local box=""

  # Parse config subcommand flags
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project)  scope="project"; shift ;;
      --enable)
        action="enable"
        if [[ $# -lt 2 ]]; then cap_name=""; shift; else cap_name="$2"; shift 2; fi
        ;;
      --disable)
        action="disable"
        if [[ $# -lt 2 ]]; then cap_name=""; shift; else cap_name="$2"; shift 2; fi
        ;;
      --list)     action="list"; shift ;;
      --*)
        error "Unknown config option: $1"
        exit 1
        ;;
      *)
        # A bareword positional is a box name → operate on that box's project
        # cap file (.cleat.<box>). "main" maps to the base .cleat.
        if [[ -n "$box" ]]; then
          error "Unexpected argument: ${BOLD}$1${RESET}"
          exit 1
        fi
        if ! _validate_box_name "$1"; then
          error "Invalid box name: ${BOLD}$1${RESET}"
          echo -e "    ${DIM}Box names: lowercase letters, digits, '-' or '_'; max 31 chars.${RESET}"
          exit 1
        fi
        box="$1"; scope="project"; shift
        ;;
    esac
  done

  local config_file
  if [[ -n "$box" && "$box" != "main" ]]; then
    config_file="$(pwd)/.cleat.$box"
  elif [[ "$scope" == "project" ]]; then
    config_file="$(pwd)/.cleat"
  else
    config_file="$CLEAT_GLOBAL_CONFIG"
  fi

  # ── Direct mode: --list
  if [[ "$action" == "list" ]]; then
    echo ""
    echo -e "  ${BOLD}Capabilities${RESET}"
    echo ""
    # Read current caps
    local _active_list=""
    local cap
    while IFS= read -r cap; do
      [[ -n "$cap" ]] && _active_list="${_active_list:+${_active_list},}${cap}"
    done < <(_read_caps_from_file "$CLEAT_GLOBAL_CONFIG")
    # Also read project caps if available (box-aware: .cleat.<box> else .cleat)
    local _proj_caps_file
    _proj_caps_file="$(_project_caps_file "$(pwd)" "${box:-main}")"
    if [[ -f "$_proj_caps_file" ]]; then
      while IFS= read -r cap; do
        [[ -n "$cap" ]] && case ",${_active_list}," in *,"$cap",*) ;; *) _active_list="${_active_list:+${_active_list},}${cap}" ;; esac
      done < <(_read_caps_from_file "$_proj_caps_file")
    fi

    for cap in "${KNOWN_CAPS[@]}"; do
      local marker="${DIM}·${RESET}"
      case ",${_active_list}," in *,"$cap",*) marker="${GREEN}✔${RESET}" ;; esac
      echo -e "    [${marker}] ${BOLD}${cap}${RESET}  ${DIM}$(_cap_description "$cap")${RESET}"
    done
    echo ""
    echo -e "  ${DIM}Config: ${config_file}${RESET}"
    echo ""
    return
  fi

  # ── Direct mode: --enable / --disable
  if [[ -n "$action" ]]; then
    if [[ -z "$cap_name" ]]; then
      error "Missing capability name. Usage: cleat config --${action} <name>"
      exit 1
    fi

    # Validate capability name
    local valid=false
    for known in "${KNOWN_CAPS[@]}"; do
      [[ "$known" == "$cap_name" ]] && valid=true
    done
    if ! $valid; then
      error "Unknown capability: ${BOLD}${cap_name}${RESET}"
      echo -e "    ${DIM}Available: ${KNOWN_CAPS[*]}${RESET}"
      exit 1
    fi

    # Read current caps
    local current_caps=()
    while IFS= read -r cap; do
      [[ -n "$cap" ]] && current_caps+=("$cap")
    done < <(_read_caps_from_file "$config_file")

    if [[ "$action" == "enable" ]]; then
      # Check if already enabled
      local already=false
      for cap in "${current_caps[@]+"${current_caps[@]}"}"; do
        [[ "$cap" == "$cap_name" ]] && already=true
      done
      if ! $already; then
        current_caps+=("$cap_name")
      fi
      _write_caps_to_file "$config_file" "${current_caps[@]}"
      success "${cap_name} enabled"
      echo -e "    ${DIM}$(_cap_description "$cap_name")${RESET}"

      # Scaffold .cleat.env when enabling env capability
      if [[ "$cap_name" == "env" ]]; then
        _scaffold_cleat_env "$(pwd)"
      fi
    else
      # Disable: remove from list
      local new_caps=()
      for cap in "${current_caps[@]+"${current_caps[@]}"}"; do
        [[ "$cap" != "$cap_name" ]] && new_caps+=("$cap")
      done
      _write_caps_to_file "$config_file" "${new_caps[@]+"${new_caps[@]}"}"
      success "${cap_name} disabled"
    fi
    return
  fi

  # ── Interactive mode (no flags)
  if [[ -t 0 ]] && [[ -t 1 ]]; then
    _config_picker_tui "$config_file" "$scope"
  else
    _config_picker_text "$config_file" "$scope"
  fi
}

# ── Workspace trust subcommands ────────────────────────────────────────────
#
# `cleat trust [path]`   : record approval for a project's .cleat caps
# `cleat trust --list`   : list all trusted projects
# `cleat untrust [path]` : remove approval for a project
#
# Normally users will be prompted automatically on first run. These
# subcommands exist for scripting, manual approval, and inspection.

cmd_trust() {
  # Flag parsing
  local list_mode=0
  local -a pos_args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --list) list_mode=1; shift ;;
      --help|-h)
        echo "Usage: cleat trust [path]      Record trust for a project's .cleat"
        echo "       cleat trust --list      List all trusted projects"
        return 0 ;;
      *) pos_args+=("$1"); shift ;;
    esac
  done

  if [[ $list_mode -eq 1 ]]; then
    if [[ ! -f "$CLEAT_TRUST_FILE" ]]; then
      info "No trusted projects."
      return 0
    fi
    local count
    count="$(_trust_list | wc -l | tr -d ' ')"
    if [[ "$count" -eq 0 ]]; then
      info "No trusted projects."
      return 0
    fi
    echo -e "  ${BOLD}Trusted projects${RESET} ${DIM}(${count})${RESET}"
    echo ""
    _trust_list | while IFS=$'\t' read -r p b; do
      [[ -z "$p" ]] && continue
      [[ -z "$b" ]] && b="main"
      local marker="${GREEN}●${RESET}"
      # Indicate if the box's cap file has changed since approval
      local _cf _stored _cur
      _cf="$(_project_caps_file "$p" "$b")"
      _stored="$(_trust_lookup "$p" "$b")"
      _cur="$(_hash_cleat_caps "$_cf")"
      if [[ -f "$_cf" && -n "$_cur" && "$_stored" != "$_cur" ]]; then
        marker="${YELLOW}●${RESET}"
      fi
      if [[ "$b" == "main" ]]; then
        echo -e "    ${marker} ${p}"
      else
        echo -e "    ${marker} ${p}  ${DIM}[${b}]${RESET}"
      fi
    done
    echo ""
    echo -e "  ${DIM}${GREEN}●${DIM} trusted at current caps   ${YELLOW}●${DIM} .cleat changed since approval${RESET}"
    return 0
  fi

  # Record trust for a specific project (default: current dir)
  local project
  project="$(resolve_project "${pos_args[0]:-}")"
  if [[ ! -f "$project/.cleat" ]]; then
    error "No .cleat file found in ${BOLD}${project}${RESET}"
    echo -e "    ${DIM}Nothing to trust. This project has no per-project capability config.${RESET}"
    exit 1
  fi
  local hash
  hash="$(_hash_cleat_caps "$project/.cleat")"
  if [[ -z "$hash" ]]; then
    error "Project .cleat has no capabilities to trust"
    exit 1
  fi
  if _trust_record "$project" "$hash"; then
    success "Trusted ${BOLD}${project}${RESET}"
    local caps
    caps="$(_read_caps_from_file "$project/.cleat" | _canonical_caps)"
    echo -e "    ${DIM}Approved caps: ${caps}${RESET}"
  else
    exit 1
  fi
}

cmd_untrust() {
  case "${1:-}" in
    --help|-h)
      echo "Usage: cleat untrust [path]    Remove trust for a project"
      return 0 ;;
  esac
  local project
  project="$(resolve_project "${1:-}")"
  local had
  had="$(_trust_lookup "$project")"
  _trust_remove "$project"
  if [[ -n "$had" ]]; then
    success "Removed trust for ${BOLD}${project}${RESET}"
  else
    info "${project} was not trusted"
  fi
}

# ── Box descriptions ────────────────────────────────────────────────────────
#
# `cleat describe`             : show the main box's description
# `cleat describe <box>`       : show that box's description
# `cleat describe <box> text`  : set/update it (no docker calls; never recreates)
#
# The description is host-side metadata (see concept/20-boxes.md), so updating
# it never restarts or recreates the container: the writable layer (e.g. an
# `az login`) is untouched.
cmd_describe() {
  case "${1:-}" in
    --help|-h)
      echo "Usage: cleat describe [box] [text]"
      echo "       cleat describe <box>          Show a box's description"
      echo "       cleat describe <box> \"text\"   Set/update it (no container restart)"
      return 0 ;;
  esac

  local box="main"
  if [[ $# -gt 0 ]]; then
    if ! _validate_box_name "$1"; then
      error "Invalid box name: ${BOLD}$1${RESET}"
      echo -e "    ${DIM}Box names: lowercase letters, digits, '-' or '_'; max 31 chars.${RESET}"
      exit 1
    fi
    box="$1"; shift
  fi

  local project cname
  project="$(resolve_project)"
  cname="$(container_name_for "$project" "$box")"

  if [[ $# -gt 0 ]]; then
    # Set/update: remaining args are the description, joined and stored as data.
    _box_desc_write "$cname" "$*"
    success "Description set for box ${BOLD}${box}${RESET}"
    # Print the description as DATA (%s), never through echo -e, which would
    # interpret backslash escapes / ANSI in user text. Colors use %b.
    printf '    %b%s%b\n' "$DIM" "$*" "$RESET"
  else
    local cur
    cur="$(_box_desc_read "$cname")"
    if [[ -n "$cur" ]]; then
      printf '  %b%s%b  %s\n' "$BOLD" "$box" "$RESET" "$cur"
    else
      info "No description set for box ${BOLD}${box}${RESET}."
      echo -e "    ${DIM}Set one with: cleat describe ${box} \"...\"${RESET}"
    fi
  fi
}

# ── Version & Update ──────────────────────────────────────────────────────
cmd_version() {
  echo -e "  ${BOLD}cleat${RESET} ${DIM}v${VERSION}${RESET}"
}

cmd_update() {
  info "Checking for updates..."

  if [[ ! -d "$REPO_DIR/.git" ]]; then
    error "Cannot auto-update: not a git installation."
    echo -e "    ${DIM}Re-install with: curl -fsSL https://raw.githubusercontent.com/cleatdev/cleat/main/install.sh | bash${RESET}"
    exit 1
  fi

  git -C "$REPO_DIR" fetch --tags --force --quiet 2>/dev/null || {
    error "Failed to fetch updates. Check your internet connection."
    exit 1
  }

  local remote_version
  remote_version=$(latest_remote_tag)

  if [[ -z "$remote_version" ]]; then
    error "Could not determine remote version. No tags found."
    exit 1
  fi

  if [[ "$VERSION" == "$remote_version" ]]; then
    success "Already on the latest version (v${VERSION})."
    return
  fi

  info "Updating v${VERSION} -> v${remote_version}..."
  git -C "$REPO_DIR" checkout "v${remote_version}" --quiet 2>/dev/null || {
    error "Failed to checkout v${remote_version}."
    exit 1
  }
  success "Updated to v${remote_version}."

  rm -f "$UPDATE_CHECK_FILE" 2>/dev/null || true
  # The new release image bundles its own Claude Code, so invalidate the
  # Claude update-check cache to re-check against the fresh image next start.
  rm -f "$CLAUDE_CHECK_FILE" 2>/dev/null || true

  # Pull the prebuilt image matching the new version. _do_pull prints its own
  # progress/result; on failure the user can rebuild locally.
  if ! _do_pull "$remote_version"; then
    echo ""
    echo -e "  ${DIM}To update the container image locally:${RESET}"
    echo -e "    ${BOLD}cleat rebuild${RESET}"
  fi
  echo ""
}

# ── Help ────────────────────────────────────────────────────────────────────
cmd_help() {
  header
  echo -e "  ${BOLD}USAGE${RESET}"
  echo -e "    cleat ${DIM}<command> [box] [options]${RESET}"
  echo -e "    ${DIM}Always operates on the current directory. [box] is a named sandbox${RESET}"
  echo -e "    ${DIM}for this project (default: main), e.g. ${RESET}${BOLD}cleat start az${RESET}"
  echo ""
  echo -e "  ${BOLD}QUICK START${RESET}"
  echo -e "    ${GREEN}start${RESET}   ${DIM}[box]${RESET}      Build + run + launch Claude (all-in-one)"
  echo -e "    ${GREEN}resume${RESET}  ${DIM}[box]${RESET}      Resume the last Claude Code session"
  echo ""
  echo -e "  ${BOLD}LIFECYCLE${RESET}"
  echo -e "    ${GREEN}build${RESET}              Build the Docker image (shared across projects)"
  echo -e "    ${GREEN}rebuild${RESET}            Force rebuild the image from scratch"
  echo -e "    ${GREEN}upgrade-claude${RESET}     Update bundled Claude Code in the image ${DIM}[stable|latest|VERSION]${RESET}"
  echo -e "    ${GREEN}run${RESET}     ${DIM}[box]${RESET}      Start a container for this project"
  echo -e "    ${GREEN}stop${RESET}    ${DIM}[box]${RESET}      Stop container (keeps it for resume)"
  echo -e "    ${GREEN}rm${RESET}      ${DIM}[box]${RESET}      Stop + remove container permanently"
  echo -e "    ${GREEN}stop-all${RESET}           Stop all Cleat containers"
  echo -e "    ${GREEN}prune${RESET}              Remove stale cleat images ${DIM}(old builds, superseded pulls; boxes untouched)${RESET}"
  echo -e "    ${GREEN}clean${RESET}              Stop everything + remove image"
  echo -e "    ${RED}nuke${RESET}               Remove ALL containers, images, and build cache"
  echo ""
  echo -e "  ${BOLD}CAPABILITIES${RESET}"
  echo -e "    ${GREEN}config${RESET} ${DIM}[box]${RESET}        Interactive wizard ${DIM}(no box = global; box = .cleat.<box>)${RESET}"
  echo -e "    ${GREEN}config${RESET} ${DIM}[box]${RESET} --list       List effective capabilities"
  echo -e "    ${GREEN}config${RESET} ${DIM}[box]${RESET} --enable ${DIM}<cap>${RESET}   Enable a capability"
  echo -e "    ${GREEN}config${RESET} ${DIM}[box]${RESET} --disable ${DIM}<cap>${RESET}  Disable a capability"
  echo ""
  echo -e "  ${BOLD}INTERACT${RESET}"
  echo -e "    ${GREEN}claude${RESET}  ${DIM}[box]${RESET}      Attach Claude Code (--dangerously-skip-permissions)"
  echo -e "    ${GREEN}shell${RESET}   ${DIM}[box]${RESET}      Open bash in the container"
  echo -e "    ${GREEN}login${RESET}   ${DIM}[box]${RESET}      Authenticate with Anthropic team account"
  echo -e "    ${GREEN}logs${RESET}    ${DIM}[box]${RESET}      Tail container logs"
  echo ""
  echo -e "  ${BOLD}INFO${RESET}"
  echo -e "    ${GREEN}status${RESET}             Show this project's boxes, auth & caps"
  echo -e "    ${GREEN}ps${RESET}                 List all Cleat containers (running & stopped)"
  echo -e "    ${GREEN}describe${RESET} ${DIM}[box] [text]${RESET}  Show or set a box's description"
  echo ""
  echo -e "  ${BOLD}SETUP${RESET}"
  echo -e "    ${GREEN}update${RESET}             Check for updates and install the latest version"
  echo -e "    ${GREEN}version${RESET}            Show current version"
  echo -e "    ${GREEN}install${RESET}            Symlink ${BOLD}cleat${RESET} to /usr/local/bin"
  echo -e "    ${GREEN}uninstall${RESET}          Remove symlinks"
  echo ""
  echo -e "  ${BOLD}FLAGS${RESET} ${DIM}(apply to start, run, resume, claude)${RESET}"
  echo -e "    ${GREEN}--cap${RESET} ${DIM}<name>${RESET}       Enable a capability for this session only"
  echo -e "    ${GREEN}--env${RESET} ${DIM}KEY=VALUE${RESET}    Pass environment variable to container"
  echo -e "    ${GREEN}--env${RESET} ${DIM}KEY${RESET}          Inherit from host environment"
  echo -e "    ${GREEN}--env-file${RESET} ${DIM}PATH${RESET}    Load env vars from file"
  echo -e "    ${GREEN}--desc${RESET} ${DIM}<text>${RESET}      Set a box description at start"
  echo ""
  echo -e "  ${BOLD}EXAMPLES${RESET}"
  echo -e "    ${DIM}cd ~/code/my-app && cleat start${RESET}           ${DIM}# first time (main box)${RESET}"
  echo -e "    ${DIM}cleat start az --desc \"cloud box\"${RESET}         ${DIM}# a separate az sandbox${RESET}"
  echo -e "    ${DIM}cleat config az --enable docker${RESET}           ${DIM}# per-box capabilities${RESET}"
  echo -e "    ${DIM}cleat resume dev${RESET}                          ${DIM}# resume the dev box${RESET}"
  echo -e "    ${DIM}cleat status${RESET}                              ${DIM}# list this project's boxes${RESET}"
  echo -e "    ${DIM}cleat --cap ssh --env GH_TOKEN start${RESET}      ${DIM}# one-off session${RESET}"
  echo ""
}

# ── Global flag parsing ────────────────────────────────────────────────────
# Extract --cap, --env, --env-file flags before dispatching to subcommands.
# Remaining args are returned in _REMAINING_ARGS.
parse_global_flags() {
  _CLI_CAPS=()
  _CLI_ENVS=()
  _CLI_ENV_FILES=()
  _CLI_TRUST_PROJECT=0
  _CLI_DESC_SET=0
  _REMAINING_ARGS=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --trust-project)
        _CLI_TRUST_PROJECT=1
        shift
        ;;
      --cap)
        if [[ -z "${2:-}" ]]; then
          error "Missing capability name after --cap"
          exit 1
        fi
        # Validate against known capabilities
        local _cap_valid=false
        for _known in "${KNOWN_CAPS[@]}"; do
          [[ "$_known" == "$2" ]] && _cap_valid=true
        done
        if ! $_cap_valid; then
          error "Unknown capability: ${BOLD}$2${RESET}"
          echo -e "    ${DIM}Available: ${KNOWN_CAPS[*]}${RESET}"
          exit 1
        fi
        _CLI_CAPS+=("$2")
        shift 2
        ;;
      --env)
        if [[ -z "${2:-}" ]]; then
          error "Missing value after --env"
          exit 1
        fi
        _CLI_ENVS+=("$2")
        shift 2
        ;;
      --env-file)
        if [[ -z "${2:-}" ]]; then
          error "Missing path after --env-file"
          exit 1
        fi
        _CLI_ENV_FILES+=("$2")
        shift 2
        ;;
      --desc)
        if [[ -z "${2:-}" ]]; then
          error "Missing text after --desc"
          exit 1
        fi
        _CLI_DESC="$2"
        _CLI_DESC_SET=1
        shift 2
        ;;
      *)
        _REMAINING_ARGS+=("$1")
        shift
        ;;
    esac
  done
}

# ── Main ────────────────────────────────────────────────────────────────────
main() {
  # Capture the original argv verbatim BEFORE flag parsing consumes it, so the
  # CLI self-update preflight can re-exec the new version with the same command.
  _CLEAT_ORIG_ARGV=("$@")

  # Defense-in-depth: always kill spinner and restore cursor on exit.
  # exec_claude sets its own trap (which calls _cleanup_spin internally).
  trap '_cleanup_spin' EXIT

  parse_global_flags "$@"
  set -- "${_REMAINING_ARGS[@]+"${_REMAINING_ARGS[@]}"}"

  local cmd="${1:-start}"
  shift 2>/dev/null || true

  # Interactive CLI self-update preflight: only for the session-launching
  # commands, and before any docker work: accepting re-execs the new version,
  # which then drives the entire run. The Docker pressure check (an amber, often
  # crucial resource warning) runs BEFORE the release highlight so it sits at the
  # top of the startup, above the editorial "New in …" note: act on the warning
  # first, read the news second. The positive "Docker tuned" confirmation runs
  # LAST, directly above the bring-up, so a well-sized VM gets a one-line nod that
  # sticks to "Image ready" (it's silent, and the warning shows instead, when the
  # VM is undersized).
  case "$cmd" in
    start|resume|r|run|claude|shell|sh)
      _maybe_prompt_cli_update
      _maybe_sweep_idle_boxes "$@"
      _maybe_check_docker_pressure
      _maybe_show_release_highlight
      _maybe_announce_docker_ready
      ;;
  esac

  case "$cmd" in
    start)     _set_box "$@"; cmd_start ;;
    resume|r)  _set_box "$@"; cmd_resume ;;
    build)     cmd_build "$@" ;;
    rebuild)   cmd_rebuild "$@" ;;
    upgrade-claude) cmd_upgrade_claude "$@" ;;
    run)       _set_box "$@"; cmd_run ;;
    stop)      _set_box "$@"; cmd_stop ;;
    rm)        _set_box "$@"; cmd_rm ;;
    stop-all)  cmd_stop_all "$@" ;;
    shell|sh)  _set_box "$@"; cmd_shell ;;
    login)     _set_box "$@"; cmd_login ;;
    claude)    _set_box "$@"; cmd_claude ;;
    logs)      _set_box "$@"; cmd_logs ;;
    ps)        cmd_ps "$@" ;;
    status|st) cmd_status "$@" ;;
    config)    cmd_config "$@" ;;
    describe)  cmd_describe "$@" ;;
    trust)     cmd_trust "$@" ;;
    untrust)   cmd_untrust "$@" ;;
    clean)     cmd_clean "$@" ;;
    prune)     cmd_prune "$@" ;;
    nuke)      cmd_nuke "$@" ;;
    update)    cmd_update "$@" ;;
    version|-v|--version) cmd_version ;;
    install)   cmd_install "$@" ;;
    uninstall) cmd_uninstall "$@" ;;
    help|-h|--help) cmd_help ;;
    *)
      error "Unknown command: ${cmd}"
      cmd_help
      exit 1
      ;;
  esac
}

# Only run main when executed directly (not when sourced for testing)
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
